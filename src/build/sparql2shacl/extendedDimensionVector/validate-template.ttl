@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix qfn: <http://qudt.org/shacl/functions#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

qfn:ExtendedDVConsistency
  a owl:Ontology ;
  owl:imports qfn: .

qfn:ExtendedDVConsistencyRule
  a sh:NodeShape ;
  sh:severity sh:Warning ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message """{$this}: qudt:hasExtendedDimensionVector is {?actualEdimVec} but factor
units compute {?calculatedEdimVec}. If the discrepancy is intentional (e.g. torque units
where R is assigned by convention rather than derived from an angular factor unit), it is
documented in DESIGN-NOTES.md as a Group-2 dimensional-cancellation case.""" ;
    sh:prefixes qfn: ;
    sh:select """

    {{QUERY_WITHOUT_PREFIXES}}

    """ ;
  ] ;
  sh:targetClass qudt:Unit .


