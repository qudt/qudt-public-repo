@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix datatype: <http://qudt.org/vocab/datatype/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .

qudt:BitEncodingType
  owl:oneOf ( datatype:BitEncoding ) .

qudt:BooleanEncodingType
  owl:oneOf ( datatype:BooleanEncoding datatype:BitEncoding datatype:OctetEncoding ) .

qudt:CardinalityType
  owl:oneOf ( datatype:CT_COUNTABLY-INFINITE datatype:CT_FINITE datatype:CT_UNCOUNTABLE ) .

qudt:CharEncodingType
  owl:oneOf ( datatype:CharEncoding ) .

qudt:EndianType
  owl:oneOf ( datatype:LittleEndian datatype:BigEndian ) .

qudt:IntegerEncodingType
  owl:oneOf ( datatype:LongUnsignedIntegerEncoding datatype:ShortUnsignedIntegerEncoding
    datatype:ShortUnsignedIntegerEncoding datatype:SignedIntegerEncoding
    datatype:UnsignedIntegerEncoding ) .

qudt:OrderedType
  owl:oneOf ( datatype:Unordered datatype:PartiallyOrdered datatype:TotallyOrdered ) .

qudt:baseUnitOfSystem
  owl:inverseOf qudt:hasBaseUnit .

qudt:definedUnitOfSystem
  owl:inverseOf qudt:hasDefinedUnit .

qudt:derivedCoherentUnitOfSystem
  owl:inverseOf qudt:hasDerivedCoherentUnit .

qudt:derivedNonCoherentUnitOfSystem
  owl:inverseOf qudt:hasDerivedNonCoherentUnit .

qudt:derivedUnitOfSystem
  owl:inverseOf qudt:hasDerivedUnit .

qudt:dimensionInverse
  a owl:InverseFunctionalProperty, owl:SymmetricProperty ;
  owl:inverseOf qudt:dimensionInverse .

qudt:hasBaseUnit
  owl:inverseOf qudt:baseUnitOfSystem .

qudt:hasDerivedCoherentUnit
  owl:inverseOf qudt:derivedCoherentUnitOfSystem .

qudt:hasDerivedNonCoherentUnit
  owl:inverseOf qudt:derivedNonCoherentUnitOfSystem .

qudt:hasDerivedUnit
  owl:inverseOf qudt:derivedUnitOfSystem .

qudt:systemDefinition
  a owl:TransitiveProperty .

qudt:unitFor
  owl:inverseOf qudt:hasUnit ;
  rdfs:domain qudt:Unit .

qudt:valueQuantity
  owl:inverseOf qudt:quantityValue .


