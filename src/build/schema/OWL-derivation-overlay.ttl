@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .

# OWL semantics that are intentionally overlaid after SHACL->OWL derivation.

# Enumerated classes.
qudt:BitEncodingType
  owl:oneOf ( qudt:BitEncoding ) .

qudt:BooleanEncodingType
  owl:oneOf ( qudt:BooleanEncoding qudt:BitEncoding qudt:OctetEncoding ) .

qudt:CardinalityType
  owl:oneOf ( qudt:CT_COUNTABLY-INFINITE qudt:CT_FINITE qudt:CT_UNCOUNTABLE ) .

qudt:CharEncodingType
  owl:oneOf ( qudt:CharEncoding ) .

qudt:EndianType
  owl:oneOf ( qudt:LittleEndian qudt:BigEndian ) .

qudt:IntegerEncodingType
  owl:oneOf (
    qudt:LongUnsignedIntegerEncoding
    qudt:ShortUnsignedIntegerEncoding
    qudt:ShortUnsignedIntegerEncoding
    qudt:SignedIntegerEncoding
    qudt:UnsignedIntegerEncoding
  ) .

qudt:OrderedType
  owl:oneOf ( qudt:Unordered qudt:PartiallyOrdered qudt:TotallyOrdered ) .

# Non-derivable object property inverses.
qudt:baseUnitOfSystem owl:inverseOf qudt:hasBaseUnit .
qudt:definedUnitOfSystem owl:inverseOf qudt:hasDefinedUnit .
qudt:derivedCoherentUnitOfSystem owl:inverseOf qudt:hasDerivedCoherentUnit .
qudt:derivedNonCoherentUnitOfSystem owl:inverseOf qudt:hasDerivedNonCoherentUnit .
qudt:derivedUnitOfSystem owl:inverseOf qudt:hasDerivedUnit .
qudt:hasBaseUnit owl:inverseOf qudt:baseUnitOfSystem .
qudt:hasDerivedCoherentUnit owl:inverseOf qudt:derivedCoherentUnitOfSystem .
qudt:hasDerivedNonCoherentUnit owl:inverseOf qudt:derivedNonCoherentUnitOfSystem .
qudt:hasDerivedUnit owl:inverseOf qudt:derivedUnitOfSystem .
qudt:unitFor owl:inverseOf qudt:hasUnit .
qudt:unitFor rdfs:domain qudt:Unit .
qudt:valueQuantity owl:inverseOf qudt:quantityValue .

# Additional OWL property characteristics.
qudt:dimensionInverse
  a owl:InverseFunctionalProperty, owl:SymmetricProperty ;
  owl:inverseOf qudt:dimensionInverse .

qudt:systemDefinition
  a owl:TransitiveProperty .
