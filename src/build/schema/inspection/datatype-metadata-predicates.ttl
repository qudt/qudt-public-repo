@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <urn:qudt:allowlist:> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Predicates treated as metadata in datatype schema diff normalization.
dcterms:description
  a ex:MetadataPredicate .

dcterms:modified
  a ex:MetadataPredicate .

rdfs:label
  a ex:MetadataPredicate .

<http://qudt.org/schema/qudt/dbpediaMatch>
  a ex:MetadataPredicate .

<http://qudt.org/schema/qudt/informativeReference>
  a ex:MetadataPredicate .

<http://qudt.org/schema/qudt/plainTextDescription>
  a ex:MetadataPredicate .
