@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qk: <http://qudt.org/schema/quantitykind/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sq: <http://qudt.org/2.1/shacl/infer/applicableUnits> .

qk:
  sh:declare [
    sh:namespace "http://qudt.org/vocab/quantitykind/"^^xsd:anyURI ;
    sh:prefix "qk" ;
  ] .

qudt:
  sh:declare [
    sh:namespace "http://qudt.org/schema/qudt/"^^xsd:anyURI ;
    sh:prefix "qudt" ;
  ] .

rdfs:
  sh:declare [
    sh:namespace "http://www.w3.org/2000/01/rdf-schema#" ;
    sh:prefix "rdfs" ;
  ] .

sq:qkRule
  a sh:NodeShape ;
  sh:rule [
    a sh:SPARQLRule ;
    sh:construct """
        CONSTRUCT {
            $this qudt:applicableUnit ?unit .
            $this rdfs:comment ?comment .
        } WHERE {
            SELECT
                 $this
                 ?qk
                 ?unit
                 (CONCAT("Applicable units are those of ",
                   REPLACE(STR(?qk),"http://qudt.org/vocab/quantitykind/","quantitykind:")) as ?comment)
            WHERE {
                # Step 1: find the minimum path length to any unit-bearing non-deprecated ancestor.
                # Two ancestors at the same minimum distance (multi-parent tie) both qualify.
                # Traversal is restricted to qudt:specializationOf, the commensurable-specialisation
                # relation, so every applicableUnit is guaranteed commensurable with $this. (Walking
                # qudt:organizedUnder or bare skos:broader would inherit units across a non-commensurable
                # edge, which is exactly the false-commensurability signal this restriction removes.)
                # Unit attachment is likewise restricted to qudt:unitForQuantityKind, not the
                # materialized qudt:hasQuantityKind super-property: qudt:categorizedByQuantityKind
                # (and any not-yet-classified legacy qudt:hasQuantityKind) makes no commensurability
                # claim, so its units must not feed applicableUnit either.
                {
                    SELECT $this (MIN(?s) AS ?minSteps)
                    WHERE {
                        {
                            SELECT $this ?qk2 (COUNT(*) AS ?s)
                            WHERE {
                                $this qudt:specializationOf* ?mid2 .
                                ?mid2 qudt:specializationOf* ?qk2 .
                            }
                            GROUP BY $this ?qk2
                        }
                        FILTER EXISTS {
                            ?u qudt:unitForQuantityKind ?qk2 .
                            {
                                  ?u a qudt:Unit .
                            } UNION {
                                  ?u a qudt:CurrencyUnit .
                            }
                            FILTER NOT EXISTS {
                                ?u qudt:deprecated true
                            }
                        }
                        # do not source applicable units from a deprecated quantity kind;
                        # $this then falls through to the nearest live ancestor
                        FILTER NOT EXISTS {
                            ?qk2 qudt:deprecated true
                        }
                    }
                    GROUP BY $this
                }
                # Step 2: enumerate all unit-bearing ancestors at exactly the minimum distance,
                # unioning their units.  For most quantity kinds this is a single ancestor (no tie);
                # for multi-parent kinds such as SignalStrength all equidistant ancestors contribute.
                {
                    SELECT $this ?qk (COUNT(*) AS ?steps)
                    WHERE {
                        $this qudt:specializationOf* ?mid .
                        ?mid qudt:specializationOf* ?qk .
                    }
                    GROUP BY $this ?qk
                }
                FILTER(?steps = ?minSteps)
                FILTER EXISTS {
                    ?unit qudt:unitForQuantityKind ?qk .
                    {
                          ?unit a qudt:Unit .
                    } UNION {
                          ?unit a qudt:CurrencyUnit .
                    }
                    FILTER NOT EXISTS {
                        ?unit qudt:deprecated true
                    }
                }
                FILTER NOT EXISTS {
                    ?qk qudt:deprecated true
                }
                ?unit qudt:hasQuantityKind ?qk .
                {
                    ?unit a qudt:Unit .
                } UNION {
                    ?unit a qudt:CurrencyUnit .
                }
                FILTER NOT EXISTS {
                    ?unit qudt:deprecated true
                }
            }
        }
        """ ;
    sh:prefixes qk: ;
    sh:prefixes qudt: ;
    sh:prefixes rdfs: ;
  ] ;
  sh:targetClass qudt:QuantityKind .


