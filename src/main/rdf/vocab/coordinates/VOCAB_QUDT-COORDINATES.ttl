  dcterms:contributor "Steve Ray" ;
  dcterms:created "2026-03-29T00:00:00Z"^^xsd:dateTime ;
  dcterms:creator "Steve Ray" ;
  dcterms:description """
  <p>The QUDT <em>Coordinates</em> vocabulary contains coordinate-system-related individuals,
  including coordinate-center kinds, frame types, axial orientation values, coordinate systems,
  and reference frames. These terms are minted in the <code>coord:</code> namespace and are
  organized here as a separate vocabulary graph.</p>
  """^^rdf:HTML ;
