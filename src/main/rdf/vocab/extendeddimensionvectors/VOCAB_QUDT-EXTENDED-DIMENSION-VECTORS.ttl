vaem:GMD_QUDT-EXTENDED-DIMENSION-VECTORS
  a vaem:GraphMetaData ;
  dcterms:created "2026-05-14T00:00:00Z"^^xsd:dateTime ;
  dcterms:creator "Steve Ray" ;
  dcterms:description "Provides the set of all extended dimension vectors, extending the SI dimension vectors with additional dimensions for angle (R) and count (N)"^^rdf:HTML ;
  dcterms:modified "1234-12-12T12:34:56Z"^^xsd:dateTime ;
  dcterms:rights "The QUDT Ontologies are issued under a Creative Commons Attribution 4.0 International License (CC BY 4.0), available at https://creativecommons.org/licenses/by/4.0/. Attribution should be made to QUDT.org" ;
  dcterms:subject "EXTENDED-DIMENSION-VECTORS" ;
  dcterms:title "QUDT Extended Dimension Vectors Version $$QUDT_MAJOR_MINOR_VERSION$$ Vocabulary" ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/vocab/extendeddimensionvector> ;
  rdfs:label "QUDT Extended Dimension Vector Vocabulary Metadata Version $$QUDT_VERSION$$" ;
  vaem:applicableDiscipline "All disciplines" ;
  vaem:applicableDomain "Science, Medicine and Engineering" ;
  vaem:dateCreated "2026-05-14T00:00:00Z"^^xsd:dateTime ;
  vaem:description "QUDT Extended Dimension Vectors extend the SI-based QUDT Dimension Vectors with two additional dimensions: angle (R) and count (N). The first eight components of each extended dimension vector are identical to the corresponding SI dimension vector, preserving backward compatibility." ;
  vaem:graphTitle "QUDT Extended Dimension Vectors Version $$QUDT_VERSION$$" ;
  vaem:hasGraphRole vaem:VocabularyGraph ;
  vaem:intent "To support dimensional analysis for quantities involving angle and count dimensions beyond the SI base dimensions" ;
  vaem:isMetadataFor <http://qudt.org/$$QUDT_VERSION$$/vocab/extendeddimensionvector> ;
  vaem:latestPublishedVersion "https://qudt.org/doc/$$CURRENT_YEAR$$/$$CURRENT_MONTH$$/DOC_VOCAB-EXTENDED-DIMENSION-VECTORS.html"^^xsd:anyURI ;
  vaem:logo "https://qudt.org/linkedmodels.org/assets/lib/lm/images/logos/qudt_logo-300x110.png" ;
  vaem:namespace "http://qudt.org/vocab/extendeddimensionvector/"^^xsd:anyURI ;
  vaem:namespacePrefix "edv" ;
  vaem:owner "qudt.org" ;
  vaem:previousPublishedVersion "https://qudt.org/doc/$$QUDT_PREV_RELEASE_YEAR$$/$$QUDT_PREV_RELEASE_MONTH$$/DOC_VOCAB-EXTENDED-DIMENSION-VECTORS.html"^^xsd:anyURI ;
  vaem:specificity 1 ;
