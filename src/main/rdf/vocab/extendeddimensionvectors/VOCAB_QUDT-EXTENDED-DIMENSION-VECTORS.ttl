<http://qudt.org/$$QUDT_VERSION$$/vocab/extendeddimensionvector>
  a owl:Ontology ;
  owl:imports <http://qudt.org/$$QUDT_VERSION$$/schema/facade/qudt> ;
  owl:versionIRI <http://qudt.org/$$QUDT_VERSION$$/vocab/extendeddimensionvector> ;
