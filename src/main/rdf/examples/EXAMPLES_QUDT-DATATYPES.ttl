# baseURI: http://qudt.org/$$QUDT_VERSION$$/examples/datatype
# imports: http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype
# imports: http://qudt.org/$$QUDT_VERSION$$/schema/shacl/qudt
# imports: http://qudt.org/$$QUDT_VERSION$$/vocab/datatype
# imports: http://qudt.org/$$QUDT_VERSION$$/vocab/quantitykind
# imports: http://qudt.org/$$QUDT_VERSION$$/vocab/unit
# imports: http://www.linkedmodel.org/schema/dtype
# imports: http://www.linkedmodel.org/schema/vaem

@prefix datatype: <http://qudt.org/vocab/datatype/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix quantitykind: <http://qudt.org/vocab/quantitykind/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix vaem: <http://www.linkedmodel.org/schema/vaem#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:DateCountTupleSpec
  a qudt:TupleSpec ;
  qudt:memberSpecs (
      [
        a qudt:MemberSpec ;
        qudt:index 1 ;
        sh:datatype xsd:date ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 2 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
      ]
    ) ;
.
ex:MeasurementTupleSpec
  a qudt:TupleSpec ;
  qudt:memberSpecs (
      [
        a qudt:MemberSpec ;
        qudt:index 1 ;
        sh:datatype xsd:date ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 2 ;
        sh:datatype xsd:decimal ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 3 ;
        sh:class qudt:Unit ;
      ]
    ) ;
.
ex:QuantityValueUnitTupleSpec
  a qudt:TupleSpec ;
  qudt:memberSpecs (
      [
        a qudt:MemberSpec ;
        qudt:index 1 ;
        sh:class qudt:QuantityKind ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 2 ;
        sh:datatype xsd:decimal ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 3 ;
        sh:class qudt:Unit ;
      ]
    ) ;
.
ex:ResourceLabelRatingTupleSpec
  a qudt:TupleSpec ;
  qudt:memberSpecs (
      [
        a qudt:MemberSpec ;
        qudt:index 1 ;
        sh:nodeKind sh:IRI ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 2 ;
        sh:languageIn (
            "en"
          ) ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 3 ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 5 ;
        sh:minInclusive 1 ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 4 ;
        sh:class qudt:Unit ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 5 ;
        sh:datatype xsd:date ;
      ]
    ) ;
.
ex:StatusFlagTupleSpec
  a qudt:TupleSpec ;
  qudt:memberSpecs (
      [
        a qudt:MemberSpec ;
        qudt:index 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
      ]
      [
        a qudt:MemberSpec ;
        qudt:index 2 ;
        sh:datatype xsd:boolean ;
      ]
    ) ;
.

ex:badExampleQuantityValueTuple
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:QuantityValueUnitTupleSpec ;
  qudt:values (
      quantitykind:Temperature
      25.6
      "DegC"
    ) ;
.
ex:badExampleTuple2a
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:StatusFlagTupleSpec ;
  qudt:values (
      "Approved"
      42
    ) ;
.
ex:badExampleTuple2b
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:StatusFlagTupleSpec ;
  qudt:values (
      "Approved"
      true
      42
    ) ;
.
ex:badExampleTuple3
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:MeasurementTupleSpec ;
  qudt:values (
      "2026-05-12"^^xsd:date
      23.7
      42
    ) ;
.
ex:exampleQuantityValueTuple
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:QuantityValueUnitTupleSpec ;
  qudt:values (
      quantitykind:Temperature
      23.7
      unit:DEG_C
    ) ;
.
ex:exampleTuple1
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:DateCountTupleSpec ;
  qudt:values (
      "2026-05-12"^^xsd:date
      42
    ) ;
.
ex:exampleTuple2
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:StatusFlagTupleSpec ;
  qudt:values (
      "Approved"
      true
    ) ;
.
ex:exampleTuple3
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:MeasurementTupleSpec ;
  qudt:values [
      rdf:first "2026-05-12"^^xsd:date ;
      rdf:rest [
          rdf:first 23.7 ;
          rdf:rest [
              rdf:first "unit:DEG_C" ;
            ] ;
        ] ;
    ] ;
.
ex:exampleTuple5
  a qudt:Tuple ;
  qudt:conformsToTupleSpec ex:ResourceLabelRatingTupleSpec ;
  qudt:values (
      quantitykind:Temperature
      "Ambient temperature"@en
      5
      unit:DEG_C
      "2026-05-12"^^xsd:date
    ) ;
.
dcterms:contributor
  a owl:AnnotationProperty ;
  rdfs:label "contributor" ;
  rdfs:range xsd:string ;
.
dcterms:creator
  a owl:AnnotationProperty ;
  rdfs:label "creator" ;
  rdfs:range xsd:string ;
.
dcterms:description
  a owl:AnnotationProperty ;
  rdfs:label "description" ;
  rdfs:range xsd:string ;
.
dcterms:rights
  a owl:AnnotationProperty ;
  rdfs:label "rights" ;
  rdfs:range xsd:string ;
.
dcterms:subject
  a owl:AnnotationProperty ;
  rdfs:label "subject" ;
  rdfs:range xsd:string ;
.
dcterms:title
  a owl:AnnotationProperty ;
  rdfs:label "title" ;
  rdfs:range xsd:string ;
.
<http://qudt.org/$$QUDT_VERSION$$/examples/datatype>
  a owl:Ontology ;
  vaem:hasGraphMetadata vaem:GMD_EXAMPLE-DATATYPES ;
  vaem:hasGraphRole vaem:VocabularyGraph ;
  rdfs:label "QUDT Examples of Datatypes v$$QUDT_VERSION$$" ;
  owl:imports <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> ;
  owl:imports <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/qudt> ;
  owl:imports <http://qudt.org/$$QUDT_VERSION$$/vocab/datatype> ;
  owl:imports <http://qudt.org/$$QUDT_VERSION$$/vocab/quantitykind> ;
  owl:imports <http://qudt.org/$$QUDT_VERSION$$/vocab/unit> ;
  owl:imports <http://www.linkedmodel.org/schema/dtype> ;
  owl:imports <http://www.linkedmodel.org/schema/vaem> ;
.
qudt:Alarm_Enumeration
  a qudt:Enumeration ;
  qudt:element qudt:HighAlarm ;
  qudt:element qudt:LowAlarm ;
  qudt:element qudt:NoAlarm ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Room Temperature Alarm" ;
.
qudt:Array1D_Integers
  a qudt:Array ;
  dcterms:description """
  <p>TBD
  </p>"""^^rdf:HTML ;
  qudt:datatype datatype:INTEGER ;
  qudt:dimensionality 1 ;
  qudt:dimensions (
      3
    ) ;
  qudt:isHeterogeneous false ;
  qudt:value (
      1
      2
      3
    ) ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Example of an Array of 3 integers" ;
.
qudt:Array_MassProperties_Rocket
  a qudt:MassPropertiesArray ;
  qudt:datatype datatype:FLOAT-DP ;
  qudt:dimensionality 1 ;
  qudt:dimensions (
      6
    ) ;
  qudt:hasQuantityKindsList (
      quantitykind:CenterOfGravity_X
      quantitykind:CenterOfGravity_Y
      quantitykind:CenterOfGravity_Z
      quantitykind:Mass
      quantitykind:MomentOfInertia
      quantitykind:PRODUCT-OF-INERTIA
    ) ;
  qudt:isHeterogeneous true ;
  qudt:value (
      0.1
      0.5
      1.0
      2.0
      3.0
      4.0
    ) ;
  rdfs:comment "TODO: qudt:datatype ( datatype:FLOAT-DP datatype:FLOAT-DP datatype:FLOAT-DP datatype:FLOAT-DP datatype:FLOAT-DP datatype:FLOAT-DP )" ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Mass Properties Array Example" ;
.
qudt:HighAlarm
  a qudt:EnumeratedValue ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "High Alarm" ;
.
qudt:List_3_Strings
  a qudt:List ;
  dcterms:description """
  <p>TBD
  </p>"""^^rdf:HTML ;
  qudt:datatype datatype:UTF8-STRING ;
  qudt:value (
      "one"
      "two"
      "three"
    ) ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Example of a List of 3 strings" ;
.
qudt:List_Decimal_Values
  a qudt:List ;
  dcterms:description """
  <p>TBD
  </p>"""^^rdf:HTML ;
  qudt:datatype datatype:DECIMAL ;
  qudt:value (
      54.0
      55.6
      56.9
      61.2
    ) ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Example of a list of 3 decimal values" ;
.
qudt:LowAlarm
  a qudt:EnumeratedValue ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Low Alarm" ;
.
qudt:Matrix-2X4-FLOAT-SP
  a qudt:Matrix ;
  qudt:datatype datatype:FLOAT-SP ;
  qudt:dimensionality 2 ;
  qudt:dimensions (
      2
      4
    ) ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Matrix example 2x4 - Single Precision" ;
.
qudt:Matrix-4X4-FLOATDP
  a qudt:Matrix ;
  qudt:datatype datatype:FLOAT-DP ;
  qudt:dimensionality 2 ;
  qudt:dimensions (
      4
      4
    ) ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Matrix example 4x4 - Double precision" ;
.
qudt:NoAlarm
  a qudt:EnumeratedValue ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "No Alarm" ;
.
qudt:Quantity_CarSpeed
  a qudt:Quantity ;
  dcterms:description """
  <p>The value of a car speed is stated as <em>90 KiloMetres/Hour</em>.
  Which car this refers to is our-of-scope for the example, a link such as <i>has speed</i> would be
   one way to reference this quantity.
  </p>"""^^rdf:HTML ;
  qudt:hasQuantityKind quantitykind:LinearVelocity ;
  qudt:hasUnit unit:KiloM-PER-HR ;
  qudt:value "90.0"^^xsd:DECIMAL ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Car Speed" ;
.
qudt:Quantity_DroneVelocity
  a qudt:Quantity ;
  dcterms:description """
  <p>In this example a drone velocity is stated as a single value without any consideration for x, y, and z directions.
  The quantity kind, unit of measure and value are held on the quantity.
  Which drone this refers to is our-of-scope for the example, a link such as <i>has speed</i> would be
   one way to reference this quantity.
  </p>"""^^rdf:HTML ;
  qudt:hasQuantityKind quantitykind:LinearVelocity ;
  qudt:hasUnit unit:M-PER-SEC ;
  qudt:value 10.0 ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Drone Velocity" ;
.
qudt:Quantity_DroneVelocity3D
  a qudt:Quantity ;
  dcterms:description """
  <p>In this example a drone velocity is stated as a 3D vector for the x, y, and z directions.
  In this case the vector holds the 3 values along with the quantity-kinds and units.
  Which drone this refers to is our-of-scope for the example, a link such as <i>has speed</i> would be
   one way to reference this quantity.
  </p>"""^^rdf:HTML ;
  qudt:value qudt:Vector_DroneVelocities_3D ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Drone Velocity 3D" ;
.
qudt:Quantity_RoomTemperature
  a qudt:Quantity ;
  qudt:hasQuantityKind quantitykind:Temperature ;
  qudt:hasUnit unit:DEG_F ;
  qudt:value qudt:List_Decimal_Values ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Room Temperature" ;
.
qudt:Quantity_RoomTemperature_AlarmState
  a qudt:Quantity ;
  qudt:value qudt:LowAlarm ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/examples/datatype> ;
  rdfs:label "Room Temperature Alarm State" ;
.
