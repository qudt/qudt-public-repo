@prefix voag: <http://voag.linkedmodel.org/schema/voag#> .

<http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>
        rdf:type               owl:Ontology;
        rdfs:isDefinedBy       <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label             "QUDT SCHEMA - Coordinate Systems";
        vaem:hasGraphMetadata  vaem:GMD_SCHEMA-COORDINATES;
        owl:imports            <http://www.linkedmodel.org/schema/dtype> , <http://www.linkedmodel.org/schema/vaem> , <http://www.w3.org/2004/02/skos/core>;
        owl:versionIRI         <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems> .

vaem:GMD_SCHEMA-COORDINATES
        rdf:type                       vaem:GraphMetaData;
        rdfs:isDefinedBy               <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label                     "QUDT Schema for Coordinate Systems - Version $$QUDT_VERSION$$";
        dcterms:description            "<p>This OWL schema is derived from the SHACL schema found at http://qudt.org/$$QUDT_VERSION$$/schema/shacl/coordinateSystems. </p>"^^rdf:HTML;
        dcterms:modified               "2025-04-02T10:54:24-05:00"^^xsd:dateTime;
        dcterms:rights                 "\n  <p>The QUDT Ontologies are issued under a Creative Commons Attribution 4.0 International License (CC BY 4.0), available  <a href=\"https://creativecommons.org/licenses/by/4.0/\">here</a>. \n  Attribution should be made to <a href=\"https://www.qudt.org\">QUDT.org</a>.\n  </p>"^^rdf:HTML;
        dcterms:subject                "Coordinate Systems";
        vaem:graphTitle                "QUDT Schema for Coordinate Systems - Version $$QUDT_VERSION$$";
        vaem:hasGraphRole              vaem:SchemaGraph;
        vaem:isMetadataFor             <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        vaem:latestPublishedVersion    "https://qudt.org/doc/$$CURRENT_YEAR$$/$$CURRENT_MONTH$$/DOC_SCHEMA-COORDINATES.html"^^xsd:anyURI;
        vaem:logo                      "https://qudt.org/linkedmodels.org/assets/lib/lm/images/logos/qudt_logo-300x110.png"^^xsd:anyURI;
        vaem:name                      "QUDT";
        vaem:namespace                 "http://qudt.org/schema/qudt/"^^xsd:anyURI;
        vaem:namespacePrefix           "qudt";
        vaem:owner                     "QUDT.ORG";
        vaem:previousPublishedVersion  "https://qudt.org/doc/$$QUDT_PREV_RELEASE_YEAR$$/$$QUDT_PREV_RELEASE_MONTH$$/DOC_SCHEMA-COORDINATES.html"^^xsd:anyURI;
        vaem:publishedDate             "2017-05-10"^^xsd:date;
        vaem:releaseDate               "2016-05-09"^^xsd:date;
        vaem:title                     "QUDT Schema for Coordinate Systems - Version $$QUDT_VERSION$$";
        vaem:turtleFileURL             "http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems.ttl"^^xsd:anyURI;
        vaem:usesNonImportedResource   dcterms:creator , dcterms:abstract , <http://voag.linkedmodel.org/voag#QUDT-Attribution> , dcterms:modified , dcterms:created , dcterms:rights , dcterms:title;
        vaem:withAttributionTo         <http://voag.linkedmodel.org/voag#QUDT-Attribution>;
        prov:derivedFrom               <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/coordinateSystems> .

dcterms:contributor  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "contributor" .

dcterms:creator  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "creator" .

dcterms:description  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "description" .

dcterms:rights  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "rights" .

dcterms:subject  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "subject" .

dcterms:title  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "title" .

qudt:AerospaceCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Aerospace Coordinate system";
        rdfs:subClassOf      qudt:CoordinateSystem;
        dcterms:description  "A sub-type of 'Coordinate system'." .

qudt:AxialOrientationType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Axial Orientation Type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "The axial orientation of a coordinate system frame axis.";
        owl:oneOf            ( coords:PositiveZ coords:PositiveY coords:NegativeY coords:NegativeZ coords:PositiveX coords:NegativeX ) .

qudt:CartesianCoordinatesType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Cartesian Coordinate Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  <p>A set of  variables which fix a geometric object.\n  If the coordinates are distances measured along perpendicular axes, they are known as Cartesian coordinates.\n  </p>"^^rdf:HTML .

qudt:CartesianCoordinates
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Cartesian Coordinate Type";
        rdfs:subClassOf      qudt:Coordinates;
        dcterms:description  "\n  A set of  variables which fix a geometric object.\n  If the coordinates are distances measured along perpendicular axes, they are known as Cartesian coordinates.\n  " .

qudt:CoordinateCenterKind
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Coordinate Center Kind";
        rdfs:subClassOf      qudt:NominalScale , qudt:EnumeratedValue;
        dcterms:description  "\n  <p>An enumeration of coordinate centers for coordinate systems, such as:\n   \"Earth centered\", \"Mars centered\", \"Moon centered\", \"Sun centered\",  and \"Vehicle centered\".\n  </p>"^^rdf:HTML;
        owl:oneOf            ( coords:CCT_MarsCentered coords:CCT_EarthCentered coords:CCT_MoonCentered coords:CCT_VehicleCentered coords:CCT_SunCentered ) .

qudt:coordinateCenter
        rdf:type          owl:ObjectProperty;
        rdfs:domain       qudt:CoordinateSystem;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "coordinate center";
        rdfs:range        qudt:CoordinateCenterKind;
        skos:prefLabel    "coordinate center" .

qudt:CoordinateMember
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Coordinate Member";
        rdfs:subClassOf      qudt:TupleMember;
        dcterms:description  "\n  <p>A <em>Coordinate Member</em> is a data type that defines the properties of a coordinate in a coordinate system.\n  </p>"^^rdf:HTML .

qudt:Coordinates-2D-DoublePrecision
        rdf:type               owl:Class;
        rdfs:isDefinedBy       <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label             "Coordinates-2D-Double precision";
        rdfs:subClassOf        qudt:Coordinates-2D;
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        dcterms:description    "\n  <p>A 2D coordinates in double floating point precision for locating a point in physical space.\n  </p>"^^rdf:HTML;
        qudt:elementTypeCount  2 .

qudt:Coordinates-2D-SinglePrecision
        rdf:type               owl:Class;
        rdfs:isDefinedBy       <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label             "Cartesian Coordinates 2D Single Precision";
        rdfs:subClassOf        qudt:Coordinates-2D;
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        dcterms:description    "\n  <p>A 2D coordinates in single floating point precision for locating a point in physical space.\n  </p>"^^rdf:HTML;
        qudt:elementTypeCount  2 .

qudt:Coordinates-2D  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "2D Coordinate Type";
        rdfs:subClassOf      qudt:TwoTuple , qudt:CartesianCoordinates;
        dcterms:description  "\n  <p>A 2D coordinate system is a system for assigning a two-tuple of numbers or scalars to each point in an 2-dimensional space. \n  A corresponding 2D Coordinate Type is a data type that defines the data type for each coordinate (tuple member) in a 2D coordinate system.\n  </p>"^^rdf:HTML .

qudt:Coordinates-3D-DoublePrecision
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "3D Coordinates (Double Precision)";
        rdfs:subClassOf      qudt:Coordinates-3D;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:double_Y
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:double_Z
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:double_Y
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:double_X
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:double_X
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:double_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:double_Y
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:double_Z
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:double_X
                             ];
        dcterms:description  "\n  <p>A 3D coordinates in double floating point precision for locating a point in physical space.\n  </p>"^^rdf:HTML .

qudt:Coordinates-3D-SinglePrecision
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "3D Coordinates (Single Precision)";
        rdfs:subClassOf      qudt:Coordinates-3D;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:float_Y
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:float_Y
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:float_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:float_X
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:float_X
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:float_X
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:float_Y
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:float_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:float_Z
                             ];
        dcterms:description  "\n  <p>A 3D coordinates in single floating point precision for locating a point in physical space.\n  </p>\n  "^^rdf:HTML .

qudt:Coordinates-3D-Type
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "3D Coordinate Type";
        rdfs:subClassOf      qudt:CartesianCoordinatesType , qudt:ThreeTuple;
        dcterms:description  "\n  <p>A 3D coordinate system is a system for assigning a three-tuple of numbers or scalars to each point in an 3-dimensional space. \n  A corresponding 3D Coordinate Type is a data type that defines the data type for each coordinate (tuple member) in a 3D coordinate system.\n  </p>"^^rdf:HTML .

qudt:Coordinates-3D  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "3D Coordinate Type";
        rdfs:subClassOf      qudt:ThreeTuple , qudt:CartesianCoordinates;
        dcterms:description  "\n  <p>A 3D coordinate system is a system for assigning a three-tuple of numbers or scalars to each point in an 3-dimensional space.\n  A corresponding 3D Coordinate Type is a data type that defines the data type for each coordinate (tuple member) in a 3D coordinate system.\n  </p>"^^rdf:HTML .

qudt:coordinateSystemFrame
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "coordinate system frame" .

qudt:CoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Coordinate system";
        rdfs:seeAlso         <http://mathworld.wolfram.com/CoordinateSystem.html> , <http://en.wikipedia.org/wiki/Astronomical_coordinate_systems> , <http://mathworld.wolfram.com/Coordinates.html> , <http://en.wikipedia.org/wiki/Coordinate_system>;
        rdfs:subClassOf      skos:Concept , qudt:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:abbreviation
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:referenceFrame
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:originDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:coordinateCenter
                             ];
        dcterms:description  "\n  <p>A <em>Coordinate System</em> is a mathematical structure for assigning a unique n-tuple of numbers or scalars to each point in an n-dimensional space. \n  A Coordinate System Type is a data type that defines the properties of data structures that represent coordinate systems.\n  </p>\n  <p>In geometry, a coordinate system is a system which uses one or more numbers, or coordinates,\n   to uniquely determine the position of a point or other geometric element on a manifold such as Euclidean space. \n  The order of the coordinates is significant.\n  They are sometimes identified by their position in an ordered tuple and sometimes by a letter, as in 'the x-coordinate'. \n  </p>\n  <p>In elementary mathematics the coordinates are taken to be real numbers, but may be complex numbers or elements of a more abstract system such as a commutative ring. \n  The use of a coordinate system allows problems in geometry to be translated into problems about numbers and vice versa; this is the basis of analytic geometry. \n  </p>\n  <p>In astronomy, a celestial coordinate system is a system for specifying positions of celestial objects: satellites, planets, stars, galaxies, and so on. \n  Coordinate systems can specify a position in 3-dimensional space, or merely the direction of the object on the celestial sphere, if its distance is not known or not important.\n  </p>\n  <p>The coordinate systems are implemented in either spherical coordinates or rectangular coordinates. \n  Spherical coordinates, projected on the celestial sphere, are analogous to the geographic coordinate system used on the surface of the Earth.\n  These differ in their choice of fundamental plane, which divides the celestial sphere into two equal hemispheres along a great circle.\n  </p>\n  <p>Rectangular coordinates, in appropriate units, are simply the cartesian equivalent of the spherical coordinates, with the same fundamental (x,y) plane and primary (x-axis) direction. \n  Each coordinate system is named for its choice of fundamental plane.\n  </p>"^^rdf:HTML;
        qudt:dbpediaMatch    <http://dbpedia.org/resource/Coordinate_system> .

qudt:coordinateSystem
        rdf:type          owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "coordinate system";
        rdfs:range        qudt:CoordinateSystem .

qudt:Coordinates  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Coordinates";
        rdfs:subClassOf      qudt:Tuple;
        dcterms:description  "\n  <p>A coordinate system is a mathematical structure for assigning a unique n-tuple of numbers or scalars to each point in an n-dimensional space. \n  A Coordinate System Type is a data type that defines the properties of data structures that represent coordinate systems.\n  </p>\n  <p>The primary attributes of any coordinate system are the coordinate frame or orientation of the axes of the coordinate system and the coordinate center or origin of the coordinate system.\n  The coordinate center is the easier of the two attributes to define and in trajectory-related coordinate systems is often taken to be the center of mass of natural solar system bodies such as the Earth, the Moon, or Mars.\n  Precise definition of the coordinate frame, however, usually takes much more effort. \n  As a result, the primary purpose is to provide a detailed description of a number of different coordinate frames commonly used in mission analysis.\n  </p>"^^rdf:HTML .

qudt:EarthCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Earth Coordinate System Type";
        rdfs:subClassOf      qudt:TrajectoryCoordinateSystem;
        dcterms:description  "\n  <p>A \"Trajectory Coordinate System\" for all earth-centered coordinates, such as:\n  </p>\n  <ul>\n  <li>Earth mean equator and prime meridian coordinate system;;</li>\n  <li>Earth true equator and prime meridian of epoch coordinate system;</li> \n  <li>International celestial reference system;</li>\n  <li>International terrestrial reference system;</li>\n  <li>Sun centered international celestial reference system;</li>\n  <li>Vehicle centered international celestial reference system.</li>\n  </ul>"^^rdf:HTML .

qudt:float_X  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "float X";
        rdfs:range        xsd:float .

qudt:float_Y  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "float Y";
        rdfs:range        xsd:float .

qudt:float_Z  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "float Z";
        rdfs:range        xsd:float .

qudt:FrameType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Frame Type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "\n  <p>A <em>Frame Type</em> specifies the intertial type of a coordinate frame as either inertial, rotating, or non-rotating.\n  </p>\n  "^^rdf:HTML;
        owl:oneOf            ( coords:FT_ROTATING coords:FT_NON-ROTATING coords:FT_INERTIAL ) .

qudt:GroundCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Ground coordinate system";
        rdfs:subClassOf      qudt:AerospaceCoordinateSystem;
        dcterms:description  "A sub-type of 'Aerospace coordinate system'." .

qudt:InertialCoordinateFrame
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Inertial Coordinate Frame";
        rdfs:seeAlso         qudt:NonRotatingInertialFrame;
        rdfs:subClassOf      qudt:InertialReferenceFrame;
        dcterms:description  "A \"Coordinate Frame\"." .

qudt:InertialReferenceFrame
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Inertial reference frame";
        rdfs:subClassOf      qudt:ReferenceFrame;
        dcterms:description  "\n  A sub-type of 'Reference Frame'.\n  " .

qudt:LocalCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Local Coordinate System";
        rdfs:subClassOf      qudt:TrajectoryCoordinateSystem;
        dcterms:description  "\n  A \"Trajectory Coordinate System\" with the following instance(s):\n   \"Local vertical curvilinear coordinate system\",\n   \"Local vertical local horizontal coordinate system\",\n   \"Vehicle centered local vertical curvilinear coordinate system\".\n  " .

qudt:LunarCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Lunar Coordinate System";
        rdfs:subClassOf      qudt:TrajectoryCoordinateSystem;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:xAxisDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:zAxisDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:realization
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:yAxisDefinition
                             ];
        dcterms:description  "\n  Two slightly different coordinate frames are commonly used to define the orientation of the axes of a lunar body-fixed coordinate system:\n   a mean Earth/rotation frame and a principal axis coordinate frame. \n  The mean Earth/rotation frame (sometimes called the \"Mean Earth/polar axis\" frame) is a lunar body-fixed coordinate frame.\n  This has the X-axis aligned with the mean direction from the Moon to the Earth and the Z-axis aligned with the mean axis of rotation of the Moon. \n  The principal axis frame is a lunar body-fixed coordinate frame aligned with the principal axes of the Moon. \n  Due to the fact that the Moon is synchronously rotating but is not exactly symmetric, the principal axes and the mean Earth/rotation axes of the Moon do not coincide.\n  " .

qudt:MarsCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Mars Coordinate System Type";
        rdfs:subClassOf      qudt:TrajectoryCoordinateSystem;
        dcterms:description  "\n  A \"Trajectory Coordinate System\" with the following instance(s): \"Mars mean equator and IAU-Node of epoch\", \"Mars mean equator and prime meridian body-fixed\".\n  " .

qudt:NonRotatingInertialFrame
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Non Rotating Coordinate Frame";
        rdfs:seeAlso         qudt:InertialCoordinateFrame;
        rdfs:subClassOf      qudt:InertialReferenceFrame;
        dcterms:description  "\n  <p>The non-rotating (or \"inertial\") coordinate frames are defined by taking a \"snapshot\" of the orientation of a particular set of right-handed, orthogonal axes at a specific epoch or time. \n  In other words, the non-rotating coordinate frame, however it is defined, is frozen or fixed at a specific time - for all time. \n  These non-rotating coordinate frames are referred to as \"of Epoch\" coordinate frames.\n  </p>"^^rdf:HTML .

qudt:pitchRotationDefinition
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label          "pitch rotation definition";
        rdfs:range          qudt:AxialOrientationType;
        rdfs:subPropertyOf  qudt:rotationDefinition .

qudt:PolarCoordinatesType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Polar Coordinate System Type";
        rdfs:subClassOf      qudt:CoordinateSystem;
        dcterms:description  "\n  <p>A set of  variables which fix a geometric object. \n  If the coordinates of a point <em>P</em> are determined by the distance from <em>P</em> to the origin and the angle subtended by the radial vector at <em>P</em> and a fixed axis,\n   they are known as polar coordinates. \n  Typically, the angle is measured with respect to the x-axis. ;\n  </p>\n  "^^rdf:HTML .

qudt:PolarCoordinates
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Polar Coordinate System";
        rdfs:subClassOf      qudt:Coordinates;
        dcterms:description  "\n  <p>A set of  variables which fix a geometric object. \n  If the coordinates of a point P are determined by the distance from P to the origin and the angle subtended by the radial vector at P and a fixed axis,\n   they are known as polar coordinates. \n  Typically, the angle is measured with respect to the x-axis. ;\n  </p>"^^rdf:HTML .

qudt:ReferenceDatatype
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Reference Data Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        dcterms:description  "\n  <p>A reference is an object containing information which refers to data stored elsewhere, as opposed to containing the data itself. \n  A reference data type is a data type that specifies how a reference is represented and stored in memory,\n   as well as the operations that can be performed on reference values. \n  The most common example of a reference data type is a pointer.\n  </p>"^^rdf:HTML .

qudt:referenceFrameType
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "reference frame type" .

qudt:ReferenceFrame  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Reference Frame";
        rdfs:subClassOf      qudt:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:zCoordinateDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:yCoordinateDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:xAxisDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:yAxisDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:realization
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:xCoordinateDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:zAxisDefinition
                             ];
        dcterms:description  "\n  <p> A <em>Reference Frame</em> (or \"frame of reference\") in physics, may refer to a coordinate system or set of axes.\nThe frame serves as the datum to measure the position, orientation, and other properties of objects in it.\nReference frame may refer to an observational reference frame tied to the state of motion of an observer. \nReference frame may also refer to both an observational reference frame and an attached coordinate system as a unit.\n</p>\n"^^rdf:HTML .

qudt:referenceFrame  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label          "reference frame";
        rdfs:range          qudt:ReferenceFrame;
        rdfs:subPropertyOf  qudt:coordinateSystemFrame .

qudt:rollRotationDefinition
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label          "roll rotation definition";
        rdfs:range          qudt:AxialOrientationType;
        rdfs:subPropertyOf  qudt:rotationDefinition .

qudt:RotatingReferenceFrame
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Rotating reference frame";
        rdfs:subClassOf      qudt:ReferenceFrame;
        dcterms:description  "A sub-type of 'Reference Frame'." .

qudt:rotationDefinition
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "rotation definition" .

qudt:StateSpaceVector
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "State Space Vector Type";
        rdfs:subClassOf      qudt:Vector;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:coordinateSystem
                             ];
        dcterms:description  "\n  A state vector in general control systems describes the observed states of an object in state space.\n  For example in variables of the degrees of freedom for motion. \n  As data types, state vector types are used to specify the structure of state vectors, such as how the observed state is encoded.\n  " .

qudt:ThreeBodyRotatingCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Three Body Rotating Coordinate System Type";
        rdfs:subClassOf      qudt:AerospaceCoordinateSystem;
        dcterms:description  "\n  <p>A <em>Three Body Rotating Coordinate System</em> is one that is associated with two different three-body systems.\n  For example, the Sun-Earth-spacecraft system and the Earth-Moon-spacecraft system.\n  </p>\n  <p>The lunar coordinate systems are primarily used when operating in close proximity to the Moon. \n  There are, however, a few additional coordinate systems that are also useful when analyzing (and depicting) trajectories in the vicinity of the Earth-Moon system.  \n  The Sun-Earth and Earth-Moon rotating coordinate frames are defined as follows: \n  </p>\n  <p>The pole vector or Z-axis of the coordinate frame is set equal to the instantaneous orbit normal of the secondary (smaller) body about the primary (larger) body.\n  The X-axis is set equal to the vector from the primary body center of mass (CM) to the secondary body CM. \n  The X-axis rotates at a rate equal to the instantaneous rotation rate of the secondary body about the primary body.\n  </p>\n  "^^rdf:HTML .

qudt:TrajectoryCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Trajectory Coordinate System";
        rdfs:subClassOf      qudt:AerospaceCoordinateSystem;
        dcterms:description  "A \"Coordinate System\"." .

qudt:VehicleCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Vehicle coordinate system";
        rdfs:subClassOf      qudt:AerospaceCoordinateSystem;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:rollRotationDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:pitchRotationDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:rollRotationDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:yawRotationDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:yawRotationDefinition
                             ];
        dcterms:description  "A sub-type of 'Aerospace coordinate system'." .

qudt:xAxisDefinition  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "X-Axis Definition";
        rdfs:range           xsd:string;
        dcterms:description  "\n  The definition of the X-Axis could be an intersection, cross-product or other function of a  meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

qudt:xCoordinateDefinition
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "X-Coordinate definition";
        rdfs:range        xsd:string .

qudt:yawRotationDefinition
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label          "Yaw rotation definition";
        rdfs:range          qudt:AxialOrientationType;
        rdfs:subPropertyOf  qudt:rotationDefinition .

qudt:yAxisDefinition  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Y-Axis definition";
        rdfs:range           xsd:string;
        dcterms:description  "\n  The definition of the Y-Axis could be an intersection, cross-product or other function of a meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

qudt:yCoordinateDefinition
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "Y-Coordinate definition";
        rdfs:range        xsd:string .

qudt:zAxisDefinition  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label           "Z-Axis definition";
        rdfs:range           xsd:string;
        dcterms:description  "\n  The definition of the Y-Axis could be an intersection, croos-product or other function of a meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

qudt:zCoordinateDefinition
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/coordinateSystems>;
        rdfs:label        "Z-Coordinate definition";
        rdfs:range        xsd:string .
