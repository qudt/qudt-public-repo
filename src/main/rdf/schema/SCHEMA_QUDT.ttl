@prefix dc:        <http://purl.org/dc/elements/1.1/> .
@prefix dcterms:   <http://purl.org/dc/terms/> .
@prefix dtype:     <http://www.linkedmodel.org/schema/dtype#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix prov:      <http://www.w3.org/ns/prov#> .
@prefix qudt:      <http://qudt.org/schema/qudt/> .
@prefix qudt.type: <http://qudt.org/vocab/type/> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:        <http://www.w3.org/ns/shacl#> .
@prefix skos:      <http://www.w3.org/2004/02/skos/core#> .
@prefix vaem:      <http://www.linkedmodel.org/schema/vaem#> .
@prefix voag:      <http://voag.linkedmodel.org/schema/voag#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .

qudt:hasDimension  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has dimension" .

qudt:definedUnitOfSystem
        rdf:type             owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "defined unit of system";
        rdfs:range           qudt:SystemOfUnits;
        rdfs:subPropertyOf   qudt:isUnitOfSystem;
        dcterms:description  "This property relates a unit of measure with the unit system that defines the unit."^^rdf:HTML;
        owl:inverseOf        qudt:hasDefinedUnit .

qudt:qkdvDenominator  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "denominator dimension vector";
        rdfs:range        qudt:QuantityKindDimensionVector .

qudt:AbstractQuantityKind
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Quantity Kind (abstract)";
        rdfs:subClassOf   qudt:Concept;
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  qudt:QuantityKind;
                            owl:onProperty     skos:broader
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:latexSymbol
                          ] .

qudt:belongsToSystemOfQuantities
        rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "belongs to system of quantities";
        rdfs:range        qudt:SystemOfQuantityKinds .

dcterms:modified  rdf:type  owl:AnnotationProperty;
        rdfs:label  "modified" .

qudt:valueQuantity  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "value for quantity";
        owl:inverseOf     qudt:quantityValue .

qudt:hasRule  rdf:type    owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has rule";
        rdfs:range        qudt:Rule .

qudt:SolidAngleUnit  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Solid Angle Unit";
        rdfs:subClassOf      qudt:AngleUnit;
        dcterms:description  "\n  The solid angle subtended by a surface S is defined as the surface area of a unit sphere covered by the surface S's projection onto the sphere. \n  A solid angle is related to the surface of a sphere in the same way an ordinary angle is related to the circumference of a circle. \n  Since the total surface area of the unit sphere is 4*pi, the measure of solid angle will always be between 0 and 4*pi.\n  " .

qudt:Enumeration  rdf:type         owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Enumeration";
        rdfs:subClassOf            qudt:Concept;
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:abbreviation
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:element
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:EnumeratedValue;
                                     owl:onProperty     qudt:default
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:default
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:EnumeratedValue;
                                     owl:onProperty     qudt:element
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:abbreviation
                                   ];
        dcterms:description        "\n  <p>An <em>Enumeration</em> is a set of literals from which a single value is selected. \n  Each literal can have a tag as an integer within a standard encoding appropriate to the range of integer values. \n  Consistency of enumeration types will allow them, and the enumerated values, to be referred to unambiguously either through symbolic name or encoding. \n  Enumerated values are also controlled vocabularies and as such need to be standardized. \n  Without this consistency enumeration literals can be stated differently and result in  data conflicts and misinterpretations.\n  </p>\n  <p>The tags are a set of positive whole numbers, not necessarily contiguous and having no numerical significance, each corresponding to the associated literal identifier. \n  An order attribute can also be given on the enumeration elements. An enumeration can itself be a member of an enumeration. This allows enumerations to be enumerated in a selection. \n  Enumerations are also subclasses of <em>Scalar Datatype</em>. \n  This allows them to be used as the reference of a datatype specification.\n  </p>\n  "^^rdf:HTML;
        qudt:dbpediaMatch          "http://dbpedia.org/resource/Enumeration"^^xsd:anyURI;
        qudt:informativeReference  "http://en.wikipedia.org/wiki/Enumerated_type"^^xsd:anyURI , "http://en.wikipedia.org/wiki/Enumeration"^^xsd:anyURI .

qudt:derivedUnitOfSystem
        rdf:type             owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "is derived unit of system";
        rdfs:range           qudt:SystemOfUnits;
        rdfs:subPropertyOf   qudt:isUnitOfSystem;
        dcterms:description  "\n  This property relates a unit of measure to the system of units in which it is defined as a derived unit. \n  That is, the derived unit is defined as a product of the base units for the system raised to some rational power.\n  ";
        owl:inverseOf        qudt:hasDerivedUnit .

qudt:normativeReference
        rdf:type             owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "normative reference";
        rdfs:range           xsd:anyURI;
        dcterms:description  "Provides a way to reference information that is an authoritative source providing a standard definition" .

qudt:relevantQuantityKind
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "relevant quantity kind" .

dcterms:contributor  rdf:type  owl:AnnotationProperty;
        rdfs:label  "contributor" .

qudt:systemDefinition
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "system definition" .

qudt:isUnitOfSystem  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "is unit of system";
        rdfs:range           qudt:SystemOfUnits;
        dcterms:description  "\n  This property relates a unit of measure with a system of units that either a) defines the unit\n   or b) allows the unit to be used within the system.\n  " .

qudt:Symbol  rdf:type     owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Symbol";
        rdfs:subClassOf   qudt:Concept .

qudt:CountingUnit  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Counting Unit";
        rdfs:subClassOf      qudt:DimensionlessUnit;
        dcterms:description  "\n  <p>A <em>Counting Unit</em> is used for all units that express counts. \n  Examples are Atomic Number, Number, Number per Year, Percent and Sample per Second.\n  </p>\n  "^^rdf:HTML .

qudt:hasDerivedCoherentUnit
        rdf:type            owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label          "derived coherent unit";
        rdfs:range          qudt:Unit;
        rdfs:subPropertyOf  qudt:hasDerivedUnit , qudt:hasCoherentUnit;
        owl:inverseOf       qudt:derivedCoherentUnitOfSystem .

qudt:hasBaseQuantityKind
        rdf:type            owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label          "has base quantity kind";
        rdfs:range          qudt:QuantityKind;
        rdfs:subPropertyOf  qudt:hasQuantityKind .

qudt:NIST_SP811_Comment
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "NIST SP~811 Comment";
        rdfs:subClassOf      qudt:Comment;
        dcterms:description  "National Institute of Standards and Technology (NIST) Special Publication 811 Comments on some quantities and their units" .

qudt:CurrencyUnit  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Currency Unit";
        rdfs:subClassOf      qudt:DimensionlessUnit;
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:integer;
                               owl:onProperty     qudt:currencyExponent
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:string;
                               owl:onProperty     qudt:currencyNumber
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:string;
                               owl:onProperty     qudt:currencyCode
                             ];
        dcterms:description  "\n  Currency Units have their own subclass of unit because:\n   (a) they have additional properties such as 'country' and\n   (b) their URIs do not conform to the same rules as other units.\n  "^^rdf:HTML .

qudt:quantityValue  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "quantity value";
        rdfs:range        qudt:QuantityValue .

qudt:ucumCode  rdf:type      owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "ucum code";
        rdfs:range           xsd:string;
        rdfs:seeAlso         <https://ucum.org/ucum.html>;
        rdfs:subPropertyOf   skos:notation;
        dcterms:description  "<p><em>ucumCode</em> associates a QUDT unit with its UCUM code (case-sensitive). </p><p>In SHACL the values are derived from specific ucum properties using 'sh:values'.</p>"^^rdf:HTML;
        dcterms:source       "https://ucum.org/ucum.html"^^xsd:anyURI .

qudt:default  rdf:type       owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "default";
        rdfs:range           qudt:EnumeratedValue;
        dcterms:description  "The default element in an enumeration"^^rdf:HTML .

qudt:vectorMagnitude  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "vector magnitude";
        rdfs:range        xsd:float .

qudt:EndianType  owl:oneOf  ( qudt:LittleEndian qudt:BigEndian ) .

qudt:RatioScale  rdf:type          owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Ratio scale";
        rdfs:seeAlso               qudt:OrdinalScale , qudt:NominalScale , qudt:IntervalScale;
        rdfs:subClassOf            qudt:Scale;
        dcterms:description        "\n  <p>A <em>Ratio Scale</em> possesses a meaningful (unique and non-arbitrary) zero value. \n  Most measurement in the physical sciences and engineering is done on ratio scales. \n  Examples include mass, length, duration, plane angle, energy and electric charge.\n  </p>\n  <p>In contrast to interval scales, ratios are now meaningful because having a non-arbitrary zero point makes it meaningful to say,\n   for example, that one object has \"twice the length\" of another (= is \"twice as long\"). \n  Very informally, many ratio scales can be described as specifying \"how much\" of something (i.e. an amount or magnitude) or \"how many\" (a count). \n  The Kelvin temperature scale is a ratio scale because it has a unique, non-arbitrary zero point called absolute zero.\n  </p>"^^rdf:HTML;
        qudt:informativeReference  "https://en.wikipedia.org/wiki/Level_of_measurement"^^xsd:anyURI .

qudt:permissibleMaths
        rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "permissible maths";
        rdfs:range        qudt:MathsFunctionType .

qudt:systemDimension  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "system dimension" .

qudt:dimensionExponentForMass
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dimension exponent for mass" .

qudt:hasReciprocalUnit
        rdf:type             owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "has reciprocal unit";
        rdfs:range           qudt:Unit;
        dcterms:description  "Used to relate a unit to its reciprocal unit." .

qudt:EnumeratedQuantity
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Enumerated Quantity";
        rdfs:subClassOf   qudt:Concept;
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  qudt:EnumeratedValue;
                            owl:onProperty     qudt:enumeratedValue
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  qudt:Enumeration;
                            owl:onProperty     qudt:enumeration
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:enumeratedValue
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:enumeration
                          ] .

qudt:applicablePhysicalConstant
        rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "applicable physical constant";
        rdfs:range        qudt:PhysicalConstant .

qudt:conversionOffsetSN
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "conversion offset scientific";
        rdfs:range        xsd:double .

qudt:QuantityKindDimensionVector_CGS
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "CGS Dimension vector";
        rdfs:subClassOf      qudt:QuantityKindDimensionVector;
        dcterms:description  "A <em>CGS Dimension Vector</em> is used to specify the dimensions for a C.G.S. quantity kind."^^rdf:HTML .

qudt:Scale  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Scale";
        rdfs:subClassOf      qudt:Verifiable , qudt:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:scaleType
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:string;
                               owl:onProperty     qudt:dataStructure
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:MathsFunctionType;
                               owl:onProperty     qudt:permissibleMaths
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:ScaleType;
                               owl:onProperty     qudt:scaleType
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:TransformType;
                               owl:onProperty     qudt:permissibleTransformation
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:dataStructure
                             ];
        dcterms:description  "\n  <p>Scales (also called \"scales of measurement\" or \"levels of measurement\") are expressions that typically are based on scale types.\n  </p>"^^rdf:HTML .

dcterms:subject  rdf:type  owl:AnnotationProperty;
        rdfs:label  "subject" .

dcterms:rights  rdf:type  owl:AnnotationProperty;
        rdfs:label  "rights" .

qudt:Organization  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Organization";
        rdfs:subClassOf   qudt:Concept;
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:url
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:anyURI;
                            owl:onProperty     qudt:url
                          ] .

qudt:Datatype  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Datatype";
        rdfs:subClassOf      qudt:Concept;
        dcterms:description  "\n   <p>A <em>Datatype</em> is a definition of the type of the \"value\" of a data item (for example, \"all integers between 0 and 10\"),\n   and the allowable operations on those values; the meaning of the data; and the way values of that type can be stored. \n  Some types are primitive - built-in to the language, with no visible internal structure.\n  For example \"Boolean\"; others are composite - constructed from one or more other types (of either kind).\n  For example lists, arrays, structures, unions. \n  Some languages provide strong typing, others allow implicit type conversion and/or explicit type conversion.\n  </p>"^^rdf:HTML .

qudt:QuantityValue  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Quantity value";
        rdfs:subClassOf      qudt:Verifiable , qudt:Concept , qudt:Quantifiable;
        dcterms:description  "\n  <p>A <em>Quantity Value</em> \n  </p>"^^rdf:HTML .

qudt:applicableISOUnit
        rdf:type            owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label          "applicable ISO unit";
        rdfs:range          qudt:Unit;
        rdfs:subPropertyOf  qudt:applicableUnit .

qudt:baseSIUnitDimensions
        rdf:type  owl:DatatypeProperty , owl:FunctionalProperty .

qudt:latexDefinition  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "latex definition" .

qudt:image  rdf:type      owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "image";
        rdfs:range        xsd:anyURI .

qudt:hasVocabulary  rdf:type       owl:AnnotationProperty;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "has vocabulary";
        qudt:plainTextDescription  "Used to relate a class to one or more graphs where vocabularies for the class are defined." .

qudt:prefix  rdf:type        owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "prefix";
        rdfs:range           qudt:Prefix;
        dcterms:description  "Associates a unit with the appropriate prefix, if any." .

qudt:BaseDimensionMagnitude
        rdf:type                   owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Base Dimension Magnitude";
        rdfs:subClassOf            qudt:Concept;
        rdfs:subClassOf            [ rdf:type         owl:Restriction;
                                     owl:cardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty   qudt:hasBaseQuantityKind
                                   ];
        rdfs:subClassOf            [ rdf:type         owl:Restriction;
                                     owl:cardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty   qudt:vectorMagnitude
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:hasBaseQuantityKind
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:QuantityKind;
                                     owl:onProperty     qudt:hasBaseQuantityKind
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:hasBaseQuantityKind
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:vectorMagnitude
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:float;
                                     owl:onProperty     qudt:vectorMagnitude
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:vectorMagnitude
                                   ];
        dcterms:description        "\n  <p>A <em>Dimension</em> expresses a magnitude for a base quantity kind such as mass, length and time.\n  </p>\n  <p>DEPRECATED - each exponent is expressed as a property. \n  Keep until a validation of this has been done.\n  </p>"^^rdf:HTML;
        qudt:informativeReference  "http://web.mit.edu/2.25/www/pdf/DA_unified.pdf"^^xsd:anyURI , "http://en.wikipedia.org/wiki/Dimensional_analysis"^^xsd:anyURI .

qudt:NominalScale  rdf:type        owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Nominal scale";
        rdfs:seeAlso               qudt:OrdinalScale , qudt:RatioScale , qudt:IntervalScale;
        rdfs:subClassOf            qudt:Scale;
        dcterms:description        "\n  A nominal scale differentiates between items or subjects based only on their names or (meta-)categories and other qualitative classifications they belong to;\n   thus dichotomous data involves the construction of classifications as well as the classification of items. \n  Discovery of an exception to a classification can be viewed as progress. \n  Numbers may be used to represent the variables but the numbers do not have numerical value or relationship:\n   for example, a Globally unique identifier. \n  Examples of these classifications include gender, nationality, ethnicity, language, genre, style, biological species, and form. \n  In a university one could also use hall of affiliation as an example.\n  "^^rdf:HTML;
        qudt:informativeReference  "https://en.wikipedia.org/wiki/Level_of_measurement"^^xsd:anyURI .

qudt:exactMatch  rdf:type  qudt:SymmetricRelation , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "exact match";
        rdfs:range        qudt:Concept .

qudt:conversionMultiplier
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "conversion multiplier";
        rdfs:range        xsd:decimal .

qudt:symbol  rdf:type        owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "symbol";
        rdfs:subPropertyOf   dtype:literal;
        dcterms:description  "The symbol is a glyph that is used to represent some concept, typically a unit or a quantity, in a compact form. For example, the symbol for an Ohm is $ohm$. This contrasts with 'unit:abbreviation', which gives a short alphanumeric abbreviation for the unit, 'ohm' for Ohm."^^qudt:LatexString .

qudt:relevantUnit  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Relevant Unit";
        dcterms:description  "This property is used for qudt:Discipline instances to identify the Unit instances that are used within a given discipline." .

qudt:plainTextDescription
        rdf:type             owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "description (plain text)";
        rdfs:range           rdfs:Literal;
        dcterms:description  "A plain text description is used to provide a description with only simple ASCII characters for cases where LaTeX , HTML or other markup would not be appropriate." .

qudt:factorUnitScalar
        rdf:type             owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "factorUnitScalar";
        rdfs:range           xsd:decimal;
        dcterms:description  "For a derived unit that is not exactly the product of its factor units, this property defines the scalar with which that product has to be multiplied with."^^rdf:HTML .

qudt:CharEncodingType
        dcterms:description  "The class of all character encoding schemes, each of which defines a rule or algorithm for encoding character data as a sequence of bits or bytes.";
        owl:oneOf            ( qudt:CharEncoding ) .

qudt:currencyExponent
        rdf:type             owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "currency exponent";
        rdfs:range           xsd:integer;
        dcterms:description  "\n  The currency exponent indicates the number of decimal places between a major currency unit and its minor currency unit. \n  For example, the US dollar is the major currency unit of the United States, and the US cent is the minor currency unit. Since one cent is 1/100 of a dollar, the US dollar has a currency exponent of 2. \n  However, the Japanese Yen has no minor currency units, so the yen has a currency exponent of 0.\n  " .

qudt:mathDefinition  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "math definition" .

qudt:value  rdf:type         owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "value";
        rdfs:range           rdf:List;
        dcterms:description  "A property to relate an observable thing with a value expressed as a decimal"^^rdf:HTML .

qudt:abbreviation  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "abbreviation";
        rdfs:range           xsd:string;
        dcterms:description  "\n  <p>An abbreviation for a unit is a short ASCII string that is used in place of the full name for the unit in contexts where non-ASCII characters would be problematic,\n   or where using the abbreviation will enhance readability. \n  When a power of abase unit needs to be expressed, such as squares this can be done using abbreviations rather than symbols. \n  For example, <em>sq ft</em> means <em>square foot</em>, and <em>cu ft</em> means <em>cubic foot</em>.\n  </p>"^^rdf:HTML .

qudt:Prefix  rdf:type     owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Prefix";
        rdfs:subClassOf   qudt:Verifiable , qudt:Concept;
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:prefixMultiplier
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:string;
                            owl:onProperty     qudt:ucumCode
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:double;
                            owl:onProperty     qudt:prefixMultiplierSN
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:decimal;
                            owl:onProperty     qudt:prefixMultiplier
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:prefixMultiplierSN
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:latexSymbol
                          ] .

qudt:currencyNumber  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "currency number";
        rdfs:range           xsd:string;
        dcterms:description  "Three-digit Currency Code as defined by ISO 4217. For example, the currency number for the US dollar is \"840\"."^^rdf:HTML .

qudt:scaleType  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "scale type";
        rdfs:range        qudt:ScaleType .

qudt:hasDefinedUnit  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "defined unit";
        rdfs:range           qudt:Unit;
        rdfs:subPropertyOf   qudt:hasUnit;
        dcterms:description  "This property relates a unit system with a unit of measure that is defined by the system."^^rdf:HTML .

qudt:QuantityKindDimensionVector_Imperial
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Imperial dimension vector";
        rdfs:subClassOf   qudt:QuantityKindDimensionVector .

qudt:hasUnitSystem  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has unit system";
        rdfs:range        qudt:SystemOfUnits .

qudt:IntervalScale  rdf:type       owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Interval scale";
        rdfs:seeAlso               qudt:OrdinalScale , qudt:RatioScale , qudt:NominalScale;
        rdfs:subClassOf            qudt:Scale;
        dcterms:description        "\n  <p>The interval type allows for the degree of difference between items, but not the ratio between them. \n  Examples include temperature with the Celsius scale, which has two defined points\n   (the freezing and boiling point of water at specific conditions) and then separated into 100 intervals,\n   date when measured from an arbitrary epoch (such as AD), percentage such as a percentage return on a stock,\n   location in Cartesian coordinates, and direction measured in degrees from true or magnetic north. \n  </p>\n  <p>Ratios are not meaningful since 20 °C cannot be said to be \"twice as hot\" as 10 °C, nor can multiplication/division be carried out between any two dates directly. \n  However, ratios of differences can be expressed; for example, one difference can be twice another. \n  Interval type variables are sometimes also called \"scaled variables\", but the formal mathematical term is an affine space (in this case an affine line).\n  </p>\n  <p>Characteristics: median, percentile &amp; Monotonic increasing (order (&lt;) &amp; totally ordered set.</p>\n  "^^rdf:HTML;
        qudt:informativeReference  "https://en.wikipedia.org/wiki/Level_of_measurement"^^xsd:anyURI .

qudt:UserQuantityKind
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "User Quantity Kind";
        rdfs:subClassOf   qudt:AbstractQuantityKind;
        rdfs:subClassOf   [ rdf:type         owl:Restriction;
                            owl:cardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty   qudt:hasQuantityKind
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:hasQuantityKind
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:hasQuantityKind
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  qudt:QuantityKind;
                            owl:onProperty     qudt:hasQuantityKind
                          ] .

qudt:isoNormativeReference
        rdf:type             owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "normative reference (ISO)";
        rdfs:range           xsd:anyURI;
        rdfs:subPropertyOf   qudt:normativeReference;
        dcterms:description  "Provides a way to reference the ISO unit definition." .

qudt:expression  rdf:type    owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "expression";
        dcterms:description  "\n  An 'expression' is a finite combination of symbols that are well-formed according to rules that apply to units of measure, quantity kinds and their dimensions.\n  " .

qudt:figure  rdf:type        owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "figure";
        rdfs:range           qudt:Figure;
        dcterms:description  "Provides a link to an image."^^rdf:HTML .

qudt:siExactMatch  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Individual from SI Reference Point" .

qudt:relativeStandardUncertainty
        rdf:type             owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "relative standard uncertainty";
        rdfs:range           xsd:double;
        dcterms:description  "The relative standard uncertainty of a measurement is the (absolute) standard uncertainty divided by the magnitude of the exact value." .

qudt:baseUSCustomaryUnitDimensions
        rdf:type  owl:DatatypeProperty , owl:FunctionalProperty .

qudt:SymmetricRelation
        rdf:type         owl:Class;
        rdfs:comment     "A `SymmetricRelation` is modeling construct used to define symmetric behavior for appropriate relations.";
        rdfs:label       "Symmetric relation";
        rdfs:subClassOf  rdf:Property .

qudt:denominatorDimensionVector
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "denominator dimension vector" .

qudt:RuleType  rdf:type   owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Rule Type";
        rdfs:subClassOf   qudt:EnumeratedValue .

dcterms:abstract  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "abstract" .

qudt:baseUnitOfSystem
        rdf:type             owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "is base unit of system";
        rdfs:subPropertyOf   qudt:definedUnitOfSystem;
        dcterms:description  "\n  This property relates a unit of measure to the system of units in which it is defined as a base unit for the system. \n  The base units of a system are used to define the derived units of the system by expressing the derived units as products of the base units raised to a rational power.\n  ";
        owl:inverseOf        qudt:hasBaseUnit .

qudt:OrderedType  dcterms:description  "Describes how a data or information structure is ordered.";
        owl:oneOf            ( qudt:Unordered qudt:PartiallyOrdered qudt:TotallyOrdered ) .

qudt:udunitsCode  rdf:type   owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "udunits code";
        rdfs:range           xsd:string;
        dcterms:description  "The UDUNITS package supports units of physical quantities. Its C library provides for arithmetic manipulation of units and for conversion of numeric values between compatible units. The package contains an extensive unit database, which is in XML format and user-extendable. The package also contains a command-line utility for investigating units and converting values."^^rdf:HTML;
        dcterms:source       "https://www.unidata.ucar.edu/software/udunits/"^^xsd:anyURI .

qudt:AbstractQuantityKind-skos_broader
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt> .

qudt:dimensionExponentForTime
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dimension exponent for time" .

qudt:PhysicalConstant
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Physical Constant";
        rdfs:subClassOf      qudt:Quantity;
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:SystemOfUnits;
                               owl:onProperty     qudt:applicableSystem
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:iec61360Code
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:anyURI;
                               owl:onProperty     qudt:isoNormativeReference
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:anyURI;
                               owl:onProperty     qudt:dbpediaMatch
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:mathMLdefinition
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:anyURI;
                               owl:onProperty     qudt:normativeReference
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:string;
                               owl:onProperty     qudt:mathMLdefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:dbpediaMatch
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:boolean;
                               owl:onProperty     qudt:exactConstant
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:QuantityKindDimensionVector;
                               owl:onProperty     qudt:hasDimensionVector
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:latexSymbol
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:Unit;
                               owl:onProperty     qudt:applicableUnit
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:latexDefinition
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  xsd:string;
                               owl:onProperty     qudt:iec61360Code
                             ];
        dcterms:description  "\n  <p>A <em>Physical constant</em> is a physical quantity that is generally believed to be both universal in nature and constant in time. \n  It can be contrasted with a mathematical constant, which is a fixed numerical value but does not directly involve any physical measurement. \n  </p>\n  <p>There are many physical constants in science, some of the most widely recognized being:\n   the speed of light in vacuum c, Newton's gravitational constant G, Planck's constant h,\n   the electric permittivity of free space ε0, and the elementary charge e.\n  </p>\n  <p>Physical constants can take many dimensional forms, or may be dimensionless depending on the system of quantities and units used.\n  </p>"^^rdf:HTML;
        qudt:dbpediaMatch    "http://dbpedia.org/resource/Physical_constant"^^xsd:anyURI .

qudt:mathMLdefinition
        rdf:type            owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label          "mathML definition";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:mathDefinition .

qudt:hasDTICode  rdf:type  owl:DatatypeProperty;
        rdfs:comment      "ISO 24165 Digital Token Identifier (12-character alphanumeric)."@en;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has DTI code"@en .

qudt:DigitalCurrencyUnit
        rdf:type                   owl:Class;
        rdfs:comment               "A currency-like unit for cryptographic or tokenized assets. Instances should reference an ISO 24165 Digital Token Identifier (DTI) when available."@en;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Digital Currency Unit"@en;
        rdfs:subClassOf            qudt:CurrencyUnit;
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:integer;
                                     owl:onProperty     qudt:currencyExponent
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:currencyCode
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:blockchainNetwork
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:blockchainNetwork
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:currencyCode
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:currencyExponent
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:hasDTICode
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:hasDTICode
                                   ];
        dcterms:description        "A currency-like unit for cryptographic or tokenized assets. Instances should reference an ISO 24165 Digital Token Identifier (DTI) when available."@en;
        qudt:informativeReference  <https://www.iso.org/standard/79891.html> , <https://dtif.org/> .

qudt:prefixMultiplier
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "prefix multiplier";
        rdfs:range        xsd:decimal .

qudt:Figure  rdf:type     owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Figure";
        rdfs:subClassOf   qudt:Concept;
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:boolean;
                            owl:onProperty     qudt:landscape
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:landscape
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:height
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:width
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:figureLabel
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:string;
                            owl:onProperty     qudt:figureLabel
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:string;
                            owl:onProperty     qudt:width
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:anyURI;
                            owl:onProperty     qudt:image
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:imageLocation
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:figureCaption
                          ];
        rdfs:subClassOf   [ rdf:type         owl:Restriction;
                            owl:cardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty   qudt:imageLocation
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:anyURI;
                            owl:onProperty     qudt:imageLocation
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:imageLocation
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:image
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:string;
                            owl:onProperty     qudt:figureCaption
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  xsd:string;
                            owl:onProperty     qudt:height
                          ] .

qudt:rationale  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "rationale";
        rdfs:range        rdf:HTML .

qudt:QuantityKindDimensionVector_CGS-GAUSS
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "CGS GAUSS Dimension vector";
        rdfs:subClassOf      qudt:QuantityKindDimensionVector_CGS;
        dcterms:description  "A <em>CGS GAUSS Dimension Vector</em> is used to specify the dimensions for Gaussioan C.G.S. quantity kind."^^rdf:HTML .

qudt:derivedNonCoherentUnitOfSystem
        rdf:type             owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "is non-coherent derived unit of system";
        rdfs:subPropertyOf   qudt:derivedUnitOfSystem;
        dcterms:description  "\n  This property relates a unit of measure to the unit system in which the unit is derived from the system's\n   base units without proportionality constant of one.\n  ";
        owl:inverseOf        qudt:hasDerivedNonCoherentUnit .

qudt:hasQuantityKind  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has quantity kind";
        rdfs:range        qudt:QuantityKind .

qudt:BitEncodingType  dcterms:description
                "A bit encoding is a correspondence between the two possible values of a bit, 0 or 1, and some interpretation. For example, in a boolean encoding, a bit denotes a truth value, where 0 corresponds to False and 1 corresponds to True.";
        owl:oneOf            ( qudt:BitEncoding ) .

qudt:acronym  rdf:type    owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "acronym" .

qudt:IntegerEncodingType
        dcterms:description  "The encoding scheme for integer types";
        owl:oneOf            ( qudt:LongUnsignedIntegerEncoding qudt:ShortUnsignedIntegerEncoding qudt:ShortUnsignedIntegerEncoding qudt:SignedIntegerEncoding qudt:UnsignedIntegerEncoding ) .

qudt:LatexString  rdf:type   rdfs:Datatype , owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Latex String";
        rdfs:subClassOf      xsd:string;
        dcterms:description  "A type of string in which some characters may be wrapped with '$' and '$ characters for LaTeX rendering." .

qudt:LogarithmicUnit  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Logarithmic Unit";
        rdfs:subClassOf      qudt:DimensionlessUnit;
        dcterms:description  "\n  Logarithmic units are abstract mathematical units that can be used to express any quantities\n   (physical or mathematical) that are defined on a logarithmic scale, that is, as being proportional\n   to the value of a logarithm function.\n  Examples of logarithmic units include common units of information and entropy, such as the bit,\n   and the byte, as well as units of relative signal strength magnitude such as the decibel.\n  "^^rdf:HTML .

qudt:Aspect  rdf:type        qudt:AspectClass , owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "QUDT Aspect";
        dcterms:description  "An aspect is an abstract type class that defines properties that can be reused."^^rdf:HTML .

qudt:Unit  rdf:type                owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Unit";
        rdfs:subClassOf            qudt:Concept , qudt:Verifiable;
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:hasQuantityKind
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:QuantityKindDimensionVector;
                                     owl:onProperty     qudt:qkdvDenominator
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:latexDefinition
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:prefix
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:SystemOfUnits;
                                     owl:onProperty     qudt:derivedUnitOfSystem
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:qkdvNumerator
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:SystemOfUnits;
                                     owl:onProperty     qudt:isUnitOfSystem
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:conversionOffset
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:mathMLdefinition
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:double;
                                     owl:onProperty     qudt:conversionOffsetSN
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:QuantityKind;
                                     owl:onProperty     qudt:hasQuantityKind
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:SystemOfUnits;
                                     owl:onProperty     qudt:derivedCoherentUnitOfSystem
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:scalingOf
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:iec61360Code
                                   ];
        rdfs:subClassOf            [ rdf:type         owl:Restriction;
                                     owl:cardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty   qudt:hasDimensionVector
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:latexSymbol
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:decimal;
                                     owl:onProperty     qudt:conversionMultiplier
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:ucumCode
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:Prefix;
                                     owl:onProperty     qudt:prefix
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:decimal;
                                     owl:onProperty     qudt:conversionOffset
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:SystemOfUnits;
                                     owl:onProperty     qudt:definedUnitOfSystem
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:SystemOfUnits;
                                     owl:onProperty     qudt:applicableSystem
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:double;
                                     owl:onProperty     qudt:conversionMultiplierSN
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:Unit;
                                     owl:onProperty     qudt:hasReciprocalUnit
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:conversionMultiplierSN
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:Unit;
                                     owl:onProperty     qudt:scalingOf
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:conversionMultiplier
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:hasDimensionVector
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:QuantityKindDimensionVector;
                                     owl:onProperty     qudt:hasDimensionVector
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:QuantityKindDimensionVector;
                                     owl:onProperty     qudt:qkdvNumerator
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:mathMLdefinition
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:uneceCommonCode
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:qkdvDenominator
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:factorUnitScalar
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:decimal;
                                     owl:onProperty     qudt:factorUnitScalar
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:siUnitsExpression
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:hasDimensionVector
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:siUnitsExpression
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:conversionOffsetSN
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:string;
                                     owl:onProperty     qudt:udunitsCode
                                   ];
        dcterms:description        "\n  A unit of measure, or unit, is a particular quantity value that has been chosen as a scale for measuring other quantities the same kind (more generally of equivalent dimension). \n  For example, the meter is a quantity of length that has been rigorously defined and standardized by the BIPM (International Board of Weights and Measures). \n  Any measurement of the length can be expressed as a number multiplied by the unit meter. \n  More formally, the value of a physical quantity Q with respect to a unit (U) is expressed as the scalar multiple of a real number (n) and U, as  $Q = nU$.\n  "^^qudt:LatexString;
        qudt:informativeReference  "http://www.allmeasures.com/Fullconversion.asp"^^xsd:anyURI , "http://dbpedia.org/resource/Category:Units_of_measure"^^xsd:anyURI .

qudt:height  rdf:type     owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "height";
        rdfs:range        xsd:string .

qudt:ScalarDataItem  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Scalar Data Item";
        rdfs:subClassOf      qudt:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:value
                             ];
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:ScalarDatatype;
                               owl:onProperty     qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:datatype
                             ];
        dcterms:description  "\n  <p>A <em>Data Item</em> holds a value that is compliant with a specified <em>Datatype</em>.\n  </p>"^^rdf:HTML .

qudt:fieldCode  rdf:type           owl:AnnotationProperty;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "field code";
        qudt:plainTextDescription  "\n  A field code is a generic property for representing unique codes that make up other identifiers. \n  For example each QuantityKind class caries a domain code as its field code.\n  " .

qudt:derivedCoherentUnitOfSystem
        rdf:type             owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "is coherent derived unit of system";
        rdfs:range           qudt:SystemOfUnits;
        rdfs:subPropertyOf   qudt:derivedUnitOfSystem , qudt:definedUnitOfSystem;
        dcterms:description  "This property relates a unit of measure to the unit system in which the unit is derived from the system's base units with a proportionality constant of one."^^rdf:HTML;
        owl:inverseOf        qudt:hasDerivedCoherentUnit .

qudt:order  rdf:type      owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "order";
        rdfs:range        xsd:nonNegativeInteger .

qudt:dimensionExponent
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dimension exponent" .

qudt:figureLabel  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "figure label";
        rdfs:range        xsd:string .

qudt:hasDenominatorPart
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has quantity kind dimension vector denominator part" .

qudt:example  rdf:type       owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "example";
        dcterms:description  "\n  The 'qudt:example' property is used to annotate an instance of a class with a reference to a concept that is an example. \n  The type of this property is 'rdf:Property'. \n  This allows both scalar and object ranges.\n  " .

qudt:QuantityKindDimensionVector_ISO
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "ISO Dimension vector";
        rdfs:subClassOf   qudt:QuantityKindDimensionVector .

qudt:reference  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "reference" .

dtype:value  rdf:type  owl:ObjectProperty;
        rdfs:range  qudt:QuantityKind .

qudt:siUnitsExpression
        rdf:type          owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "si units expression";
        rdfs:range        xsd:string .

qudt:conversionOffset
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "conversion offset";
        rdfs:range        xsd:decimal .

qudt:dimensionExponentForThermodynamicTemperature
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dimension exponent for thermodynamic temperature" .

qudt:QuantityKindDimensionVector_CGS-EMU
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "CGS EMU Dimension vector";
        rdfs:subClassOf      qudt:QuantityKindDimensionVector_CGS;
        dcterms:description  "A <em>CGS EMU Dimension Vector</em> is used to specify the dimensions for EMU C.G.S. quantity kind."^^rdf:HTML .

qudt:dimensionInverse
        rdf:type          owl:ObjectProperty , owl:SymmetricProperty , owl:InverseFunctionalProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dimension inverse";
        owl:inverseOf     qudt:dimensionInverse .

qudt:baseISOUnitDimensions
        rdf:type  owl:DatatypeProperty , owl:FunctionalProperty .

qudt:iec61360Code  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "iec-61360 code";
        rdfs:range        xsd:string .

qudt:QuantityKindDimensionVector
        rdf:type                   owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Quantity Kind Dimension Vector";
        rdfs:subClassOf            qudt:Concept;
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:dimensionExponentForElectricCurrent
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:latexDefinition
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  qudt:QuantityKind;
                                     owl:onProperty     qudt:hasReferenceQuantityKind
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:integer;
                                     owl:onProperty     qudt:dimensionExponentForElectricCurrent
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:latexSymbol
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:dimensionExponentForElectricCurrent
                                   ];
        rdfs:subClassOf            [ rdf:type         owl:Restriction;
                                     owl:cardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty   qudt:dimensionExponentForElectricCurrent
                                   ];
        dcterms:description        "\n $\\text{Quantity Kind Dimension Vector}$ describes the dimensionality of a quantity kind in the context of a system of units. \n In the SI system of units, the dimensions of a quantity kind are expressed as a product of the basic\n  physical dimensions mass ($M$), length ($L$), time ($T$) current ($I$), amount of substance ($N$),\n   luminous intensity ($J$) and absolute temperature \n   ($\\theta$) as $dim \\, Q = L^{\\alpha} \\, M^{\\beta} \\, T^{\\gamma} \\, I ^{\\delta} \\, \\theta ^{\\epsilon} \\, N^{\\eta} \\, J ^{\\nu}$.\n\n\n  The rational powers of the dimensional exponents, $\\alpha, \\, \\beta, \\, \\gamma, \\, \\delta, \\, \\epsilon, \\, \\eta, \\, \\nu$, are positive, negative, or zero.\n\n  For example, the dimension of the physical quantity kind $\\it{speed}$ is $\\boxed{length/time}$, $L/T$ or $LT^{-1}$,\n   and the dimension of the physical quantity kind force is $\\boxed{mass \\times acceleration}$ or $\\boxed{mass \\times (length/time)/time}$, $ML/T^2$ or $MLT^{-2}$ respectively.\n "^^qudt:LatexString;
        qudt:informativeReference  "http://web.mit.edu/2.25/www/pdf/DA_unified.pdf"^^xsd:anyURI , "http://en.wikipedia.org/wiki/Dimensional_analysis"^^xsd:anyURI .

qudt:QuantityKindDimensionVector_CGS-ESU
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "CGS ESU Dimension vector";
        rdfs:subClassOf      qudt:QuantityKindDimensionVector_CGS;
        dcterms:description  "A <em>CGS ESU Dimension Vector</em> is used to specify the dimensions for ESU C.G.S. quantity kind."^^rdf:HTML .

qudt:isDimensionInSystem
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "is dimension in system" .

qudt:outOfScope  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "out of scope" .

vaem:QUDT  rdf:type          vaem:Party;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "QUDT";
        dcterms:description  "QUDT is a non-profit organization that governs the QUDT ontologies."^^rdf:HTML;
        vaem:graphName       "qudt.org";
        vaem:website         "http://www.qudt.org"^^xsd:anyURI .

qudt:CardinalityType  dcterms:description
                "\n  In mathematics, the cardinality of a set is a measure of the number of elements of the set.\n  For example, the set $A = {2, 4, 6}$ contains 3 elements, and therefore $A$ has a cardinality of 3. \n  There are two approaches to cardinality: one which compares sets directly using bijections and injections,\n   and another which uses cardinal numbers.\n  "^^qudt:LatexString;
        owl:oneOf            ( qudt:CT_COUNTABLY-INFINITE qudt:CT_FINITE qudt:CT_UNCOUNTABLE ) .

qudt:hasFactorUnit  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "hasFactorUnit";
        dcterms:description  "This property relates a derived unit to one of its constituent factor units"^^rdf:HTML .

qudt:baseCGSUnitDimensions
        rdf:type  owl:DatatypeProperty , owl:FunctionalProperty .

<http://qudt.org/$$QUDT_VERSION$$/schema/qudt>
        rdf:type               owl:Ontology;
        rdfs:isDefinedBy       <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label             "QUDT Schema - Version $$QUDT_VERSION$$";
        vaem:hasGraphMetadata  vaem:GMD_QUDT-SCHEMA;
        owl:imports            <http://www.linkedmodel.org/schema/dtype> , <http://www.linkedmodel.org/schema/vaem> , <http://www.w3.org/2004/02/skos/core>;
        owl:versionIRI         <http://qudt.org/$$QUDT_VERSION$$/schema/qudt> .

qudt:standardUncertaintySN
        rdf:type             owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "standard uncertainty scientific";
        rdfs:range           xsd:double;
        dcterms:description  "The standard uncertainty of a quantity is the estimated standard deviation of the mean taken from a series of measurements." .

qudt:DataItem  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Data Item";
        rdfs:subClassOf      qudt:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:value
                             ];
        dcterms:description  "\n  <p>A <em>Data Item</em> holds a value that maybe a scalar or structured datatype.\n  <em>Quantity Value</em> specifies which case applies.\n  </p>"^^rdf:HTML .

qudt:permissibleTransformation
        rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "permissible transformation";
        rdfs:range        qudt:TransformType .

qudt:hasNumeratorPart
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has numerator part" .

qudt:width  rdf:type      owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "width";
        rdfs:range        xsd:string .

qudt:UCUMcs  rdf:type        rdfs:Datatype , owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "case-sensitive UCUM code";
        rdfs:seeAlso         <https://ucum.org/ucum.html>;
        rdfs:subClassOf      xsd:string;
        dcterms:description  "Lexical pattern for the case-sensitive version of UCUM code";
        dcterms:source       <https://ucum.org/ucum.html> .

qudt:isMetricUnit  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "is metric unit" .

qudt:DerivedUnit  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Derived Unit";
        rdfs:subClassOf      qudt:Unit;
        dcterms:description  "\n  <p>A <em>Derived Unit</em> is a type specification for units that are derived from other units.\n  </p>"^^rdf:HTML;
        qudt:dbpediaMatch    "http://dbpedia.org/resource/Category:SI_derived_units"^^xsd:anyURI .

qudt:imageLocation  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "image location";
        rdfs:range        xsd:anyURI .

qudt:baseDimensionEnumeration
        rdf:type             owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "base dimension enumeration";
        rdfs:range           qudt:Enumeration;
        dcterms:description  "This property associates a system of quantities with an enumeration that enumerates the base dimensions of the system in canonical order."^^rdf:HTML .

qudt:Rule  rdf:type       owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Rule";
        rdfs:subClassOf   qudt:Concept , qudt:Verifiable;
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  rdf:HTML;
                            owl:onProperty     qudt:rationale
                          ];
        rdfs:subClassOf   [ rdf:type           owl:Restriction;
                            owl:allValuesFrom  qudt:RuleType;
                            owl:onProperty     qudt:ruleType
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  "0"^^xsd:nonNegativeInteger;
                            owl:onProperty      qudt:rationale
                          ] .

dtype:literal  rdf:type  owl:DatatypeProperty;
        rdfs:range  xsd:string .

qudt:id  rdf:type            owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "qudt id";
        rdfs:range           xsd:string;
        dcterms:description  "\n  <p>The \"qudt:id\" is an identifier string that uniquely identifies a QUDT concept. \n  The identifier is constructed using a prefix. \n  For example, units are coded using the pattern: \"UCCCENNNN\", where \"CCC\" is a numeric code or a category\n   and \"NNNN\" is a digit string for a member element of that category. \n  </p>\n  <p>For scaled units there may be an addition field that has the format \"QNN\" where \"NN\" is a digit string representing\n   an exponent power, and \"Q\" is a qualifier that indicates with the code \"P\" that the power is a positive decimal exponent,\n   or the code \"N\" for a negative decimal exponent, or the code \"B\" for binary positive exponents.\n  </p>"^^rdf:HTML .

qudt:blockchainNetwork
        rdf:type          owl:DatatypeProperty;
        rdfs:comment      "Primary network name (e.g., 'Bitcoin Mainnet', 'Ethereum Mainnet')."@en;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "blockchain network"@en .

qudt:OrdinalScale  rdf:type        owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label                 "Ordinal scale";
        rdfs:seeAlso               qudt:RatioScale , qudt:IntervalScale , qudt:NominalScale;
        rdfs:subClassOf            qudt:Scale;
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:order
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty      qudt:order
                                   ];
        rdfs:subClassOf            [ rdf:type         owl:Restriction;
                                     owl:cardinality  "1"^^xsd:nonNegativeInteger;
                                     owl:onProperty   qudt:order
                                   ];
        rdfs:subClassOf            [ rdf:type           owl:Restriction;
                                     owl:allValuesFrom  xsd:nonNegativeInteger;
                                     owl:onProperty     qudt:order
                                   ];
        dcterms:description        "\n  <p>The ordinal type allows for rank order (1st, 2nd, 3rd, etc.) by which data can be sorted,\n   but still does not allow for relative degree of difference between them. \n  Examples include, on one hand, dichotomous data with dichotomous (or dichotomized) values such as:\n   'sick' vs. 'healthy' when measuring health, 'guilty' vs. 'innocent' when making judgments in courts,\n   'wrong/false' vs. 'right/true' when measuring truth value, and, on the other hand, non-dichotomous data consisting of a spectrum of values, such as:\n   'completely agree', 'mostly agree', 'mostly disagree', 'completely disagree' when measuring opinion.\n  </p>"^^rdf:HTML;
        qudt:informativeReference  "https://en.wikipedia.org/wiki/Level_of_measurement"^^xsd:anyURI .

qudt:dataStructure  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "data structure";
        rdfs:range        xsd:string .

qudt:dimensionExponentForAmountOfSubstance
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dimension exponent for amount of substance" .

qudt:deprecated  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "deprecated";
        rdfs:range        xsd:boolean .

qudt:QuantityType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Quantity type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        rdfs:subClassOf      [ rdf:type           owl:Restriction;
                               owl:allValuesFrom  qudt:QuantityKind;
                               owl:onProperty     dtype:value
                             ];
        dcterms:description  "\n  A $\\textit{Quantity Type}$ is an enumeration of quantity kinds. \n  It specializes $\\boxed{dtype:EnumeratedValue}$ by constrinaing $\\boxed{dtype:value}$ to instances of $\\boxed{qudt:QuantityKind}$.\n  "^^qudt:LatexString .

qudt:dimensionExponentForLuminousIntensity
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dimension exponent for luminous intensity" .

qudt:Statement  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Statement";
        rdfs:subClassOf   rdf:Statement .

qudt:qkdvNumerator  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "numerator dimension vector";
        rdfs:range        qudt:QuantityKindDimensionVector .

qudt:FactorUnit  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "Factor Unit" , "Reified Factor";
        rdfs:subClassOf      qudt:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:hasUnit
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty      qudt:hasUnit
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  "1"^^xsd:nonNegativeInteger;
                               owl:onProperty   qudt:hasUnit
                             ];
        dcterms:description  "\n  <p>A <em>Factor Unit</em> is a type specification for a unit, exponent pair that is a component of a derived unit.\n  </p>"^^rdf:HTML;
        qudt:dbpediaMatch    "http://dbpedia.org/resource/Category:SI_derived_units"^^xsd:anyURI .

qudt:dbpediaMatch  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "dbpedia match";
        rdfs:range        xsd:anyURI .

qudt:scalingOf  rdf:type     owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label           "scalingOf";
        rdfs:range           qudt:Unit;
        dcterms:description  "This property relates a unit that is scaled to the base unit that its qudt:conversionMultiplier converts it to"^^rdf:HTML .

qudt:prefixMultiplierSN
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "prefix multiplier scientific";
        rdfs:range        xsd:double .

qudt:Discipline  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "Discipline";
        rdfs:subClassOf   qudt:Concept .

qudt:numericValue  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "numeric value" .

qudt:hasReferenceQuantityKind
        rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/qudt>;
        rdfs:label        "has reference quantity kind";
        rdfs:range        qudt:QuantityKind .

qudt:enumeratedValue  rdf:type  owl:ObjectProperty , owl:FunctionalProperty;
        rdfs:range  qudt:EnumeratedValue .

<http://www.linkedmodel.org/schema/dtype>
        vaem:namespace        "http://www.linkedmodel.org/schema/dtype#"^^xsd:anyURI;
        vaem:namespacePrefix  "dtype" .

qudt:Citation  rdf:type      owl:Class;
