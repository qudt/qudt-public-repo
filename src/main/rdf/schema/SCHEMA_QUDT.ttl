qudt:Quantifiable
  a owl:Class ;
  dcterms:description """
  <p><em>Quantifiable</em> is an aspect class that affords to an entity properties for being measurable,
   observable, or countable.
  </p>"""^^rdf:HTML ;
  rdfs:isDefinedBy <http://qudt.org/$$QUDT_VERSION$$/schema/qudt> ;
  rdfs:label "Quantifiable" ;
