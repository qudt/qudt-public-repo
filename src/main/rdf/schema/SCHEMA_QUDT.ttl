  ] ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onProperty qudt:hasDimensionVector ;
  ] ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:minCardinality "0"^^xsd:nonNegativeInteger ;
    owl:onProperty qudt:applicableISOUnit ;
  ] ;
