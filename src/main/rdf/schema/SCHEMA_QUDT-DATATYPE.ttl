                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Function";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Concept> .

<http://qudt.org/schema/qudt/SignedMediumIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/SignedIntegerType>;
        <http://purl.org/dc/terms/description>
                "\n  A \"Signed Medium Integers\" is an integer of 24 bits that can take on both positive and negative values.\n  " .

<http://qudt.org/schema/qudt/bitOrder>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "bit order";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/EndianType> .

<http://qudt.org/schema/qudt/Coordinates-2D>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "2D Coordinate Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TwoTuple> , <http://qudt.org/schema/qudt/CartesianCoordinates>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A 2D coordinate system is a system for assigning a two-tuple of numbers or scalars to each point in an 2-dimensional space. \n  A corresponding 2D Coordinate Type is a data type that defines the data type for each coordinate (tuple member) in a 2D coordinate system.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/valueRange>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "value range" .

<http://qudt.org/schema/qudt/CoordinateCenterKind>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Coordinate Center Kind";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/NominalScale> , <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "\n  <p>An enumeration of coordinate centers for coordinate systems, such as:\n   \"Earth centered\", \"Mars centered\", \"Moon centered\", \"Sun centered\",  and \"Vehicle centered\".\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/pythonName>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
