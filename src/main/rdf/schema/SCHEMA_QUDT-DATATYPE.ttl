                <http://www.w3.org/2001/XMLSchema#string>;
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/id> .

<http://qudt.org/schema/qudt/vector>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "vector";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Vector> .

<http://qudt.org/schema/qudt/CharacterType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Character Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/OrdinalType>;
        <http://purl.org/dc/terms/description>
                "\n  A <em>Character Type</em> is a data type that defines the type and encoding of single characters.\n  " .

<http://qudt.org/schema/qudt/DataEncoding>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Data Encoding";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Aspect>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/bitOrder>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/byteOrder>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/encoding>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p><em>Data Encoding</em> expresses the properties that specify how data is represented at the bit and byte level. \n  These properties are applicable to describing raw data.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/TupleType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Tuple Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CompositeDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/length>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/length>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementTypeCount>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p><em>Tuple</em> originated as an abstraction of the sequence: single, double, triple, quadruple, quintuple, n-tuple.  \n  In mathematics, a tuple is a finite sequence (also known as an <em>Ordered List</em> of objects, each of a specified type. \n  The <em>n</em> can be any non-negative integer.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.w3.org/2001/XMLSchema#unsignedByte>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/IntegerListShape>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/List> .

<http://qudt.org/schema/qudt/PhysicalAddress>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Physical Address Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CompositeDatatype>;
        <http://purl.org/dc/terms/description>
                "A physical address is a pointer to a memory location." .

<http://qudt.org/schema/qudt/elementDatatype>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "element datatype";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/CharacterType> , <http://qudt.org/schema/qudt/TupleMember> , <http://qudt.org/schema/qudt/ScalarDatatype> , <http://qudt.org/schema/qudt/UnsignedIntegerType> , <http://qudt.org/schema/qudt/NumericType> , <http://qudt.org/schema/qudt/Datatype> , <http://qudt.org/schema/qudt/RealSinglePrecisionType> , <http://qudt.org/schema/qudt/CoordinateMember>;
        <http://purl.org/dc/terms/description>
                "\n  This property is used to relate a structured data type with the data type the structured type's elements. \n  It is used for structured data types with elements that are all of the same type.\n  " .

<http://qudt.org/schema/qudt/Yes>
        a       <http://qudt.org/schema/qudt/YesNoType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Yes";
        <http://www.linkedmodel.org/schema/dtype#literal>
                "Y" .

<http://qudt.org/schema/qudt/CoordinateMember>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Coordinate Member";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TupleMember>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Coordinate Member</em> is a data type that defines the properties of a coordinate in a coordinate system.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/OrderedType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Ordered type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "Describes how a data or information structure is ordered." .

<http://qudt.org/schema/qudt/CompositionTree>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Composition Tree";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Tree>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/function>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/function>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/function>
                ] .

<http://qudt.org/schema/qudt/AerospaceCoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Aerospace Coordinate system";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CoordinateSystem>;
        <http://purl.org/dc/terms/description>
                "A sub-type of 'Coordinate system'." .

<http://qudt.org/schema/qudt/BigEndian>
        a       <http://qudt.org/schema/qudt/EndianType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Big Endian";
        <http://www.linkedmodel.org/schema/dtype#literal>
                "big" .

<http://qudt.org/schema/qudt/CompositeDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Composite Data Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StructuredDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/padding>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Composite Datatype</em> is a datatype that is constructed from basic primitive types and other composite types. \n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML>;
        <http://www.w3.org/ns/prov#wasInfluencedBy>
                <https://en.wikipedia.org/wiki/List_of_data_structures> .

<http://qudt.org/schema/qudt/field>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "field";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/DataSetElement> .

<http://qudt.org/schema/qudt/TimeSeriesArrayType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Time Series Array Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ArrayType>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Time Series Array Type</em> is a data type that specifies the properties of arrays that hold time series data. \n  A time series is a sequence of data points, measured at successive time intervals. \n  The time intervals may be uniformly or non-uniformly spaced.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/ReferenceFrame>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Reference Frame";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Concept>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/zAxisDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/yCoordinateDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/informativeReference>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://purl.org/dc/terms/description>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/realization>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/xCoordinateDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/xAxisDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/yAxisDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/vaem#comment>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/zCoordinateDefinition>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p> A <em>Reference Frame</em> (or \"frame of reference\") in physics, may refer to a coordinate system or set of axes.\nThe frame serves as the datum to measure the position, orientation, and other properties of objects in it.\nReference frame may refer to an observational reference frame tied to the state of motion of an observer. \nReference frame may also refer to both an observational reference frame and an attached coordinate system as a unit.\n</p>\n"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/FunctionDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Function Data Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StructuredDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/functionArity>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/functionArity>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/returnType>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/functionArity>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/returnType>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A function data type defines the input and output data type for a function or method. \n  The data type includes at least the function name and the number of its parameters. \n  In some programming languages, it may also specify the function's return type or the types of its arguments.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/precision>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "precision";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer>;
        <http://purl.org/dc/terms/description>
                "\n  <p>Precision is the number of digits used to perform a given computation. \n  The concepts of accuracy and precision are both closely related and often confused. \n  While the accuracy of a number x is given by the number of significant decimal (or other) digits to the right of the decimal point in x,\n   the precision of x is the total number of significant decimal (or other) digits.\n  </p>\n  <p>For a given numeric data type, the value of type:precision (?p) is related to the values of type:maxMantissa (?M) and type:base (?b) by the formula:\n  </p>\n  <p>?p := log(?b, ?M)\n  </p>\n  <p>where log(a,y) = x iff y=a^x.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/Set>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Set Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Collection>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Set</em> is an abstract data type that defines the properties of sets. \n  A set is a collection (container) of certain values, without any particular order, and no repeated values. \n  It corresponds with a finite set in mathematics.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/Encoding>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Encoding";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://www.w3.org/2004/02/skos/core#Concept>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/bits>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/bytes>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>An encoding is a rule or algorithm that is used to convert data from a native, or unspecified form into a specific form that satisfies the encoding rules. \n  Examples of encodings include character encodings, such as UTF-8.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/OrdinalType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Ordinal Data Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ScalarDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>An ordinal data type is a data type that specifies the properties of values that can easily be put in a one to one correspondence with a subset of the natural numbers. \n  Examples include boolean, character, and integer data types.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/AlgebraicDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Algebraic Datatype";
        <http://www.w3.org/2000/01/rdf-schema#seeAlso>
                <http://qudt.org/schema/qudt/AbstractDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StructuredDatatype>;
        <http://purl.org/dc/terms/description>
                "<p>An <em>Algebraic Datatype</em> is a datatype each of whose values are data from other data types wrapped in one of the constructors of the data type. \nAny wrapped datum is an argument to the constructor. \nIn contrast to other data types, the constructor is not executed and the only way to operate on the data is to unwrap the constructor using pattern matching.\n</p>\n<p>The most common algebraic data type is a list with two constructors: Nil or [] for an empty list, and Cons (an abbreviation of constructor), \n ::, or : for the combination of a new element with a shorter list (for example (Cons 1 '(2 3 4)) or 1:[2,3,4]).\n</p>\n<p>Special cases of algebraic types are product types i.e. records (only one constructor) and enumerated types (many constructors with no arguments). \nAlgebraic types are one kind of composite type (i.e. a type formed by combining other types).\n</p>\n<p>An algebraic data type may also be an abstract data type (ADT) if it is exported from a module without its constructors. \nValues of such a type can only be manipulated using functions defined in the same module as the type itself.\n</p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML>;
        <http://www.w3.org/ns/prov#wasInfluencedBy>
                <http://en.wikipedia.org/wiki/Algebraic_data_type> .

<http://qudt.org/schema/qudt/SplineCalibrator>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Spline calibrator";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Map>;
        <http://purl.org/dc/terms/description>
                "A sub-type of 'Map Type'." .

<http://qudt.org/schema/qudt/BigIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Big Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/IntegerDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Big Integer</em> is an integer that can be represented in eight octets (64 bits) of machine memory. \n  Big integers may be signed or unsigned.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://purl.org/dc/terms/description>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "description" .

<http://qudt.org/schema/qudt/ParameterModifiabilityType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Parameter modifiability type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "An enumeration of literals that signify whether a parameter is modifiable and if so, by whom." .

<http://qudt.org/schema/qudt/memberDatatype>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "member datatype";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/CharacterType>;
        <http://purl.org/dc/terms/description>
                "\n  This property is used to define the data type of a collection's elements. \n  It is used for collections with elements that are all of the same type.\n  " .

<http://qudt.org/schema/qudt/signedness>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "signedness";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/SignednessType> .

<http://www.w3.org/2001/XMLSchema#QName>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/IntegerEncodingType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Integer Encoding";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Encoding>;
        <http://purl.org/dc/terms/description>
                "The encoding scheme for integer types" .

<http://qudt.org/schema/qudt/OrderedTree>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Ordered Tree Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Tree> , <http://qudt.org/schema/qudt/OrderedCollection>;
        <http://purl.org/dc/terms/description>
                "\n  <p>An \"Ordered Tree Type\" is a data type that defines the properties of data structures that represent ordered trees. \n  An ordered tree is a tree where the children of every node are ordered, that is, there is a first child, second child, third child, etc. \n  Typically a type specification for an ordered tree will include the comparison operator (such as <b>lt</b> or <b>gt</b>) that is used to order the nodes.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/Signed>
        a       <http://qudt.org/schema/qudt/SignednessType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed";
        <http://www.linkedmodel.org/schema/dtype#literal>
                "signed" .

<http://qudt.org/schema/qudt/LargeObject>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Large object";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CompositeDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  A 'LargeObject' datatype is used to store blocks of unstructured data (such as text, graphic images, video clips, and sound waveforms). \n  They often are used to allow efficient, random, piece-wise access to the data.\n  " .

<http://qudt.org/schema/qudt/VariableIntervalTimeSeriesArrayType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Variable Interval Time Series Array Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TimeSeriesArrayType>;
        <http://purl.org/dc/terms/description>
                "A Variable Interval Time Series Array Type is a data type that specifies the properties of arrays that hold time series data that has been sampled over non-uniformly spaced time intervals. A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals. For variable interval time series, the successive time intervals may follow a repeating pattern, or may be completely random." .

<http://qudt.org/schema/qudt/totalDigits>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "total digits" .

<http://qudt.org/schema/qudt/Coordinates-3D-DoublePrecision>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "3D Coordinates (Double Precision)";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Coordinates-3D>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_X>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_Z>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_Y>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_Z>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_Y>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_Z>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_Y>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_X>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/double_X>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A 3D coordinates in double floating point precision for locating a point in physical space.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/TaggedEnumeration>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Tagged Enumeration";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Enumeration>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/dtype#code>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/dtype#code>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/dtype#code>
                ];
        <http://purl.org/dc/terms/description>
                "An enumeration where each literal  has a tag that is a non-negative integer. These enumerations are likely to have their literals encoded - hence the need for the tag." .

<http://qudt.org/schema/qudt/MemoryOrderType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Memory order type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "A sub-type of 'Enumerated Value'." .

<http://qudt.org/schema/qudt/mantissa>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "mantissa";
        <http://purl.org/dc/terms/description>
                "In scientific notation, the mantissa of a real number is the integer coefficient preceding the base raised to the exponent." .

<http://qudt.org/schema/qudt/zCoordinateDefinition>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Z-Coordinate definition";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string> .

<http://qudt.org/schema/qudt/Map>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Map Type";
        <http://www.w3.org/2000/01/rdf-schema#seeAlso>
                <http://qudt.org/schema/qudt/AssociativeArray>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Collection>;
        <http://purl.org/dc/terms/description>
                "A Map Type is an abstract data type that defines the properties of map data structures. A Map (or Associative Array) is an abstract data structure composed of a collection of keys and a collection of values, where each key is associated with one value. The operation of finding the value associated with a key is called a lookup or indexing, and this is the most important operation supported by an associative array. The relationship between a key and its value is sometimes called a mapping or binding." .

<http://qudt.org/schema/qudt/Sequence>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Sequence";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Collection>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Sequence</em> is an enumerated collection of objects in which repetitions are allowed. \n  Like a set, it contains members (also called elements, or terms). \n  The number of elements (possibly infinite) is called the length of the sequence.\n  </p>\n  <p>Unlike a set, order matters, and exactly the same elements can appear multiple times at different positions in the sequence. \n  Formally, a sequence can be defined as a function whose domain is either the set of the natural numbers (for infinite sequences) or the set of the first n natural numbers (for a sequence of finite length n). \n  </p>\n  <p>The position of an element in a sequence is its rank or index; it is the integer from which the element is the image. \n  It depends on the context or of a specific convention, if the first element has index 0 or 1. [Wikipedia]\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/ByteEncodingType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Byte Encoding";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Encoding>;
        <http://purl.org/dc/terms/description>
                "This class contains the various ways that information may be encoded into bytes." .

<http://qudt.org/schema/qudt/upperBound>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "upper bound" .

<http://qudt.org/schema/qudt/IconicCue>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Iconic enumeration literal";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ModalCue>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/image>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/image>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/image>
                ] .

<http://qudt.org/schema/qudt/OneMeansOff>
        a       <http://qudt.org/schema/qudt/OnOffStateType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "One means off";
        <http://qudt.org/schema/qudt/inverted>
                true;
        <http://www.linkedmodel.org/schema/dtype#literal>
                "off" .

<http://qudt.org/schema/qudt/yAxisDefinition>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Y-Axis definition";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://purl.org/dc/terms/description>
                "\n  The definition of the Y-Axis could be an intersection, cross-product or other function of a meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

<http://qudt.org/schema/qudt/RealNumberType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Real number type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/RealDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Real Number Type</em> is the class of data values that approximate real numbers in finite precision. \n  Often, such values are expressed in \"mantissa, base, exponent\" form. \n  Any rational number can be expressed in the form m*b^<sup>e</sup>, where m (the mantissa), b (the base), and e (the exponent) are integers. \n  Typically, b is chosen to be either 2 or 10, and then the values of m and e are determined given the choice of base.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/TypeVector>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Type vector";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Vector>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Type Vector</em> is a vector whose elements are data types. \n  They are used to specify the type of each component of a vector or class of vectors. \n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/elementName>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "element name";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string> .

<http://www.w3.org/2001/XMLSchema#string>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/dimensions>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "dimensions";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#int>;
        <http://purl.org/dc/terms/description>
                "\n  The extent of each dimension making up an array or matrix.\n  Dimensions are expressed as an integer list.\n  For example a 4 by 4 array has dimensions (4 4), whereas a vector or a string has dimensions (1).\n  " , "\n  The extent of each dimension making up a matrix or an array. \n  For example a 4 by 4 array has dimensions (4 4),\n  whereas a vector or a string has dimensions (1).\n  " .

<http://qudt.org/schema/qudt/enumeration>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "enumeration" .

<http://qudt.org/schema/qudt/zAxisDefinition>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Z-Axis definition";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://purl.org/dc/terms/description>
                "\n  The definition of the Y-Axis could be an intersection, croos-product or other function of a meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

<http://qudt.org/schema/qudt/ShortUnsignedIntegerEncoding>
        a       <http://qudt.org/schema/qudt/IntegerEncodingType> , <http://qudt.org/schema/qudt/BooleanEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
