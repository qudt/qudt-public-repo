@prefix dc:        <http://purl.org/dc/elements/1.1/> .
@prefix dcterms:   <http://purl.org/dc/terms/> .
@prefix dtype:     <http://www.linkedmodel.org/schema/dtype#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix prov:      <http://www.w3.org/ns/prov#> .
@prefix qudt:      <http://qudt.org/schema/qudt/> .
@prefix qudt.type: <http://qudt.org/vocab/type/> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:        <http://www.w3.org/ns/shacl#> .
@prefix skos:      <http://www.w3.org/2004/02/skos/core#> .
@prefix vaem:      <http://www.linkedmodel.org/schema/vaem#> .
@prefix voag:      <http://voag.linkedmodel.org/schema/voag#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .

qudt:RealDoublePrecisionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Real Double Precision Type";
        rdfs:subClassOf      qudt:RealDatatype , qudt:DoublePrecisionType;
        dcterms:description  "\n  <p>A real double precision data type specifies how a real number, or an approximation of a real number is stored in memory.\n  Typically this occupies two words in computer memory, where the byte length of a word depends on machine address size of the computer processor. \n  For example, on 32-bit machine architectures, a word is four bytes.\n  An example of a real double precision data type specification is the IEEE 754 standard for encoding binary or decimal floating point numbers in 8 bytes for storage on 32-bit machine architectures.\n  </p>"^^rdf:HTML .

xsd:unsignedShort  rdf:type  rdfs:Datatype .

qudt:WetDryStateType  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Wet dry state type";
        rdfs:subClassOf   qudt:EnumeratedValue , qudt:DiscreteState .

qudt:coordinateSystem
        rdf:type          owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "coordinate system";
        rdfs:range        qudt:CoordinateSystem .

qudt:byRow  rdf:type      owl:DatatypeProperty , owl:FunctionalProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:range        xsd:boolean .

qudt:ThreeTuple  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Three-Tuple";
        rdfs:subClassOf      qudt:N-Tuple;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  A three-tuple is a tuple with exactly three members. \n  A Three-Tuple Type is a data type that defines the type properties of a class of three-tuples and their members.\n  " .

qudt:StructuredDatatype
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Structured Data Type";
        rdfs:subClassOf      qudt:Datatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  <p>A <em>Structured Datatype</em>, in contrast to a scalar data type, is used to characterize classes of complex data structures.\n  Examples are collections, linked and indexed lists, trees, ordered trees, and multi-dimensional file formats.\n  </p>"^^rdf:HTML .

qudt:Table  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Table Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:dimensionality
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:columns
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:rows
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:byRow
                             ];
        dcterms:description  "\n  A Table Type is a data type that specifies the properties of table data structures. \n  A table is both a mode of visual communication and a means of arranging data. \n  The precise conventions and terminology for describing tables varies depending on the context. \n  Moreover, tables differ significantly in variety, structure, flexibility, notation, representation and use.\n  " .

qudt:SignedBigIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Big Integer Type";
        rdfs:subClassOf      qudt:BigIntegerType , qudt:SignedIntegerType;
        dcterms:description  "A Signed Big Integer is a signed integer that can be represented in eight octets (64 bits) of machine memory." .

qudt:PartialArray  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Partial Array";
        rdfs:subClassOf      qudt:Array;
        dcterms:description  "\n  A partial array is an Array with two attributes that define the starting and ending indices of the elements that are provided.\n  "^^rdf:HTML .

xsd:gMonth  rdf:type  rdfs:Datatype .

qudt:rollRotationDefinition
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "roll rotation definition";
        rdfs:range          qudt:AxialOrientationType;
        rdfs:subPropertyOf  qudt:rotationDefinition .

qudt:ISO8601-UTCDateTime-BasicFormat
        rdf:type             qudt:DateTimeStringEncodingType;
        rdfs:isDefinedBy     <file:///Users/ralphtq/git-qudt/qudt-public-repo/qudt> , <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "ISO 8601 UTC Date Time - Basic Format";
        qudt:allowedPattern  "[0-9]{4}[0-9]{2}[0-9]{2}T[0-9]{2}[0-9]{2}[0-9]{2}.[0-9]+Z" , "[0-9]{4}[0-9]{2}[0-9]{2}T[0-9]{2}[0-9]{2}[0-9]{2}Z" .

qudt:cardinality  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "cardinality";
        rdfs:range        qudt:CardinalityType .

qudt:SystemModifiableParameter
        rdf:type             qudt:ParameterModifiabilityType;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "System modifiable parameter";
        dcterms:description  "Parameter is modifiable by a (computer) system.";
        dtype:code           "1";
        dtype:literal        "system" .

qudt:visualCue  rdf:type    owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "visual cue";
        rdfs:subPropertyOf  qudt:modalCue .

qudt:StateSpaceVector
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "State Space Vector Type";
        rdfs:subClassOf      qudt:Vector;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:coordinateSystem
                             ];
        dcterms:description  "\n  A state vector in general control systems describes the observed states of an object in state space.\n  For example in variables of the degrees of freedom for motion. \n  As data types, state vector types are used to specify the structure of state vectors, such as how the observed state is encoded.\n  " .

qudt:IntegerUnionList
        rdf:type          qudt:List;
        rdf:first         xsd:int;
        rdf:rest          ( xsd:nonNegativeInteger xsd:positiveInteger xsd:integer );
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Integer Union List" .

qudt:TextTypeUnion  rdf:type  qudt:List;
        rdf:first            xsd:string;
        rdf:rest             ( rdf:HTML qudt:LatexString );
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Text Type Union";
        dcterms:description  "\n  An rdf:List that can be used in property constraints as value for sh:or to indicate that all values of a property\n   must be a plain string, a string with HTML markup, or a string with LaTeX markup.\n  " .

qudt:AbstractDatatype
        rdf:type              owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Abstract Datatype";
        rdfs:subClassOf       qudt:StructuredDatatype;
        dcterms:description   "\n  <p>An \"Abstract Datatype\" (ADT) is a specification of a set of data and the set of operations that can be performed on the data. \n  Such a data type is abstract in the sense that it is independent of various concrete implementations. \n  The definition can be mathematical, or it can be programmed as an interface. \n  A first class ADT supports the creation of multiple instances of the ADT, and the interface normally provides a constructor,\n   which returns an abstract handle to new data, and several operations, \n   which are functions accepting the abstract handle as an argument.</p>\n  "^^rdf:HTML;
        prov:wasInfluencedBy  <http://en.wikipedia.org/wiki/Abstract_data_type> , <http://xlinux.nist.gov/dads/HTML/abstractDataType.html> .

qudt:minInclusive  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "min inclusive";
        rdfs:subPropertyOf   qudt:lowerBound;
        dcterms:description  "minInclusive is the inclusive lower bound of the value space for a datatype with the ordered property. The value of minInclusive must be in the value space of the base type." .

qudt:orderingRelation
        rdf:type             owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordering Relation";
        rdfs:range           dtype:ComparisonOperator;
        dcterms:description  "\n  This property identifies the mathematical comparison operator (such as \"<\" or \">\") that is used to order the elements of a collection.\n  " .

qudt:rotationDefinition
        rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "rotation definition" .

qudt:argType  rdf:type       owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "argType";
        rdfs:range           qudt:Datatype;
        rdfs:subPropertyOf   qudt:elementDatatype;
        dcterms:description  "This property relates a function data type with the type of one of its arguments." .

qudt:HexBinaryType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Hexidecimal Binary Type";
        rdfs:subClassOf      qudt:TextStringType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:pattern
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:length
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxLength
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:minLength
                             ];
        dcterms:description  "A string composed of hex characters." .

qudt:UnsignedIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Integer Type";
        rdfs:subClassOf      qudt:UnsignedType , qudt:IntegerDatatype;
        dcterms:description  "Unsgned Integers are integers that are either strictly non-negative or non-positive." .

qudt:MultiSet  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Bag";
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "A bag is a set in which elements may be repeated." .

qudt:xCoordinateDefinition
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "X-Coordinate definition";
        rdfs:range        xsd:string .

qudt:Coordinates-2D-DoublePrecision
        rdf:type               owl:Class;
        rdfs:isDefinedBy       <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label             "Coordinates-2D-Double precision";
        rdfs:subClassOf        qudt:Coordinates-2D;
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        dcterms:description    "\n  <p>A 2D coordinates in double floating point precision for locating a point in physical space.\n  </p>"^^rdf:HTML;
        qudt:elementTypeCount  2 .

qudt:LimitType  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Limit type";
        rdfs:subClassOf   qudt:EnumeratedValue .

qudt:Graph  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Graph Type";
        rdfs:subClassOf      qudt:DataItem;
        dcterms:description  "\n  <p>A <em>Graph</em> is an instance of a kind of abstract data type, that consists of a set of nodes (also called vertices) and a set of edges that establish relationships (connections) between the nodes. \n  A Graph Type is a data type that defines the properties of data structures that represent graphs and their members (nodes and edges).\n  </p>"^^rdf:HTML .

qudt:minBits  rdf:type    owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "minimum bits";
        rdfs:range        xsd:integer .

qudt:matlabName  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "matlab name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:Quantifiable  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:dataEncoding
                             ];
        vaem:isElaboratedIn  <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

qudt:StateSpaceMatrix
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "State Space Matrix Type";
        rdfs:subClassOf      qudt:Matrix;
        dcterms:description  "\n  <p>In control engineering, a state space representation is a mathematical model of a physical system\n   as a set of input, output and state variables related by first-order differential equations. \n  To abstract from the number of inputs, outputs and states, the variables are expressed as vectors.\n  The differential and algebraic equations are written in matrix form (the last one can be done when the dynamical system is linear and time invariant).\n  </p>"^^rdf:HTML .

qudt:TupleMember  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Tuple Member Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  <p><em>Tuple Member</em> defines the properties of a member of a tuple. \n  It is used to provide fine grained type specification to the elements of tuples.\n  </p>\n  "^^rdf:HTML .

xsd:unsignedInt  rdf:type  rdfs:Datatype .

dtype:literal  rdf:type  owl:DatatypeProperty;
        rdfs:range  xsd:string .

qudt:inverted  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "inverted";
        rdfs:range        xsd:boolean .

qudt:oracleSQLName  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "ORACLE SQL name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:DimensionalDatatype
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Dimensional Data Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        dcterms:description  "\n  <p>A <em>Dimensional Data Type</em> is a data type that specifies a physical quantity or unit of measure.\n  Information about the physical dimensions of the quantities and units is embedded in their types.\n  </p>\n  "^^rdf:HTML .

qudt:BinaryTree  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Binary Tree Type";
        rdfs:subClassOf      qudt:Tree;
        dcterms:description  "\n  <p>A <em>Binary Tree</em> is a data type that defines the properties of data structures that represent binary trees. \n  A binary tree is a tree in which each node has at most 2 children.\n  </p>"^^rdf:HTML .

qudt:ByRow  rdf:type      qudt:ArrayDataOrder;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "By row";
        dtype:literal     "byRow" .

qudt:maxExclusive  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "max exclusive";
        rdfs:range           xsd:string;
        rdfs:subPropertyOf   qudt:upperBound;
        dcterms:description  "maxExclusive is the exclusive upper bound of the value space for a datatype with the ordered property. The value of maxExclusive must be in the value space of the base type or be equal to {value} in {base type definition}." .

qudt:float_X  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "float X";
        rdfs:range        xsd:float .

qudt:Function  rdf:type   owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Function";
        rdfs:subClassOf   qudt:Concept .

qudt:SignedMediumIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Integer Type";
        rdfs:subClassOf      qudt:SignedIntegerType;
        dcterms:description  "\n  A \"Signed Medium Integers\" is an integer of 24 bits that can take on both positive and negative values.\n  " .

qudt:bitOrder  rdf:type   owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "bit order";
        rdfs:range        qudt:EndianType .

qudt:Coordinates-2D  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "2D Coordinate Type";
        rdfs:subClassOf      qudt:TwoTuple , qudt:CartesianCoordinates;
        dcterms:description  "\n  <p>A 2D coordinate system is a system for assigning a two-tuple of numbers or scalars to each point in an 2-dimensional space. \n  A corresponding 2D Coordinate Type is a data type that defines the data type for each coordinate (tuple member) in a 2D coordinate system.\n  </p>"^^rdf:HTML .

qudt:valueRange  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "value range" .

qudt:CoordinateCenterKind
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Coordinate Center Kind";
        rdfs:subClassOf      qudt:NominalScale , qudt:EnumeratedValue;
        dcterms:description  "\n  <p>An enumeration of coordinate centers for coordinate systems, such as:\n   \"Earth centered\", \"Mars centered\", \"Moon centered\", \"Sun centered\",  and \"Vehicle centered\".\n  </p>"^^rdf:HTML .

qudt:pythonName  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "python name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:vector  rdf:type     owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "vector";
        rdfs:range        qudt:Vector .

qudt:CharacterType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Character Type";
        rdfs:subClassOf      qudt:OrdinalType;
        dcterms:description  "\n  A <em>Character Type</em> is a data type that defines the type and encoding of single characters.\n  " .

qudt:DataEncoding  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Data Encoding";
        rdfs:subClassOf      qudt:Aspect;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bitOrder
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:byteOrder
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:encoding
                             ];
        dcterms:description  "\n  <p><em>Data Encoding</em> expresses the properties that specify how data is represented at the bit and byte level. \n  These properties are applicable to describing raw data.\n  </p>"^^rdf:HTML .

qudt:TupleType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Tuple Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:length
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:length
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementTypeCount
                             ];
        dcterms:description  "\n  <p><em>Tuple</em> originated as an abstraction of the sequence: single, double, triple, quadruple, quintuple, n-tuple.  \n  In mathematics, a tuple is a finite sequence (also known as an <em>Ordered List</em> of objects, each of a specified type. \n  The <em>n</em> can be any non-negative integer.\n  </p>\n  "^^rdf:HTML .

xsd:unsignedByte  rdf:type  rdfs:Datatype .

qudt:IntegerListShape
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf   qudt:List .

qudt:PhysicalAddress  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Physical Address Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "A physical address is a pointer to a memory location." .

qudt:elementDatatype  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element datatype";
        rdfs:range           qudt:CharacterType , qudt:TupleMember , qudt:ScalarDatatype , qudt:UnsignedIntegerType , qudt:NumericType , qudt:Datatype , qudt:RealSinglePrecisionType , qudt:CoordinateMember;
        dcterms:description  "\n  This property is used to relate a structured data type with the data type the structured type's elements. \n  It is used for structured data types with elements that are all of the same type.\n  " .

qudt:Yes  rdf:type        qudt:YesNoType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Yes";
        dtype:literal     "Y" .

qudt:CoordinateMember
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Coordinate Member";
        rdfs:subClassOf      qudt:TupleMember;
        dcterms:description  "\n  <p>A <em>Coordinate Member</em> is a data type that defines the properties of a coordinate in a coordinate system.\n  </p>"^^rdf:HTML .

qudt:OrderedType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordered type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "Describes how a data or information structure is ordered." .

qudt:CompositionTree  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Composition Tree";
        rdfs:subClassOf   qudt:Tree;
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  1;
                            owl:onProperty      qudt:function
                          ];
        rdfs:subClassOf   [ rdf:type         owl:Restriction;
                            owl:cardinality  1;
                            owl:onProperty   qudt:function
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  1;
                            owl:onProperty      qudt:function
                          ] .

qudt:AerospaceCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Aerospace Coordinate system";
        rdfs:subClassOf      qudt:CoordinateSystem;
        dcterms:description  "A sub-type of 'Coordinate system'." .

qudt:CompositeDatatype
        rdf:type              owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Composite Data Type";
        rdfs:subClassOf       qudt:StructuredDatatype;
        rdfs:subClassOf       [ rdf:type            owl:Restriction;
                                owl:maxCardinality  1;
                                owl:onProperty      qudt:padding
                              ];
        dcterms:description   "\n  <p>A <em>Composite Datatype</em> is a datatype that is constructed from basic primitive types and other composite types. \n  </p>"^^rdf:HTML;
        prov:wasInfluencedBy  <https://en.wikipedia.org/wiki/List_of_data_structures> .

qudt:BigEndian  rdf:type  qudt:EndianType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Big Endian";
        dtype:literal     "big" .

qudt:field  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "field";
        rdfs:range        qudt:DataSetElement .

qudt:TimeSeriesArrayType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time Series Array Type";
        rdfs:subClassOf      qudt:ArrayType;
        dcterms:description  "\n  <p>A <em>Time Series Array Type</em> is a data type that specifies the properties of arrays that hold time series data. \n  A time series is a sequence of data points, measured at successive time intervals. \n  The time intervals may be uniformly or non-uniformly spaced.\n  </p>\n  "^^rdf:HTML .

qudt:ReferenceFrame  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Reference Frame";
        rdfs:subClassOf      qudt:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:xAxisDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:realization
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:zAxisDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:zCoordinateDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:yAxisDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:xCoordinateDefinition
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:yCoordinateDefinition
                             ];
        dcterms:description  "\n  <p> A <em>Reference Frame</em> (or \"frame of reference\") in physics, may refer to a coordinate system or set of axes.\nThe frame serves as the datum to measure the position, orientation, and other properties of objects in it.\nReference frame may refer to an observational reference frame tied to the state of motion of an observer. \nReference frame may also refer to both an observational reference frame and an attached coordinate system as a unit.\n</p>\n"^^rdf:HTML .

qudt:FunctionDatatype
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Function Data Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:returnType
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:functionArity
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:functionArity
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:functionArity
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:returnType
                             ];
        dcterms:description  "\n  <p>A function data type defines the input and output data type for a function or method. \n  The data type includes at least the function name and the number of its parameters. \n  In some programming languages, it may also specify the function's return type or the types of its arguments.\n  </p>"^^rdf:HTML .

qudt:precision  rdf:type     owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "precision";
        rdfs:range           xsd:integer;
        dcterms:description  "\n  <p>Precision is the number of digits used to perform a given computation. \n  The concepts of accuracy and precision are both closely related and often confused. \n  While the accuracy of a number x is given by the number of significant decimal (or other) digits to the right of the decimal point in x,\n   the precision of x is the total number of significant decimal (or other) digits.\n  </p>\n  <p>For a given numeric data type, the value of type:precision (?p) is related to the values of type:maxMantissa (?M) and type:base (?b) by the formula:\n  </p>\n  <p>?p := log(?b, ?M)\n  </p>\n  <p>where log(a,y) = x iff y=a^x.\n  </p>\n  "^^rdf:HTML .

qudt:Set  rdf:type           owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Set Type";
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "\n  <p>A <em>Set</em> is an abstract data type that defines the properties of sets. \n  A set is a collection (container) of certain values, without any particular order, and no repeated values. \n  It corresponds with a finite set in mathematics.\n  </p>\n  "^^rdf:HTML .

qudt:Encoding  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Encoding";
        rdfs:subClassOf      skos:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bytes
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bits
                             ];
        dcterms:description  "\n  <p>An encoding is a rule or algorithm that is used to convert data from a native, or unspecified form into a specific form that satisfies the encoding rules. \n  Examples of encodings include character encodings, such as UTF-8.\n  </p>"^^rdf:HTML .

qudt:OrdinalType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordinal Data Type";
        rdfs:subClassOf      qudt:ScalarDatatype;
        dcterms:description  "\n  <p>An ordinal data type is a data type that specifies the properties of values that can easily be put in a one to one correspondence with a subset of the natural numbers. \n  Examples include boolean, character, and integer data types.\n  </p>"^^rdf:HTML .

qudt:AlgebraicDatatype
        rdf:type              owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Algebraic Datatype";
        rdfs:seeAlso          qudt:AbstractDatatype;
        rdfs:subClassOf       qudt:StructuredDatatype;
        dcterms:description   "<p>An <em>Algebraic Datatype</em> is a datatype each of whose values are data from other data types wrapped in one of the constructors of the data type. \nAny wrapped datum is an argument to the constructor. \nIn contrast to other data types, the constructor is not executed and the only way to operate on the data is to unwrap the constructor using pattern matching.\n</p>\n<p>The most common algebraic data type is a list with two constructors: Nil or [] for an empty list, and Cons (an abbreviation of constructor), \n ::, or : for the combination of a new element with a shorter list (for example (Cons 1 '(2 3 4)) or 1:[2,3,4]).\n</p>\n<p>Special cases of algebraic types are product types i.e. records (only one constructor) and enumerated types (many constructors with no arguments). \nAlgebraic types are one kind of composite type (i.e. a type formed by combining other types).\n</p>\n<p>An algebraic data type may also be an abstract data type (ADT) if it is exported from a module without its constructors. \nValues of such a type can only be manipulated using functions defined in the same module as the type itself.\n</p>"^^rdf:HTML;
        prov:wasInfluencedBy  <http://en.wikipedia.org/wiki/Algebraic_data_type> .

qudt:SplineCalibrator
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Spline calibrator";
        rdfs:subClassOf      qudt:Map;
        dcterms:description  "A sub-type of 'Map Type'." .

qudt:BigIntegerType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Big Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  <p>A <em>Big Integer</em> is an integer that can be represented in eight octets (64 bits) of machine memory. \n  Big integers may be signed or unsigned.\n  </p>\n  "^^rdf:HTML .

dcterms:description  rdf:type  owl:AnnotationProperty;
        rdfs:label  "description" .

qudt:ParameterModifiabilityType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Parameter modifiability type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "An enumeration of literals that signify whether a parameter is modifiable and if so, by whom." .

qudt:memberDatatype  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "member datatype";
        rdfs:range           qudt:CharacterType;
        dcterms:description  "\n  This property is used to define the data type of a collection's elements. \n  It is used for collections with elements that are all of the same type.\n  " .

qudt:signedness  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "signedness";
        rdfs:range        qudt:SignednessType .

xsd:QName  rdf:type  rdfs:Datatype .

qudt:IntegerEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Integer Encoding";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "The encoding scheme for integer types" .

qudt:OrderedTree  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordered Tree Type";
        rdfs:subClassOf      qudt:Tree , qudt:OrderedCollection;
        dcterms:description  "\n  <p>An \"Ordered Tree Type\" is a data type that defines the properties of data structures that represent ordered trees. \n  An ordered tree is a tree where the children of every node are ordered, that is, there is a first child, second child, third child, etc. \n  Typically a type specification for an ordered tree will include the comparison operator (such as <b>lt</b> or <b>gt</b>) that is used to order the nodes.\n  </p>"^^rdf:HTML .

qudt:Signed  rdf:type     qudt:SignednessType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Signed";
        dtype:literal     "signed" .

qudt:LargeObject  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Large object";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  A 'LargeObject' datatype is used to store blocks of unstructured data (such as text, graphic images, video clips, and sound waveforms). \n  They often are used to allow efficient, random, piece-wise access to the data.\n  " .

qudt:VariableIntervalTimeSeriesArrayType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Variable Interval Time Series Array Type";
        rdfs:subClassOf      qudt:TimeSeriesArrayType;
        dcterms:description  "A Variable Interval Time Series Array Type is a data type that specifies the properties of arrays that hold time series data that has been sampled over non-uniformly spaced time intervals. A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals. For variable interval time series, the successive time intervals may follow a repeating pattern, or may be completely random." .

qudt:totalDigits  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "total digits" .

qudt:Coordinates-3D-DoublePrecision
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "3D Coordinates (Double Precision)";
        rdfs:subClassOf      qudt:Coordinates-3D;
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:double_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:double_Z
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:double_Y
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:double_Y
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:double_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:double_X
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:double_Y
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:double_X
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:double_X
                             ];
        dcterms:description  "\n  <p>A 3D coordinates in double floating point precision for locating a point in physical space.\n  </p>"^^rdf:HTML .

qudt:TaggedEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Tagged Enumeration";
        rdfs:subClassOf      qudt:Enumeration;
        dcterms:description  "An enumeration where each literal  has a tag that is a non-negative integer. These enumerations are likely to have their literals encoded - hence the need for the tag." .

qudt:MemoryOrderType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Memory order type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "A sub-type of 'Enumerated Value'." .

qudt:mantissa  rdf:type      owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "mantissa";
        dcterms:description  "In scientific notation, the mantissa of a real number is the integer coefficient preceding the base raised to the exponent." .

qudt:zCoordinateDefinition
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Z-Coordinate definition";
        rdfs:range        xsd:string .

qudt:Map  rdf:type           owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Map Type";
        rdfs:seeAlso         qudt:AssociativeArray;
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "A Map Type is an abstract data type that defines the properties of map data structures. A Map (or Associative Array) is an abstract data structure composed of a collection of keys and a collection of values, where each key is associated with one value. The operation of finding the value associated with a key is called a lookup or indexing, and this is the most important operation supported by an associative array. The relationship between a key and its value is sometimes called a mapping or binding." .

qudt:Sequence  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Sequence";
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "\n  <p>A <em>Sequence</em> is an enumerated collection of objects in which repetitions are allowed. \n  Like a set, it contains members (also called elements, or terms). \n  The number of elements (possibly infinite) is called the length of the sequence.\n  </p>\n  <p>Unlike a set, order matters, and exactly the same elements can appear multiple times at different positions in the sequence. \n  Formally, a sequence can be defined as a function whose domain is either the set of the natural numbers (for infinite sequences) or the set of the first n natural numbers (for a sequence of finite length n). \n  </p>\n  <p>The position of an element in a sequence is its rank or index; it is the integer from which the element is the image. \n  It depends on the context or of a specific convention, if the first element has index 0 or 1. [Wikipedia]\n  </p>\n  "^^rdf:HTML .

qudt:ByteEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Byte Encoding";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "This class contains the various ways that information may be encoded into bytes." .

qudt:upperBound  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "upper bound" .

qudt:IconicCue  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Iconic enumeration literal";
        rdfs:subClassOf   qudt:ModalCue;
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  1;
                            owl:onProperty      qudt:image
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  1;
                            owl:onProperty      qudt:image
                          ];
        rdfs:subClassOf   [ rdf:type         owl:Restriction;
                            owl:cardinality  1;
                            owl:onProperty   qudt:image
                          ] .

qudt:OneMeansOff  rdf:type  qudt:OnOffStateType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "One means off";
        qudt:inverted     true;
        dtype:literal     "off" .

qudt:yAxisDefinition  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Y-Axis definition";
        rdfs:range           xsd:string;
        dcterms:description  "\n  The definition of the Y-Axis could be an intersection, cross-product or other function of a meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

qudt:RealNumberType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Real number type";
        rdfs:subClassOf      qudt:RealDatatype;
        dcterms:description  "\n  <p>A <em>Real Number Type</em> is the class of data values that approximate real numbers in finite precision. \n  Often, such values are expressed in \"mantissa, base, exponent\" form. \n  Any rational number can be expressed in the form m*b^<sup>e</sup>, where m (the mantissa), b (the base), and e (the exponent) are integers. \n  Typically, b is chosen to be either 2 or 10, and then the values of m and e are determined given the choice of base.\n  </p>\n  "^^rdf:HTML .

qudt:TypeVector  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Type vector";
        rdfs:subClassOf      qudt:Vector;
        dcterms:description  "\n  <p>A <em>Type Vector</em> is a vector whose elements are data types. \n  They are used to specify the type of each component of a vector or class of vectors. \n  </p>"^^rdf:HTML .

qudt:elementName  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "element name";
        rdfs:range        xsd:string .

xsd:string  rdf:type  rdfs:Datatype .

qudt:dimensions  rdf:type    owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "dimensions";
        rdfs:range           qudt:List;
        dcterms:description  "\n  The extent of each dimension making up an array or matrix.\n  Dimensions are expressed as an integer list.\n  For example a 4 by 4 array has dimensions (4 4), whereas a vector or a string has dimensions (1).\n  " .

qudt:enumeration  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "enumeration" .

qudt:zAxisDefinition  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Z-Axis definition";
        rdfs:range           xsd:string;
        dcterms:description  "\n  The definition of the Y-Axis could be an intersection, croos-product or other function of a meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

qudt:ShortUnsignedIntegerEncoding
        rdf:type          qudt:BooleanEncodingType , qudt:IntegerEncodingType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Short Unsigned Integer Encoding";
        qudt:bytes        2 .

qudt:DateTimeStringType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Temporal Type";
        rdfs:subClassOf      qudt:StringType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:encoding
                             ];
        dcterms:description  "\n  <p>A class of data types for structures that represent temporal quantities.\n  For example, calendar dates, times, duration of time since a given epoch, etc.\n  </p>"^^rdf:HTML .

xsd:base64Binary  rdf:type  rdfs:Datatype .

qudt:SplinePoint  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Spline point";
        rdfs:subClassOf      qudt:Tuple;
        dcterms:description  "A sub-type of 'Tuple Type'." .

xsd:date  rdf:type  rdfs:Datatype .

qudt:Coordinates-2D-SinglePrecision
        rdf:type               owl:Class;
        rdfs:isDefinedBy       <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label             "Cartesian Coordinates 2D Single Precision";
        rdfs:subClassOf        qudt:Coordinates-2D;
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_Y
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:maxCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type            owl:Restriction;
                                 owl:minCardinality  1;
                                 owl:onProperty      qudt:double_X
                               ];
        rdfs:subClassOf        [ rdf:type         owl:Restriction;
                                 owl:cardinality  1;
                                 owl:onProperty   qudt:double_X
                               ];
        dcterms:description    "\n  <p>A 2D coordinates in single floating point precision for locating a point in physical space.\n  </p>"^^rdf:HTML;
        qudt:elementTypeCount  2 .

qudt:MathsFunctionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Maths Function Type";
        rdfs:subClassOf      qudt:Concept;
        dcterms:description  "A sub-type of 'QUDT Concept'." .

qudt:modifiability  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "modifiability";
        dcterms:description  "Reference to one in a list of enumerated elements that indicates whether data (e.g. variable or parameter) can be changed." .

xsd:long  rdf:type  rdfs:Datatype .

qudt:OnOffStateTypeEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      qudt:Enumeration;
        dcterms:description  "\n  A discrete state enumeration whose values are 'off' and 'on'. \n  The 'on' value is encoded as a zero (0) and the 'off' value as a one (1).\n  ";
        qudt:inverted        true .

qudt:bytes  rdf:type      owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "bytes";
        rdfs:range        xsd:integer .

qudt:UnsignedLongIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Long Integer Type";
        rdfs:subClassOf      qudt:UnsignedIntegerType , qudt:LongIntegerType;
        dcterms:description  "An Unsigned Long Integer is an unsigned integer that can be represented in four octets (32 bits) of machine memory." .

qudt:double_Y  rdf:type   owl:DatatypeProperty , owl:FunctionalProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:range        xsd:double .

qudt:TypeMatrix  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Type matrix";
        rdfs:subClassOf      qudt:Matrix;
        dcterms:description  "\n  Members of this class are matrix data structures that describe the datatypes of a class of matrices. \n  That is, the members of this class are matrices with cells that contain datatypes (c.f. type:Datatype) and are used to describe the datatype structure of other matrices.\n  " .

dcterms:creator  rdf:type  owl:AnnotationProperty;
        rdfs:label  "creator" .

qudt:odbcName  rdf:type     owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "ODBC name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:type  rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "type";
        rdfs:range           qudt:TimeStringType;
        dcterms:description  "A reference to the specification of the data type of a variable or constant." .

qudt:javaName  rdf:type     owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "java name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:Collection  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Collection Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        dcterms:description  "\n  <p>A collection is a grouping of some variable number of zero or more data items that need to be operated upon together in some controlled fashion. \n  Generally, the data items will all share the same data type or are derived from some common ancestor data type.\n  </p>"^^rdf:HTML .

qudt:CompositionFunction
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Composition function";
        rdfs:subClassOf   qudt:Function .

qudt:CompositeTable  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Composite Table Type";
        rdfs:subClassOf      qudt:Table;
        dcterms:description  "A sub-type of 'Table Type'." .

xsd:hexBinary  rdf:type  rdfs:Datatype .

qudt:UnsignedIntegerEncoding
        rdf:type          qudt:IntegerEncodingType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Unsigned Integer Encoding";
        qudt:bytes        4 .

qudt:Array  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Array";
        rdfs:subClassOf      qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:dimensionality
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:isHeterogeneous
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        dcterms:description  "\n  <p>An <em>Array></em> is a data structure that stores a collection of elements, typically of the same type, in a contiguous block of memory. \n  Each element in an array is identified by an index or key, which is typically a numerical identifier, either starting at '0' or '1'.\n  </p>\n  <p>The key considerations for an Array are:\n  </p>\n  <ol>\n  <li>Fixed Size: The size of an array may be pre-determined when it is created and cannot be changed;</li>\n  <li>Index-Based Access: Elements can be accessed, updated, or modified using their index;</li>\n  <li>Contiguous Memory Allocation: The elements are stored in consecutive memory locations, which allows efficient access using the index.</li>\n  </ol>\n  <p>An Array is represented as ordered entries of values arranged according to its dimensionality.\n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>An array can be multi-dimensional.\n  Multiple indices are used but they are treated as extensions of the same structure.\n  For Example: for a 2D array arr[2][3], indices refer to the row and column positions.\n  A 2D array is still represented as a list, where each member of the list is a list.\n  </p>\n  <p>Higher dimensional arrays can be represented as nested lists.\n  For each dimension a new nested list is defined.\n  </p>"^^rdf:HTML .

qudt:OffOnStateTypeEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      qudt:Enumeration;
        dcterms:description  "\n  A discrete state enumeration whose values are 'off' and 'on'. \n  The 'off' value is encoded as a zero (0) and the 'on' value as a one (1).\n  " .

qudt:FloatingPointEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Floating Point Encoding";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "\n  <p>A type for specifying an \"Encoding\" with the following instance(s): \n  \"Double Precision Encoding\", and \"Single Precision Real Encoding\".\n  </p>"^^rdf:HTML , "\n  A \"Encoding\" with the following instance(s): \"Double Precision Encoding\", \"Single Precision Real Encoding\".\n  " .

xsd:boolean  rdf:type  rdfs:Datatype .

qudt:maxMantissa  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "max mantissa";
        dcterms:description  "\n  <p>The maximium mantissa is the largest integer that may appear as a coefficient in a finite precision representation of a real number.\n  For a given numeric data type, the value of <em>maxMantissa}</em> (<em>M</em>) and the values of <em>base</em> (<em>b</em>) and  <em>precision</em> (<em>p</em>) are related by the formula:\n  </p>\n  <p><em>M = b<sup></sup> - 1</em> .</p>\n  "^^rdf:HTML .

qudt:coordinateCenter
        rdf:type          owl:ObjectProperty;
        rdfs:domain       qudt:CoordinateSystem;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "coordinate center";
        rdfs:range        qudt:CoordinateCenterKind;
        skos:prefLabel    "coordinate center" .

qudt:Coordinates-3D-Type
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "3D Coordinate Type";
        rdfs:subClassOf      qudt:ThreeTuple , qudt:CartesianCoordinatesType;
        dcterms:description  "\n  <p>A 3D coordinate system is a system for assigning a three-tuple of numbers or scalars to each point in an 3-dimensional space. \n  A corresponding 3D Coordinate Type is a data type that defines the data type for each coordinate (tuple member) in a 3D coordinate system.\n  </p>"^^rdf:HTML .

qudt:StringUTF16  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "String UTF16";
        rdfs:subClassOf      qudt:TextStringType , qudt:StringType;
        dcterms:description  "\n  <p><em>String UTF-16</em> is a string data type that specifies the properties of string data structures which encode strings using the UTF-16 encoding. \n  UTF-16 is the native internal representation of text in many software systems, for example:\n  </p>\n  <ol>\n  <li>Microsoft Windows NT/Windows 2000/Windows XP/Windows CE;</li>\n  <li>Qualcomm BREW, and Symbian operating systems;</li>\n  <li>the Java and .NET byte code environments;</li>\n  <li>Mac OS X's Cocoa and Core Foundation frameworks;</li>\n  <li>Qt cross-platform graphical widget toolkit.</li>\n  </ol>\n  "^^rdf:HTML .

qudt:valueType  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "value type" .

dcterms:subject  rdf:type  owl:AnnotationProperty;
        rdfs:label  "subject" .

qudt:UserModifiableParameter
        rdf:type             qudt:ParameterModifiabilityType;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "User modifiable parameter";
        dcterms:description  "Parameter is modifiable by a user.";
        dtype:code           "2";
        dtype:literal        "user" .

qudt:AlignmentType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Alignment type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "\n  Specifies how a physical data field is aligned. \n  The alignment could be at a bit, byte or word boundary.\n  " .

qudt:PartiallyOrdered
        rdf:type                   qudt:OrderedType;
        rdfs:isDefinedBy           <file:///Users/ralphtq/git-qudt/qudt-public-repo/qudt> , <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label                 "Partially Ordered";
        qudt:plainTextDescription  "Partial ordered structure.";
        dtype:literal              "partial" .

qudt:StringUTF8  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "String UTF8 Type";
        rdfs:subClassOf      qudt:TextStringType , qudt:StringType;
        dcterms:description  "\n  String UTF-8 Type is a string data type that specifies the properties of string data structures which encode strings using the UTF-8 encoding. \n  UTF-8 includes ASCII, otherwise referred to as IA-5 (International Alphabet 5, as standardized by International Organization for Standardization [ISO]) as the first 128 values. \n  The Internet Engineering Task Force (IETF) requires all Internet protocols to identify the encoding used for character data with UTF-8 as at least one supported encoding. \n  The Internet Mail Consortium (IMC) recommends that all e-mail programs must be able to display and create mail using UTF-8.\n  ";
        vaem:isElaboratedIn  <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

qudt:MultiModalEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Multi modal enumeration";
        rdfs:subClassOf      qudt:Enumeration;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:visualCueEnumeration
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:iconicCueEnumeration
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:auralCueEnumeration
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:kinestheticCueEnumeration
                             ];
        dcterms:description  "A sub-type of 'QUDT Enumeration'." .

qudt:length  rdf:type        owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "length";
        rdfs:range           xsd:integer;
        dcterms:description  "The length of a structure, for example the size of a vector" .

qudt:yawRotationDefinition
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "Yaw rotation definition";
        rdfs:range          qudt:AxialOrientationType;
        rdfs:subPropertyOf  qudt:rotationDefinition .

qudt:TimeDataType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time data type";
        rdfs:subClassOf      qudt:ScalarDatatype , qudt:Enumeration;
        dcterms:description  "A sub-type of 'QUDT Enumeration'.";
        dtype:value          qudt:TIME .

qudt:jsName  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "Javascript name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:byteOrder  rdf:type     owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "byte order";
        rdfs:range           qudt:EndianType;
        dcterms:description  "Byte order is an enumeration of two values: 'Big Endian' and 'Little Endian' and is used to denote whether the most signiticant byte is either first or last, respectively." .

qudt:CartesianCoordinates
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Cartesian Coordinate Type";
        rdfs:subClassOf      qudt:Coordinates;
        dcterms:description  "\n  A set of  variables which fix a geometric object.\n  If the coordinates are distances measured along perpendicular axes, they are known as Cartesian coordinates.\n  " .

qudt:stringValue  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "string value";
        rdfs:subPropertyOf  qudt:scalarValue .

xsd:float  rdf:type  rdfs:Datatype .

qudt:TypeList  rdf:type      owl:Class;
