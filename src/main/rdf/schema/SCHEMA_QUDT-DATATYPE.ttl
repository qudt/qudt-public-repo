        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/shacl/datatype> , <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Minor";
        <http://www.linkedmodel.org/schema/dtype#code>
                1;
        <http://www.linkedmodel.org/schema/dtype#literal>
                "minor";
        <http://www.linkedmodel.org/schema/dtype#order>
                "1"^^<http://www.w3.org/2001/XMLSchema#int> .

<http://qudt.org/schema/qudt/iconicCue>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "iconic cue";
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/modalCue> .

<http://purl.org/dc/terms/title>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "title" .

<http://qudt.org/schema/qudt/Array2DvalueList>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#first>
                <http://qudt.org/schema/qudt/List>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>
                ( <http://qudt.org/schema/qudt/List> );
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "2D Array Value List";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/List>;
        <http://purl.org/dc/terms/description>
                "\n  An rdf:List for a 2D array.\n  For example \"[[1,2], [3,4], [5,6]]\"\n  " .

<http://purl.org/dc/terms/rights>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "rights" .

<http://qudt.org/schema/qudt/protocolBuffersName>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "protocol buffers name";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/id> .

<http://qudt.org/schema/qudt/Time>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Time";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ScalarDatatype>;
        <http://purl.org/dc/terms/description>
                "The class of data values that denote a point in time. Time values may be encoded in a 12-hour clock or a 24-hour clock, such as 1:35 AM, or 13:35." .

<http://qudt.org/schema/qudt/xAxisDefinition>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "X-Axis Definition";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://purl.org/dc/terms/description>
                "\n  The definition of the X-Axis could be an intersection, cross-product or other function of a  meridian or orbit. \n  It could also mention any aspects of rotation, for example, the rotation equator of the Earth, Sun, Moon or other celestial body. \n  An epoch might also be given.\n  " .

<http://qudt.org/schema/qudt/returnType>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "return type";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Datatype>;
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/elementDatatype>;
        <http://purl.org/dc/terms/description>
                "This property is used to state the return type of a function type." .

<http://qudt.org/schema/qudt/UnsignedShortIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Unsigned Short Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ShortIntegerType> , <http://qudt.org/schema/qudt/UnsignedIntegerType>;
        <http://purl.org/dc/terms/description>
                "An Unsigned Short Integer is an unsigned integer that can be represented in four octets (32 bits) of machine memory." .

<http://qudt.org/schema/qudt/VisualCue>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Visual Cue";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ModalCue> .

<http://qudt.org/schema/qudt/SignedIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/SignedType> , <http://qudt.org/schema/qudt/IntegerDatatype>;
        <http://purl.org/dc/terms/description>
                "Signed Integers are integers can take on both positive and negative values." .

<http://qudt.org/schema/qudt/NonRotatingInertialFrame>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Non Rotating Coordinate Frame";
        <http://www.w3.org/2000/01/rdf-schema#seeAlso>
                <http://qudt.org/schema/qudt/InertialCoordinateFrame>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/InertialReferenceFrame>;
        <http://purl.org/dc/terms/description>
                "\n  <p>The non-rotating (or \"inertial\") coordinate frames are defined by taking a \"snapshot\" of the orientation of a particular set of right-handed, orthogonal axes at a specific epoch or time. \n  In other words, the non-rotating coordinate frame, however it is defined, is frozen or fixed at a specific time - for all time. \n  These non-rotating coordinate frames are referred to as \"of Epoch\" coordinate frames.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/DoublePrecisionType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Double Precision Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/NumericType>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A double precision data type specifies how a numeric value, such as an integer or real number, is stored in memory.\n  Typically this occupies two words in computer memory, where the byte length of a word depends on machine address size of the computer processor. \n  For example, on 32-bit machine architectures, a word is four bytes, and so double precision data value on a 32-bit machine architecture occupies eight bytes of memory.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/arg1Type>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "arg1Type";
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/argType>;
        <http://purl.org/dc/terms/description>
                "This property relates a funciton data type with the type of its arg1." .

<http://qudt.org/schema/qudt/AllValuesMustHaveSameDataTypeShape>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "All Values must have same DataType Shape" .

<http://qudt.org/schema/qudt/ColorCue>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Color Cue";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/VisualCue>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/rgbCode>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/rgbCode>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/rgbCode>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A visual cue that uses color to distinguish it from other cues. \n  Each color cue has exactly one corresponding coordinate point in the RGB space.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/YesNoType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Yes no type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue> .

<http://qudt.org/schema/qudt/Tuple>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Tuple";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CompositeDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementTypeCount>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/length>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/length>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>The term <em>Tuple</em> originated as an abstraction of the sequence: single, double, triple, quadruple, quintuple, n-tuple. \n  In mathematics, a tuple is a finite sequence (also known as an <em>Ordered List</em> of objects, each of a specified type. \n  The <em>n</em> can be any non-negative integer.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.w3.org/2001/XMLSchema#nonNegativeInteger>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

