qudt:TimeStringType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time Type";
        rdfs:subClassOf      qudt:TextStringType , qudt:DateTimeStringType;
        dcterms:description  "Time takes a number of forms, depending on the units used (e.g., year, day, minute, millisecond, or combinations thereof) and the origin (i.e., time zero) to which the time value is related." .

qudt:yCoordinateDefinition
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Y-Coordinate definition";
        rdfs:range        xsd:string .

qudt:Coordinates-3D-SinglePrecision
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "3D Coordinates (Single Precision)";
        rdfs:subClassOf      qudt:Coordinates-3D;
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:float_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:float_Y
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:float_Y
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:float_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:float_Y
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:float_X
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:float_Z
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:float_X
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:float_X
                             ];
        dcterms:description  "\n  <p>A 3D coordinates in single floating point precision for locating a point in physical space.\n  </p>\n  "^^rdf:HTML .

qudt:modalCueEnumeration
        rdf:type            owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "modal cue enumeration";
        rdfs:range          qudt:ModalEnumeration;
        rdfs:subPropertyOf  qudt:enumeration .

qudt:RawValueTupleMember
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Raw value tuple member";
        rdfs:subClassOf      qudt:TupleMember;
        dcterms:description  "A sub-type of 'Tuple Member Type'." .

xsd:dateTime  rdf:type       rdfs:Datatype;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        dcterms:description  "\n  <p>YYYY-MM-DDThh:mm:ss[.dd] or YYYY-DDDThh:mm:ss[.dd], where 'YYYY' is the year, 'MM' is the two-digit month, 'DD' is the two-digit day, 'DDD' is the three digit day of year, 'T' is constant, 'hh:mm:ss[.dd]' is the UTC time in hours, minutes, seconds, and optional fractional seconds. \n  As many 'd' characters to the right of the period as required may be used to obtain the required precision. \n  All fields require leading zeros.\n  </p>"^^rdf:HTML .

qudt:kinestheticCueEnumeration
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "kinesthetic cue enumeration";
        rdfs:subPropertyOf  qudt:modalCueEnumeration .

qudt:DateStringType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Date String Type";
        rdfs:subClassOf      qudt:DateTimeStringType;
        dcterms:description  "Date String Types are scalar data types that define the properties of strings that represent calendar dates." .

qudt:fieldLabels  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "field labels";
        dcterms:description  "This property is used to list the field labels for a record type." .

qudt:sound  rdf:type         owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "sound";
        rdfs:range           xsd:anyURI;
        dcterms:description  "The intended use of the sound property is to be associated with modal enumerations" .

xsd:short  rdf:type  rdfs:Datatype .

qudt:elementTypeCount
        rdf:type             owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element type count";
        rdfs:range           xsd:integer;
        dcterms:description  "This property determines the allowed number of element types that a structured data type may have." .

qudt:VariableLengthIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Variable Length Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  A \"Variable Length Integer\" data type defines a data structure for representing integers that uses a variable number of bits depending on the magnitude of the integer. \n  Typically, variable length integer data types are between one and 64 bits in length.\n  " .

qudt:LongIntegerType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Long Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  A \"Long Integer\" is an integer that can be represented in four octets (32 bits) of machine memory. \n  Long integers may be signed or unsigned.\n  " .

qudt:BitField  rdf:type      rdfs:Datatype;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      xsd:string;
        dcterms:description  "\n  <p>A bit field is a common idiom used in computer programming to store a set of Boolean datatype flags compactly, as a series of bits. \n  The bit field is stored in an integral type of known, fixed bit-width. \n  Each Boolean flag is stored in a separate bit. \n  Usually the source code will define a set of constants, each a power of two, that semantically associate each individual bit with its respective Boolean flag. \n  The bitwise operators and, or, and not are used in combination to set, reset and test the flags.\n  </p>\n  "^^rdf:HTML .

qudt:maxInclusive  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "max inclusive";
        rdfs:subPropertyOf   qudt:upperBound;
        dcterms:description  "maxInclusive is the inclusive upper bound of the value space for a datatype with the ordered property. The value of maxInclusive must be in the value space of the base type." .

qudt:realization  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "realization";
        rdfs:range        xsd:string .

qudt:typeMatrix  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "type matrix" .

qudt:OctetType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Octet Type";
        rdfs:subClassOf      qudt:UnsignedIntegerType;
        dcterms:description  "An 8 bit unsigned integer" .

qudt:RealDatatype  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Real Datatype";
        rdfs:subClassOf      qudt:NumericType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:precision
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:base
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxExponent
                             ];
        dcterms:description  "\n  <p>A real number is represented as a factor, called the mantissa, multiplied by a power (the exponent) of a base. \n  Different bases yield different approximations to real numbers, and conversion between them is limited in accuracy.\n  Four floating-point types are defined in 'IEEE-754 Standard for Binary Floating-Point'. \n  These types are 'single', 'extended single', 'double', and 'extended double'.\n  </p>\n  "^^rdf:HTML .

qudt:OnOffStateType  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "On off state type";
        rdfs:subClassOf   qudt:DiscreteState .

qudt:InterpolatedTable
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Interpolated Table Type";
        rdfs:subClassOf      qudt:TableType , qudt:Table;
        dcterms:description  "A sub-type of 'Table Type'." .

qudt:minValue  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "minimum value" .

qudt:TotallyOrdered  rdf:type      qudt:OrderedType;
        rdfs:isDefinedBy           <file:///Users/ralphtq/git-qudt/qudt-public-repo/qudt> , <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label                 "Totally Ordered";
        qudt:plainTextDescription  "Totally ordered structure.";
        dtype:literal              "total" .

qudt:Heap  rdf:type           owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Heap";
        rdfs:subClassOf       qudt:OrderedTree;
        dcterms:description   "\n  <p>A heap is a specialized tree-based data structure that satisfies the condition: if B is a child node of A, then $key(A) \\ge key(B)$. \n  This implies that an element with the greatest key is always in the root node, and so such a heap is sometimes called a max heap. \n  Alternatively, if the comparison is reversed, the smallest element is always in the root node, which results in a min heap. \n  The function or method that implements the key() operator is specified by the heap type.\n  </p>"^^rdf:HTML;
        prov:wasInfluencedBy  <http://en.wikipedia.org/wiki/Heap_(data_structure)> .

qudt:LittleEndian  rdf:type  qudt:EndianType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Little Endian";
        dtype:literal     "little" .

qudt:NonModifiableParameter
        rdf:type             qudt:ParameterModifiabilityType;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Non modifiable parameter";
        dcterms:description  "Parameter is fixed, not modifiable.";
        dtype:code           "0";
        dtype:literal        "fixed" .

qudt:PositiveIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Positive Integer Type";
        rdfs:subClassOf      qudt:UnsignedType , qudt:IntegerDatatype;
        dcterms:description  "Positive Integers are integers that are either non-zero and non-negative." .

qudt:ArrayDataOrder  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Array data order";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "A sub-type of 'Enumerated Value'. Detailed description to be provided in a future version." .

qudt:function  rdf:type   owl:ObjectProperty , owl:FunctionalProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:range        qudt:CompositionFunction .

qudt:auralCue  rdf:type     owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "aural cue";
        rdfs:subPropertyOf  qudt:modalCue .

qudt:functionArity  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "function arity";
        rdfs:range           xsd:integer;
        dcterms:description  "This property is used to state the number of arguments for a function type." .

qudt:Triplet  rdf:type       owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Triplet";
        rdfs:seeAlso         qudt:ThreeTuple;
        rdfs:subClassOf      qudt:ThreeTuple;
        dcterms:description  "A \"Tuple\"." .

qudt:UNARY-FUNCTION  rdf:type  qudt:FunctionDatatype;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "UNARY-FUNCTION";
        dcterms:description  "This type identifies functions that have exactly one argument."^^rdf:HTML;
        qudt:functionArity   1 .

qudt:originDefinition
        rdf:type          owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "origin definition";
        rdfs:range        xsd:string .

qudt:WordAligned  rdf:type  qudt:AlignmentType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Word Aligned";
        dtype:literal     "word" .

qudt:rgbCode  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "rgb code";
        rdfs:range        xsd:string .

qudt:FrameType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Frame Type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "\n  <p>A <em>Frame Type</em> specifies the intertial type of a coordinate frame as either inertial, rotating, or non-rotating.\n  </p>\n  "^^rdf:HTML .

qudt:id  rdf:type         owl:DatatypeProperty , owl:FunctionalProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:range        xsd:string .

xsd:negativeInteger  rdf:type  rdfs:Datatype .

xsd:double  rdf:type  rdfs:Datatype .

qudt:N-Tuple  rdf:type       owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "N-Tuple Type";
        rdfs:subClassOf      qudt:Tuple;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  A tuple containing n objects is known as an \"n-tuple\". \n  For example the 4-tuple (or \"quadruple\"), with components of respective types PERSON, DAY, MONTH and YEAR.\n  This could be used to record that a certain person was born on a certain day of a certain month of a certain year.\n  " .

qudt:arg3Type  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "arg3Type";
        rdfs:subPropertyOf   qudt:argType;
        dcterms:description  "This property relates a funciton data type with the type of its arg3." .

qudt:Record  rdf:type        owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Record Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  A Record Type is a type whose values are records, i.e. aggregates of several items of possibly different types. \n  The aggregated items are called fields or members and are usually identified or indexed by field labels.\n  " .

qudt:List  rdf:type          owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "List";
        rdfs:subClassOf      qudt:DataItem;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:hasUnit
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:quantity
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:datatype
                             ];
        dcterms:description  "A sub-type of 'AbstractDataItem'." .

qudt:CharEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Char Encoding Type";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "The class of all character encoding schemes, each of which defines a rule or algorithm for encoding character data as a sequence of bits or bytes." , "\n  <p>The class of all character encoding schemes.\n  Each defines a rule or algorithm for encoding character data as a sequence of bits or bytes.\n  </p>"^^rdf:HTML .

xsd:int  rdf:type  rdfs:Datatype .

qudt:float_Y  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "float Y";
        rdfs:range        xsd:float .

xsd:integer  rdf:type  rdfs:Datatype .

qudt:cName  rdf:type         owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "C Language name" , "C name";
        rdfs:range           xsd:string;
        rdfs:subPropertyOf   qudt:id;
        dcterms:description  "Datatype name in the C programming language" .

qudt:FieldType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Field Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:fieldType
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:fieldLabel
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:elementName
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:elementName
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:fieldLabel
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:elementName
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:fieldLabel
                             ];
        dcterms:description  "\n  A sub-type of 'Composite Data Type'.\n  " .

qudt:pitchRotationDefinition
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "pitch rotation definition";
        rdfs:range          qudt:AxialOrientationType;
        rdfs:subPropertyOf  qudt:rotationDefinition .

qudt:DiscreteState  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Discrete State";
        rdfs:subClassOf      qudt:EnumeratedValue;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:inverted
                             ];
        dcterms:description  "\n  <p>A <em>Discrete State</em> is the parent class for enumerated values that express a 'State' or 'Condition'.\n  Examples are 'on' and 'off for a switch, 'open' and 'closed' for a valve, and 'wet' and 'dry'.\n  </p>\n  "^^rdf:HTML .

qudt:isHeterogeneous  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "is heterogeneous";
        rdfs:range        xsd:boolean .

qudt:oleDBName  rdf:type           owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label                 "OLE DB name";
        rdfs:range                 xsd:string;
        rdfs:subPropertyOf         qudt:id;
        dcterms:description        "OLE DB (Object Linking and Embedding, Database, sometimes written as OLEDB or OLE-DB), an API designed by Microsoft, allows accessing data from a variety of sources in a uniform manner. The API provides a set of interfaces implemented using the Component Object Model (COM); it is otherwise unrelated to OLE. " , "\n  <p>OLE DB (Object Linking and Embedding, Database, sometimes written as OLEDB or OLE-DB), an API designed by Microsoft, allows accessing data from a variety of sources in a uniform manner. \n  The API provides a set of interfaces implemented using the Component Object Model (COM); it is otherwise unrelated to OLE.\n  </p>"^^rdf:HTML;
        qudt:informativeReference  "http://msdn.microsoft.com/en-us/library/windows/desktop/ms714931(v=vs.85).aspx"^^xsd:anyURI , "http://en.wikipedia.org/wiki/OLE_DB"^^xsd:anyURI;
        prov:wasInfluencedBy       <http://en.wikipedia.org/wiki/OLE_DB> , <http://msdn.microsoft.com/en-us/library/windows/desktop/ms714931(v=vs.85).aspx> .

xsd:gYearMonth  rdf:type  rdfs:Datatype .

qudt:FixedIntervalTimeSeriesArray
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Fixed Interval Time Series Array Type";
        rdfs:subClassOf      qudt:TimeSeriesArray;
        dcterms:description  "\n  <p>A <em>Fixed Interval Time Series Array Type</em> is a data type that specifies the properties of arrays that hold time series data.\n  For example, data that has been sampled over uniformly spaced time intervals.\n  A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals.\n  </p>"^^rdf:HTML .

qudt:fieldName  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "field name" .

qudt:Unsigned  rdf:type   qudt:SignednessType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Unsigned";
        dtype:literal     "unsigned" .

qudt:LongUnsignedIntegerEncoding
        rdf:type          qudt:IntegerEncodingType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Long Unsigned Integer Encoding";
        qudt:bytes        8 .

qudt:True  rdf:type       qudt:BooleanStateType;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "true";
        dtype:code        "1";
        dtype:literal     "true" .

qudt:optional  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "optional";
        rdfs:range        xsd:boolean .

qudt:elementKind  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element kind";
        rdfs:subPropertyOf   qudt:elementKind;
        dcterms:description  "This property is used to describe the quantity kind for a dimensional data type." .

qudt:SinglePrecisionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Single Precision Type";
        rdfs:subClassOf      qudt:NumericType;
        dcterms:description  "\n  A single precision data type specifies how a numeric value, such as an integer or real number,\n   is stored in memory that occupies one word in computer memory,\n   where the byte length of a word depends on machine address size of the computer processor. \n  For example, on 32-bit machine architectures, a word is four bytes.\n  A single precision data value on a 32-bit machine architecture occupies four bytes of memory.\n  " .

qudt:ShortIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Short Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  A Short Integer is an integer that can be represented in two octets (16 bits) of machine memory. \n  Short integers may be signed or unsigned.\n  " .

qudt:vbName  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "Visual Basic name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:lowerBound  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "lower bound" .

qudt:GroundCoordinateSystem
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ground coordinate system";
        rdfs:subClassOf      qudt:AerospaceCoordinateSystem;
        dcterms:description  "A sub-type of 'Aerospace coordinate system'." .

qudt:maxBits  rdf:type    owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "maximum bits";
        rdfs:range        xsd:integer .

qudt:CRC32  rdf:type      rdfs:Datatype;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "CRC-32";
        rdfs:subClassOf   xsd:integer .

qudt:LargeObjectType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Large object";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "A 'LargeObject' datatype is used to store blocks of unstructured data (such as text, graphic images, video clips, and sound waveforms). They often are used to allow efficient, random, piece-wise access to the data." .

xsd:duration  rdf:type  rdfs:Datatype .

