        <http://www.w3.org/2000/01/rdf-schema#label>
                "modifiability";
        <http://purl.org/dc/terms/description>
                "Reference to one in a list of enumerated elements that indicates whether data (e.g. variable or parameter) can be changed." .

<http://www.w3.org/2001/XMLSchema#long>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/OnOffStateTypeEnumeration>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Enumeration>;
        <http://purl.org/dc/terms/description>
                "\n  A discrete state enumeration whose values are 'off' and 'on'. \n  The 'on' value is encoded as a zero (0) and the 'off' value as a one (1).\n  ";
        <http://qudt.org/schema/qudt/inverted>
                true .

<http://qudt.org/schema/qudt/bytes>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
