        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Discrete State</em> is the parent class for enumerated values that express a 'State' or 'Condition'.\n  Examples are 'on' and 'off for a switch, 'open' and 'closed' for a valve, and 'wet' and 'dry'.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/isHeterogeneous>
