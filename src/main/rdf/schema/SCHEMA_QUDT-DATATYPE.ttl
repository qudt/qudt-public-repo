                          <http://qudt.org/schema/qudt/double_X>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A 2D coordinates in single floating point precision for locating a point in physical space.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML>;
        <http://qudt.org/schema/qudt/elementTypeCount>
                2 .

<http://qudt.org/schema/qudt/MathsFunctionType>
        a       <http://www.w3.org/2002/07/owl#Class>;
