                "A sub-type of 'Enumerated Value'." .

<http://qudt.org/schema/qudt/SignedType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/NumericType>;
        <http://purl.org/dc/terms/description>
                "A signed type is a numeric type that distinguishes between positive and negative numbers using an encoding scheme, such as sign and magnitude, one's compliment, and two's compliment to represent negative numbers." .

<http://qudt.org/schema/qudt/DateTypeUnion>
        a       <http://qudt.org/schema/qudt/List>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#first>
                <http://www.w3.org/2001/XMLSchema#date>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>
                ( <http://www.w3.org/2001/XMLSchema#dateTime> <http://www.w3.org/2001/XMLSchema#gYear> <http://www.w3.org/2001/XMLSchema#gMonth> );
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Date Type Union";
        <http://purl.org/dc/terms/description>
                "\n  An rdf:List that can be used in property constraints as the type in an sh:or to indicate\n   that all values of a property must be an xsd date type.\n  " .

<http://qudt.org/schema/qudt/RawValueTupleMemberType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Raw value tuple member type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TupleMember> .

<http://www.w3.org/2001/XMLSchema#gYear>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/BooleanTypeEnumeratedValue>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "boolean value";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "Specifies how a boolean value is expressed" .

<http://qudt.org/schema/qudt/valueVector>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "value vector";
        <http://purl.org/dc/terms/description>
