        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "ORACLE SQL name";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/id> .

<http://qudt.org/schema/qudt/DimensionalDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Dimensional Data Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StructuredDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Dimensional Data Type</em> is a data type that specifies a physical quantity or unit of measure.\n  Information about the physical dimensions of the quantities and units is embedded in their types.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/BinaryTree>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Binary Tree Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Tree>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Binary Tree</em> is a data type that defines the properties of data structures that represent binary trees. \n  A binary tree is a tree in which each node has at most 2 children.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/ByRow>
