        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/dataEncoding>
                ];
        <http://www.linkedmodel.org/schema/vaem#isElaboratedIn>
                <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

<http://qudt.org/schema/qudt/StateSpaceMatrix>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "State Space Matrix Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Matrix>;
        <http://purl.org/dc/terms/description>
                "\n  <p>In control engineering, a state space representation is a mathematical model of a physical system\n   as a set of input, output and state variables related by first-order differential equations. \n  To abstract from the number of inputs, outputs and states, the variables are expressed as vectors.\n  The differential and algebraic equations are written in matrix form (the last one can be done when the dynamical system is linear and time invariant).\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/TupleMember>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Tuple Member Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CompositeDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/orderInStructure>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/orderInStructure>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/orderInStructure>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p><em>Tuple Member</em> defines the properties of a member of a tuple. \n  It is used to provide fine grained type specification to the elements of tuples.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.linkedmodel.org/schema/vaem#comment>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> .

<http://www.w3.org/2001/XMLSchema#unsignedInt>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://www.linkedmodel.org/schema/dtype#literal>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string> .

<http://qudt.org/schema/qudt/inverted>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
