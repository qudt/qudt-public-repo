<http://qudt.org/schema/qudt/Polarity>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Polarity";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "\n  A \"Tagged Enumeration\" with the following instance(s): \"negative\", \"positive\".\n  " .

<http://qudt.org/schema/qudt/positiveDeltaLimit>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Positive delta limit";
        <http://purl.org/dc/terms/description>
                "A positive change limit between consecutive sample values for a parameter. The Positive Delta may be the encoded value or engineering units value depending on whether or not a Calibrator is defined."^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/padding>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "padding";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/PaddingType> .

<http://qudt.org/schema/qudt/Enumeration>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
