<http://qudt.org/schema/qudt/RealDoublePrecisionType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Real Double Precision Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/RealDatatype> , <http://qudt.org/schema/qudt/DoublePrecisionType>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A real double precision data type specifies how a real number, or an approximation of a real number is stored in memory.\n  Typically this occupies two words in computer memory, where the byte length of a word depends on machine address size of the computer processor. \n  For example, on 32-bit machine architectures, a word is four bytes.\n  An example of a real double precision data type specification is the IEEE 754 standard for encoding binary or decimal floating point numbers in 8 bytes for storage on 32-bit machine architectures.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.w3.org/2001/XMLSchema#unsignedShort>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/WetDryStateType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Wet dry state type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/DiscreteState> , <http://qudt.org/schema/qudt/EnumeratedValue> .

<http://qudt.org/schema/qudt/coordinateSystem>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "coordinate system";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/CoordinateSystem> .

<http://qudt.org/schema/qudt/byRow>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty> , <http://www.w3.org/2002/07/owl#FunctionalProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#boolean> .

<http://qudt.org/schema/qudt/ThreeTuple>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Three-Tuple";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/N-Tuple>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementDatatype>
                ];
        <http://purl.org/dc/terms/description>
                "\n  A three-tuple is a tuple with exactly three members. \n  A Three-Tuple Type is a data type that defines the type properties of a class of three-tuples and their members.\n  " .

<http://qudt.org/schema/qudt/StructuredDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Structured Data Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Datatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementDatatype>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Structured Datatype</em>, in contrast to a scalar data type, is used to characterize classes of complex data structures.\n  Examples are collections, linked and indexed lists, trees, ordered trees, and multi-dimensional file formats.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/Table>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Table Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StructuredDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/columns>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/dimensionality>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/rows>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/byRow>
                ];
        <http://purl.org/dc/terms/description>
                "\n  A Table Type is a data type that specifies the properties of table data structures. \n  A table is both a mode of visual communication and a means of arranging data. \n  The precise conventions and terminology for describing tables varies depending on the context. \n  Moreover, tables differ significantly in variety, structure, flexibility, notation, representation and use.\n  " .

<http://qudt.org/schema/qudt/SignedBigIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Big Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/BigIntegerType> , <http://qudt.org/schema/qudt/SignedIntegerType>;
        <http://purl.org/dc/terms/description>
                "A Signed Big Integer is a signed integer that can be represented in eight octets (64 bits) of machine memory." .

<http://www.linkedmodel.org/schema/vaem#description>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> .

<http://qudt.org/schema/qudt/PartialArray>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Partial Array";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Array>;
        <http://purl.org/dc/terms/description>
                "\n  A partial array is an Array with two attributes that define the starting and ending indices of the elements that are provided.\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.w3.org/2001/XMLSchema#gMonth>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/rollRotationDefinition>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
