                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/encoding>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A class of data types for structures that represent temporal quantities.\n  For example, calendar dates, times, duration of time since a given epoch, etc.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

