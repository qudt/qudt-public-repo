                "roll rotation definition";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/AxialOrientationType>;
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/rotationDefinition> .

<http://qudt.org/schema/qudt/ISO8601-UTCDateTime-BasicFormat>
        a       <http://qudt.org/schema/qudt/DateTimeStringEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <file:///Users/ralphtq/git-qudt/qudt-public-repo/qudt> , <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "ISO 8601 UTC Date Time - Basic Format";
        <http://qudt.org/schema/qudt/allowedPattern>
                "[0-9]{4}[0-9]{2}[0-9]{2}T[0-9]{2}[0-9]{2}[0-9]{2}.[0-9]+Z" , "[0-9]{4}[0-9]{2}[0-9]{2}T[0-9]{2}[0-9]{2}[0-9]{2}Z" .

<http://qudt.org/schema/qudt/cardinality>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "cardinality";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/CardinalityType> .

<http://qudt.org/schema/qudt/SystemModifiableParameter>
        a       <http://qudt.org/schema/qudt/ParameterModifiabilityType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "System modifiable parameter";
        <http://purl.org/dc/terms/description>
                "Parameter is modifiable by a (computer) system.";
        <http://www.linkedmodel.org/schema/dtype#code>
                "1";
        <http://www.linkedmodel.org/schema/dtype#literal>
                "system" .

<http://qudt.org/schema/qudt/visualCue>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "visual cue";
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/modalCue> .

<http://qudt.org/schema/qudt/StateSpaceVector>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "State Space Vector Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Vector>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/coordinateSystem>
                ];
        <http://purl.org/dc/terms/description>
                "\n  A state vector in general control systems describes the observed states of an object in state space.\n  For example in variables of the degrees of freedom for motion. \n  As data types, state vector types are used to specify the structure of state vectors, such as how the observed state is encoded.\n  " .

<http://qudt.org/schema/qudt/IntegerUnionList>
        a       <http://qudt.org/schema/qudt/List>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#first>
                <http://www.w3.org/2001/XMLSchema#int>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>
                ( <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> <http://www.w3.org/2001/XMLSchema#positiveInteger> <http://www.w3.org/2001/XMLSchema#integer> );
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Integer Union List" .

<http://qudt.org/schema/qudt/TextTypeUnion>
        a       <http://qudt.org/schema/qudt/List>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#first>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>
                ( <http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> <http://qudt.org/schema/qudt/LatexString> );
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Text Type Union";
        <http://purl.org/dc/terms/description>
                "\n  An rdf:List that can be used in property constraints as value for sh:or to indicate that all values of a property\n   must be a plain string, a string with HTML markup, or a string with LaTeX markup.\n  " .

<http://qudt.org/schema/qudt/AbstractDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Abstract Datatype";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StructuredDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>An \"Abstract Datatype\" (ADT) is a specification of a set of data and the set of operations that can be performed on the data. \n  Such a data type is abstract in the sense that it is independent of various concrete implementations. \n  The definition can be mathematical, or it can be programmed as an interface. \n  A first class ADT supports the creation of multiple instances of the ADT, and the interface normally provides a constructor,\n   which returns an abstract handle to new data, and several operations, \n   which are functions accepting the abstract handle as an argument.</p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML>;
        <http://www.w3.org/ns/prov#wasInfluencedBy>
                <http://en.wikipedia.org/wiki/Abstract_data_type> , <http://xlinux.nist.gov/dads/HTML/abstractDataType.html> .

<http://qudt.org/schema/qudt/minInclusive>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "min inclusive";
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/lowerBound>;
        <http://purl.org/dc/terms/description>
                "minInclusive is the inclusive lower bound of the value space for a datatype with the ordered property. The value of minInclusive must be in the value space of the base type." .

<http://qudt.org/schema/qudt/orderingRelation>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Ordering Relation";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.linkedmodel.org/schema/dtype#ComparisonOperator>;
        <http://purl.org/dc/terms/description>
                "\n  This property identifies the mathematical comparison operator (such as \"<\" or \">\") that is used to order the elements of a collection.\n  " .

<http://qudt.org/schema/qudt/rotationDefinition>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "rotation definition" .

<http://qudt.org/schema/qudt/argType>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
