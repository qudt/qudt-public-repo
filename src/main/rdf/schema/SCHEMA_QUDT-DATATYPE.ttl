        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Scale> , <http://www.linkedmodel.org/schema/dtype#Enumeration>;
        <http://purl.org/dc/terms/description>
                "\n  A sub-type of 'DTYPE Enumeration'.\n  " .

<http://qudt.org/schema/qudt/ByColumn>
