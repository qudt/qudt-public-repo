                               owl:onProperty   qudt:datatype
                             ];
        dcterms:description  "\n  <p>An <em>Array></em> is a data structure that stores a collection of elements, typically of the same type, in a contiguous block of memory. \n  Each element in an array is identified by an index or key, which is typically a numerical identifier, either starting at '0' or '1'.\n  </p>\n  <p>The key considerations for an Array are:\n  </p>\n  <ol>\n  <li>Fixed Size: The size of an array may be pre-determined when it is created and cannot be changed;</li>\n  <li>Index-Based Access: Elements can be accessed, updated, or modified using their index;</li>\n  <li>Heterogenous Elements: all elements in the array may be of different data types;</li>\n  <li>Contiguous Memory Allocation: \n    the elements are stored in consecutive memory locations, which allows efficient access using the index.</li>\n  </ol>\n  <p>An Array is represented as ordered entries of values arranged according to its dimensionality.\n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>The property 'qudt:datatype' refers to a list if the datatypes of the elements.  \n  </p>\n  <p>An heterogenous array can be multi-dimensional.\n  Multiple indices are used but they are treated as extensions of the same structure.\n  For example: for a 2D array arr[2][3], indices refer to the row and column positions.\n  A 2D array is still represented as a list, where each member of the list is a list.\n  </p>\n  <p>Higher dimensional arrays can be represented as nested lists.\n  For each dimension a new nested list is defined.\n  </p>"^^rdf:HTML .

qudt:TextStringType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Text String Type";
        rdfs:subClassOf      qudt:StringType;
        dcterms:description  "\n  A <em>Text String Type</em> has encodings that are specified in subclasses or in connection to character arrays in <em>Structured Datatypes</em>.\n  " .

qudt:typeVector  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "type vector" .

qudt:positive  rdf:type   qudt:Polarity;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "positive";
        dtype:code        "2";
        dtype:literal     "positive" .

xsd:time  rdf:type  rdfs:Datatype .

dcterms:contributor  rdf:type  owl:AnnotationProperty;
        rdfs:label  "contributor" .

qudt:bounded  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "bounded";
        rdfs:range           xsd:boolean;
        dcterms:description  "A datatype is bounded if its value space has either a finite upper and lower bound. Either bound may be inclusive or exclusive. " .

xsd:positiveInteger  rdf:type  rdfs:Datatype .

