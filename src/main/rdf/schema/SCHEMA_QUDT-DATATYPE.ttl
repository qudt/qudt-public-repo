                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Quantity> .

<http://qudt.org/schema/qudt/CompositeDataStructure>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Composite Data Structure";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CompositeDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Composite Data Structure</em>, also referred to as <em>Data Record</em> is a datatype that aggregates element of possibly different types. \n  The aggregated items are called fields or members and are usually identified or indexed by field labels.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML>;
        <http://www.w3.org/ns/prov#wasInfluencedBy>
                <https://en.wikipedia.org/wiki/List_of_data_structures> , <https://en.wikipedia.org/wiki/Record_(computer_science)> .

<http://qudt.org/schema/qudt/microsoftSQLServerName>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Microsoft SQL Server name";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/id> .

