        <http://www.w3.org/2000/01/rdf-schema#label>
                "Modal Enumeration";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Enumeration>;
        <http://purl.org/dc/terms/description>
                "A sub-type of 'QUDT Enumeration'." .

<http://qudt.org/schema/qudt/AuralCue>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Aural Cue";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ModalCue>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/sound>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/sound>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/sound>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>An aural cue is a sound produced by a device or a system that is used to alert personnel of of an advisory, cautionary, warning, or emergency state.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/IEEE754_1985RealEncoding>
        a       <http://qudt.org/schema/qudt/FloatingPointEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "IEEE 754 1985 Real Encoding";
        <http://qudt.org/schema/qudt/bytes>
                32 .

<http://qudt.org/schema/qudt/XSDatomicTypeUnion>
        a       <http://qudt.org/schema/qudt/List>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#first>
                <http://www.w3.org/2001/XMLSchema#anySimpleType>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>
                ( <http://www.w3.org/2001/XMLSchema#anySimpleType> );
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "XSD Atomic Type Union";
        <http://purl.org/dc/terms/description>
                "\n  <p>In XML Schema Definition (XSD) xsd:anySimpleType is the base type for all simple types.\n  Simple types in XSD represent atomic values without any child elements or complex structures.\n  All simple types are compliant with xsd:anySimpleType.\n  </p>\n  <p>In XSD, the atomic types are: xsd:string, xsd:boolean, xsd:decimal, xsd:float,\n   xsd:double, xsd:duration, xsd:dateTime, xsd:time, xsd:date, xsd:gYearMonth, xsd:gYear, xsd:gMonthDay,\n   xsd:gDay, xsd:gMonth, xsd:hexBinary, xsd:base64Binary, xsd:anyURI, xsd:QName, and xsd:NOTATION.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/double_Z>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty> , <http://www.w3.org/2002/07/owl#FunctionalProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#double> .

<http://qudt.org/schema/qudt/minExclusive>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "min exclusive";
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/lowerBound>;
        <http://purl.org/dc/terms/description>
                "minExclusive is the exclusive lower bound of the value space for a datatype with the ordered property. The value of minExclusive must be in the value space of the base type or be equal to {value} in {base type definition}." .

<http://qudt.org/schema/qudt/fieldLabel>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty> , <http://www.w3.org/2002/07/owl#FunctionalProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string> .

<http://qudt.org/schema/qudt/StringEncodingType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "String Encoding Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Encoding>;
        <http://purl.org/dc/terms/description>
                "\n  <p><em>String Encoding Type</em> is an \"Encoding\" with the following instance(s):\n   \"UTF-16 String\", \"UTF-8 Encoding\".\n   </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> , "\n  An \"Encoding\" with the following instance(s): \"qudt:UTF8-StringEncoding\", \"qudt:UTF16-StringEncoding\".\n  " .

<http://qudt.org/schema/qudt/ByLeftMostIndex>
        a       <http://qudt.org/schema/qudt/ArrayDataOrder>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "By Left Most Index";
        <http://www.linkedmodel.org/schema/dtype#literal>
                "byLeftMostIndex" .

<http://qudt.org/schema/qudt/Major>
        a       <http://qudt.org/schema/qudt/MajorMinorType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/shacl/datatype> , <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Major";
        <http://www.linkedmodel.org/schema/dtype#code>
                2;
        <http://www.linkedmodel.org/schema/dtype#literal>
                "major";
        <http://www.linkedmodel.org/schema/dtype#order>
                "2"^^<http://www.w3.org/2001/XMLSchema#int> .

<http://qudt.org/schema/qudt/ThreeBodyRotatingCoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Three Body Rotating Coordinate System Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/AerospaceCoordinateSystem>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Three Body Rotating Coordinate System</em> is one that is associated with two different three-body systems.\n  For example, the Sun-Earth-spacecraft system and the Earth-Moon-spacecraft system.\n  </p>\n  <p>The lunar coordinate systems are primarily used when operating in close proximity to the Moon. \n  There are, however, a few additional coordinate systems that are also useful when analyzing (and depicting) trajectories in the vicinity of the Earth-Moon system.  \n  The Sun-Earth and Earth-Moon rotating coordinate frames are defined as follows: \n  </p>\n  <p>The pole vector or Z-axis of the coordinate frame is set equal to the instantaneous orbit normal of the secondary (smaller) body about the primary (larger) body.\n  The X-axis is set equal to the vector from the primary body center of mass (CM) to the secondary body CM. \n  The X-axis rotates at a rate equal to the instantaneous rotation rate of the secondary body about the primary body.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/EngineeringValueTupleMember>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Engineering Value Tuple Member";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TupleMember>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A sub-type of 'Tuple Member Type'. \n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/isByteString>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "is byte string";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#boolean> .

<http://qudt.org/schema/qudt/hasUnit>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Unit> .

<http://qudt.org/schema/qudt/dataEncoding>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "data encoding";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/DataEncoding> .

<http://qudt.org/schema/qudt/modalCue>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "modal cue";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/ModalCue> .

<http://qudt.org/schema/qudt/CT_UNCOUNTABLE>
        a       <http://qudt.org/schema/qudt/CardinalityType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Uncountable Cardinality Type";
        <http://purl.org/dc/terms/description>
                "\n  Any set with cardinality greater than that of the natural numbers, or \n  $$| X | \\; >  \\; | \\mathbb N | $$\n  \n  For example $| R| \\; =  \\;  c  \\; > |\\mathbb N |$, is said to be uncountable.\n  "^^<http://qudt.org/schema/qudt/LatexString>;
        <http://www.linkedmodel.org/schema/dtype#literal>
                "uncountable" .

<http://qudt.org/schema/qudt/visualCueEnumeration>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "visual cue enumeration";
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/modalCueEnumeration> .

<http://qudt.org/schema/qudt/CT_COUNTABLY-INFINITE>
        a       <http://qudt.org/schema/qudt/CardinalityType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Countably Infinite Cardinality Type";
        <http://purl.org/dc/terms/description>
                "\n  A set of numbers is called countably infinite if there is a way to enumerate them.\n  Formally this is done with a bijection function that associates each number in the set with exactly one of the positive integers.\n  The set of all fractions is also countably infinite.\n  In other words, any set $X$ that has the same cardinality as the set of the natural numbers,\n   or $| X | \\; =  \\; | \\mathbb N | \\; = \\; \\aleph0$, is said to be a countably infinite set.\n  "^^<http://qudt.org/schema/qudt/LatexString>;
        <http://qudt.org/schema/qudt/informativeReference>
                "http://www.math.vanderbilt.edu/~schectex/courses/infinity.pdf"^^<http://www.w3.org/2001/XMLSchema#anyURI>;
        <http://www.linkedmodel.org/schema/dtype#literal>
                "countable" .

<http://qudt.org/schema/qudt/Coordinates>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Coordinates";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Tuple>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A coordinate system is a mathematical structure for assigning a unique n-tuple of numbers or scalars to each point in an n-dimensional space. \n  A Coordinate System Type is a data type that defines the properties of data structures that represent coordinate systems.\n  </p>\n  <p>The primary attributes of any coordinate system are the coordinate frame or orientation of the axes of the coordinate system and the coordinate center or origin of the coordinate system.\n  The coordinate center is the easier of the two attributes to define and in trajectory-related coordinate systems is often taken to be the center of mass of natural solar system bodies such as the Earth, the Moon, or Mars.\n  Precise definition of the coordinate frame, however, usually takes much more effort. \n  As a result, the primary purpose is to provide a detailed description of a number of different coordinate frames commonly used in mission analysis.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/ReferenceDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Reference Data Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StructuredDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A reference is an object containing information which refers to data stored elsewhere, as opposed to containing the data itself. \n  A reference data type is a data type that specifies how a reference is represented and stored in memory,\n   as well as the operations that can be performed on reference values. \n  The most common example of a reference data type is a pointer.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/FixedIntervalTimeSeriesArrayType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Fixed Interval Time Series Array Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TimeSeriesArrayType>;
        <http://purl.org/dc/terms/description>
                "<p>A <em>Fixed Interval Time Series Array Type</em> is a data type that specifies the properties of arrays that hold time series data.\n For example, data that has been sampled over uniformly spaced time intervals. \n A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals.\n </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/ArrayType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Array Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/CompositeDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>An <em>Array Type</em> is a type specification for ordered entries of values arranged according to the dimensions given. \n  The dimensions are given as a list of integers where each integer is the cardinality of each dimension. \n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>Optionally a reference can be made to a variable, whose values are the array entries. \n  The data type of the array entries is an optional field, 'elementType', which points to a data type definition. \n  If the data type is given, then it applies to all elements.  \n  If it is not given then the elements can be of different types for each position in the array.\n  </p>\n  <p>The property <em>qudt:typeMatrix</em> must refer to a matrix of types.\n  If a default value is given this can be used to place the appropriate value in a cell when an entry value is not known. \n  If no dimensionality or dimension vector is specified the array is under-specified but still legitimate as a place-holder for a data type.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.linkedmodel.org/schema/dtype#value>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/EnumeratedValue> .

<http://www.w3.org/2001/XMLSchema#gMonthDay>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/member>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "member";
        <http://purl.org/dc/terms/description>
                "\n  This property is used to define a collection's elements. \n  " .

<http://qudt.org/schema/qudt/minLength>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "min length";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer> .

<http://qudt.org/schema/qudt/negativeDeltaLimit>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "negative delta limit";
        <http://purl.org/dc/terms/description>
                "A negative change limit between consecutive sample values for a parameter. The Negative Delta may be the encoded value or engineering units value depending on whether or not a Calibrator is defined."^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/incrementDatatype>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty> , <http://www.w3.org/2002/07/owl#FunctionalProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/TimeStringType> .

<http://qudt.org/schema/qudt/KinestheticCue>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Kinesthetic Cue";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ModalCue>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/dtype#code>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/dtype#code>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/dtype#code>
                ] .

<http://qudt.org/schema/qudt/DateTimeStringEncodingType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Date Time String Encoding Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/StringEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/allowedPattern>
                ];
        <http://purl.org/dc/terms/description>
                "Date Time encodings are logical encodings for expressing date/time quantities as strings by applying unambiguous formatting and parsing rules." .

<http://qudt.org/schema/qudt/BooleanEncodingType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Boolean Encoding Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Encoding> .

<http://qudt.org/schema/qudt/TwoTupleType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Two-Tuple Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/N-TupleType>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementDatatype>
                ];
        <http://purl.org/dc/terms/description>
                "A 2-tuple is called a pair. For example, a complex number can be represented as a 2-tuple, and 2D coordinates are sometimes represented as 2-tuples." .

<http://qudt.org/schema/qudt/FileFormat>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "File format";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "\n  A sub-type of 'Enumerated Value'.\n  " .

<http://qudt.org/schema/qudt/BalancedTree>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Balanced Tree Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Tree>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/maxDepth>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Balanced Tree</em> is a data type that defines the properties of data structures that represent balanced trees. \n  A balanced tree is a tree where no leaf is much farther away from the root than any other leaf. \n  Different balancing schemes allow different definitions of \"much farther\" and different amounts of work to keep them balanced.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/StringType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "String Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ScalarDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/typeMatrix>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/isByteString>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/maxLength>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/typeMatrix>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/typeMatrix>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>String Type</em> is a data type that specifies the properties of a list structure that holds characters.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/rdfsDatatype>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "rdfs datatype";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/$$QUDT_VERSION$$/schema/datatype>
        a       <http://www.w3.org/2002/07/owl#Ontology>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "QUDT SCHEMA - Datatypes";
        <http://www.linkedmodel.org/schema/vaem#hasGraphMetadata>
                <http://qudt.org/schema/datatype/GMD_datatype>;
        <http://www.w3.org/2002/07/owl#imports>
                <http://www.linkedmodel.org/schema/dtype> , <http://www.linkedmodel.org/schema/vaem> , <http://www.w3.org/2004/02/skos/core>;
        <http://www.w3.org/2002/07/owl#versionIRI>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype> .

<http://qudt.org/schema/qudt/referenceFrame>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "reference frame";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/ReferenceFrame>;
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/coordinateSystemFrame> .

<http://qudt.org/schema/qudt/dataOrder>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "data order";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/MatrixElementOrder> .

<http://qudt.org/schema/qudt/BooleanEncoding>
        a       <http://qudt.org/schema/qudt/BooleanEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Boolean Encoding";
        <http://qudt.org/schema/qudt/bits>
                1 .

<http://qudt.org/schema/qudt/pattern>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "pattern";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://purl.org/dc/terms/description>
                "A pattern is a constraint on the value space of a datatype which is achieved by constraining the lexical space to literals which match a specific pattern. The value of pattern must be a regular expression." .

<http://qudt.org/schema/qudt/N-TupleType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "N-Tuple Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Tuple>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementDatatype>
                ];
        <http://purl.org/dc/terms/description>
                "\n  A tuple containing n objects is known as an \"n-tuple\". \n  For example the 4-tuple (or \"quadruple\"), with components of respective types PERSON, DAY, MONTH and YEAR.\n  This could be used to record that a certain person was born on a certain day of a certain month of a certain year.\n  " .

<http://qudt.org/schema/qudt/auralCueEnumeration>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "aural cue enumeration";
        <http://www.w3.org/2000/01/rdf-schema#subPropertyOf>
                <http://qudt.org/schema/qudt/modalCueEnumeration> .

<http://qudt.org/schema/qudt/LunarCoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Lunar Coordinate System";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TrajectoryCoordinateSystem>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/realization>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/yAxisDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/xAxisDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/zAxisDefinition>
                ];
        <http://purl.org/dc/terms/description>
                "\n  Two slightly different coordinate frames are commonly used to define the orientation of the axes of a lunar body-fixed coordinate system:\n   a mean Earth/rotation frame and a principal axis coordinate frame. \n  The mean Earth/rotation frame (sometimes called the \"Mean Earth/polar axis\" frame) is a lunar body-fixed coordinate frame.\n  This has the X-axis aligned with the mean direction from the Moon to the Earth and the Z-axis aligned with the mean axis of rotation of the Moon. \n  The principal axis frame is a lunar body-fixed coordinate frame aligned with the principal axes of the Moon. \n  Due to the fact that the Moon is synchronously rotating but is not exactly symmetric, the principal axes and the mean Earth/rotation axes of the Moon do not coincide.\n  " .

<http://qudt.org/schema/qudt/hexbinary>
        a       <http://www.w3.org/2002/07/owl#Class> , <http://www.w3.org/2000/01/rdf-schema#Datatype>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "hexbinary";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://www.w3.org/2001/XMLSchema#string> .

<http://qudt.org/schema/qudt/minMantissa>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "min mantissa";
        <http://purl.org/dc/terms/description>
                "\n  <p>The minimium mantissa is the negative integer with the greatest magnitude that may appear as a coefficient in a finite precision representation of a real number.  \n  For a given numeric data type, the value of <em>minMantissa</em> (<em>M</em>) and the values of <em>base</em> (<em>b</em>) and <em>precision</em> (<em>p</em>) are related by the formula:\n  </p>\n  <p><em>M = -(b<sup>p</sup> - 1)</em>.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.w3.org/2001/XMLSchema#gDay>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/QuantityValueType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Quantity value type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/DimensionalDatatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementUnit>
                ];
        <http://purl.org/dc/terms/description>
                "A sub-type of 'Dimensional Data Type'." .

<http://www.w3.org/2001/XMLSchema#NOTATION>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/OrderedCollection>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Ordered Collection Kind";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Collection>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/orderingRelation>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>An <em>Ordered Collection Kind</em> is an abstract data type that defines the properties of collection data structures whose members can be linearly ordered. \n  An ordered collection is a collection together with an ordering relation (such as greater than) that linearly orders the collection elements.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://www.w3.org/2001/XMLSchema#byte>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/columns>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "columns";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer> .

<http://qudt.org/schema/qudt/orderedType>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "ordered type";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/OrderedType> .

<http://qudt.org/schema/qudt/maxDepth>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "max depth";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer> .

<http://qudt.org/schema/qudt/UnsignedMediumIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Unsigned Medium Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/UnsignedIntegerType>;
        <http://purl.org/dc/terms/description>
                "\n  An \"Unsigned Medium Integer\" is an integer of 24 bits that only takes on both positive values.\n  " .

<http://qudt.org/schema/qudt/accuracy>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "accuracy";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer>;
        <http://purl.org/dc/terms/description>
                "\n  <p><em>Accuracy</em> is the degree to which a given quantity is correct and free from error. \n  For example, a quantity specified as 100+/-1 has an (absolute) accuracy of +/-1 (meaning its true value can fall in the range 99-101),\n   while a quantity specified as 100+/-2% has a (relative) accuracy of +/-2% (meaning its true value can fall in the range 98-102).\n  </p>\n  <p>The concepts of accuracy and precision are both closely related and often confused. \n  While the accuracy of a number x is given by the number of significant decimal (or other) digits to the right of the decimal point in x,\n   the precision of x is the total number of significant decimal (or other) digits.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/InertialReferenceFrame>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Inertial reference frame";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ReferenceFrame>;
        <http://purl.org/dc/terms/description>
                "\n  A sub-type of 'Reference Frame'.\n  " .

<http://qudt.org/schema/qudt/SinglePrecisionRealEncoding>
        a       <http://qudt.org/schema/qudt/FloatingPointEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Single Precision Real Encoding";
        <http://qudt.org/schema/qudt/bytes>
                32 .

<http://qudt.org/schema/qudt/VariableIntervalTimeSeriesArray>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Variable Interval Time Series Array Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TimeSeriesArray>;
        <http://purl.org/dc/terms/description>
                "A Variable Interval Time Series Array Type is a data type that specifies the properties of arrays that hold time series data that has been sampled over non-uniformly spaced time intervals. A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals. For variable interval time series, the successive time intervals may follow a repeating pattern, or may be completely random." .

<http://qudt.org/schema/qudt/DataSetElement>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "QUDT DataSet Element";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/DataItem> , <http://qudt.org/schema/qudt/Tuple>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/hasQuantityKind>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementLabel>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/optional>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementLabel>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementLabel>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/optional>
                ];
        <http://purl.org/dc/terms/description>
                "\n  A field is a tuple that carries a name, a type and optionally other properties that characterize a member element of a composite data structure.\n  " .

<http://qudt.org/schema/qudt/UnsignedBigIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Unsigned Big Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/UnsignedIntegerType> , <http://qudt.org/schema/qudt/BigIntegerType>;
        <http://purl.org/dc/terms/description>
                "An Unsgned Big Integer is an unsigned integer that can be represented in eight octets (64 bits) of machine memory." .

<http://qudt.org/schema/qudt/Coordinates-3D>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "3D Coordinate Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ThreeTuple> , <http://qudt.org/schema/qudt/CartesianCoordinates>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A 3D coordinate system is a system for assigning a three-tuple of numbers or scalars to each point in an 3-dimensional space.\n  A corresponding 3D Coordinate Type is a data type that defines the data type for each coordinate (tuple member) in a 3D coordinate system.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/MassPropertiesArray>
        a       <http://www.w3.org/1999/02/22-rdf-syntax-ns#Class> , <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Mass Properties Array";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/HeterogenousArray>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Mass Properties Array</em> holds, for an object, four values for the properties:\n   Center of Gravity, Mass, Moment of Inertia, and Product of Inertia. </p>\n  " .

<http://qudt.org/schema/qudt/basis>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "basis";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Datatype> , <http://qudt.org/schema/qudt/QuantityType> .

<http://qudt.org/schema/qudt/PositiveBigIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Positive Big Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/UnsignedType> , <http://qudt.org/schema/qudt/IntegerDatatype>;
        <http://purl.org/dc/terms/description>
                "Positive Integers are integers that are either non-zero and non-negative." .

<http://www.w3.org/2001/XMLSchema#decimal>
        a       <http://www.w3.org/2000/01/rdf-schema#Datatype> .

<http://qudt.org/schema/qudt/exponent>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "exponent" .

<http://qudt.org/schema/qudt/NonNegativeIntegerUnionList>
        a       <http://qudt.org/schema/qudt/List>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#first>
                <http://www.w3.org/2001/XMLSchema#nonNegativeInteger>;
        <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>
                ( <http://www.w3.org/2001/XMLSchema#positiveInteger> );
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Non-negative union list" .

<http://qudt.org/schema/qudt/SignedLongIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Long Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/LongIntegerType> , <http://qudt.org/schema/qudt/SignedIntegerType>;
        <http://purl.org/dc/terms/description>
                "A Signed Long Integer is a signed integer that can be represented in four octets (32 bits) of machine memory." .

<http://qudt.org/schema/qudt/BitAligned>
        a       <http://qudt.org/schema/qudt/AlignmentType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Bit Aligned";
        <http://www.linkedmodel.org/schema/dtype#literal>
                "bit" .

<http://qudt.org/schema/qudt/dimensionality>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "dimensionality";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer>;
        <http://purl.org/dc/terms/description>
                "\n  The number of dimensions making up a matrix or an array. \n  For example a 4 by 4 array has a dimensionality of 2. \n  Whereas a vector or a string has a dimensionality of 1.\n  " .

<http://qudt.org/schema/qudt/hasQuantityKind>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/QuantityKind> .

<http://qudt.org/schema/qudt/CT_FINITE>
        a       <http://qudt.org/schema/qudt/CardinalityType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Finite Cardinality Type";
        <http://purl.org/dc/terms/description>
                "\n  Any set $X$ with cardinality less than that of the natural numbers, or\n  $$| X | \\; <  \\; | \\mathbb N | $$\n  is said to be a finite set.\n  "^^<http://qudt.org/schema/qudt/LatexString>;
        <http://www.linkedmodel.org/schema/dtype#literal>
                "finite" .

<http://qudt.org/schema/qudt/Dictionary>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Dictionary Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Map>;
        <http://purl.org/dc/terms/description>
                "A \"Map\"." .

<http://qudt.org/schema/qudt/UnsignedVariableLengthIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Unsigned Variable Length Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/VariableLengthIntegerType> , <http://qudt.org/schema/qudt/UnsignedIntegerType>;
        <http://purl.org/dc/terms/description>
                "\n  An \"Unsigned Variable Length Integer\" data type defines a data structure for representing unsigned integers that uses a variable number of bits depending on the magnitude of the integer. \n  Typically, variable length integer data types are between one and 64 bits in length.\n  " .

<http://qudt.org/schema/qudt/quantity>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty> , <http://www.w3.org/2002/07/owl#FunctionalProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Quantity> .

<http://qudt.org/schema/qudt/EarthCoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Earth Coordinate System Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TrajectoryCoordinateSystem>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A \"Trajectory Coordinate System\" for all earth-centered coordinates, such as:</p>\n  <ul>\n  <li>Earth mean equator and prime meridian coordinate system;;</li>\n  <li>Earth true equator and prime meridian of epoch coordinate system;</li> \n  <li>International celestial reference system;</li>\n  <li>International terrestrial reference system;</li>\n  <li>Sun centered international celestial reference system;</li>\n  <li>Vehicle centered international celestial reference system.</li>\n  </ul>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/negative>
        a       <http://qudt.org/schema/qudt/Polarity>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "negative";
        <http://www.linkedmodel.org/schema/dtype#code>
                "1";
        <http://www.linkedmodel.org/schema/dtype#literal>
                "negative" .

<http://qudt.org/schema/qudt/elementLabel>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "element label";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://purl.org/dc/terms/description>
                "This property is used to label the field of a composite data structure." .

<http://qudt.org/schema/qudt/double_X>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty> , <http://www.w3.org/2002/07/owl#FunctionalProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#double> .

<http://qudt.org/schema/qudt/SignedIntegerEncoding>
        a       <http://qudt.org/schema/qudt/IntegerEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Integer Encoding";
        <http://qudt.org/schema/qudt/bytes>
                4 .

<http://qudt.org/schema/qudt/IntegerDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Integer Datatype";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/OrdinalType> , <http://qudt.org/schema/qudt/NumericType>;
        <http://purl.org/dc/terms/description>
                "An Integer Type is a data type that specifies how integer numbers are represented and stored in machine memory." .

<http://qudt.org/schema/qudt/frameType>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "frame type";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/FrameType> .

<http://qudt.org/schema/qudt/UnsignedType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Unsigned Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/NumericType>;
        <http://purl.org/dc/terms/description>
                "An unsigned data type is a numeric type that does not distinguish between positive and negative values." .

<http://qudt.org/schema/qudt/BitEncodingType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Bit Encoding";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Encoding>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Bit Encoding Type</em> is an encoding type for the correspondence between the two possible values of a bit, 0 or 1, and some interpretation. \n  For example, in a boolean encoding, a bit denotes a truth value, where 0 corresponds to False and 1 corresponds to True.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/ShortSignedIntegerEncoding>
        a       <http://qudt.org/schema/qudt/IntegerEncodingType>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Short Signed Integer Encoding";
        <http://qudt.org/schema/qudt/bytes>
                2 .

<http://qudt.org/schema/qudt/RealSinglePrecisionType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Real Single Precision Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/SinglePrecisionType> , <http://qudt.org/schema/qudt/RealDatatype>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A real single precision data type specifies how a real number,\n   or an approximation of a real number is stored in memory that occupies one word in computer memory, \n   where the byte length of a word depends on machine address size of the computer processor.\n  </p>\n  <p> \n  For example, on 32-bit machine architectures, a word is four bytes. \n  An example of a real single precision data type specification is the IEEE 754 standard for encoding binary\n   or decimal floating point numbers in 4 bytes for storage on 32-bit machine architectures.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/PaddingType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Padding type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "\n  <p>This describes how unused bits of a field are filled. \n  Unused bits could be set to one or zero. \n  A third option is \"don't care\".\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/rows>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "rows";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer> .

<http://qudt.org/schema/qudt/QuantityKindList>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Quantity kind List";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/List>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Quantity Kind List</em> is a list of qudt:QuantityKind. \n  They are used, for instance, to specify the quantity kind in a Mass Properties Array. \n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/Tree>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Tree Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Graph>;
        <http://purl.org/dc/terms/description>
                "\n  A \"Tree\" is a data type that defines the properties of data structures that represent trees. \n  Each node is either a leaf or an internal node. \n  An internal node has one or more child nodes and is called the parent of its child nodes. \n  Leaf nodes have no chidren. Nodes that share the same parent are siblings. \n  In graph theoretic terminology, a tree is a connected, undirected, acyclic graph.\n  ";
        <http://www.w3.org/ns/prov#wasInfluencedBy>
                <http://en.wikipedia.org/wiki/Tree_(data_structure)> .

<http://qudt.org/schema/qudt/MultiModalType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Multi Modal Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/kinestheticCue>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/iconicCue>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/visualCue>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/auralCue>
                ];
        <http://purl.org/dc/terms/description>
                "A sub-type of 'Enumerated Value'." .

<http://qudt.org/schema/qudt/fieldType>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Datatype> .

<http://qudt.org/schema/qudt/image>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty> , <http://www.w3.org/2002/07/owl#FunctionalProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype> .

<http://qudt.org/schema/qudt/EndianType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Endian Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://qudt.org/schema/qudt/informativeReference>
                "http://en.wikipedia.org/wiki/Endianness"^^<http://www.w3.org/2001/XMLSchema#anyURI>;
        <http://qudt.org/schema/qudt/plainTextDescription>
                "In computing, endianness is the ordering used to represent some kind of data as a sequence of smaller units. Typical cases are the order in which integer values are stored as bytes in computer memory (relative to a given memory addressing scheme) and the transmission order over a network or other medium. When specifically talking about bytes, endianness is also referred to simply as byte order.  Most computer processors simply store integers as sequences of bytes, so that, conceptually, the encoded value can be obtained by simple concatenation. For an 'n-byte' integer value this allows 'n!' (n factorial) possible representations (one for each byte permutation). The two most common of them are: increasing numeric significance with increasing memory addresses, known as little-endian, and its opposite, called big-endian." .

<http://qudt.org/schema/qudt/MultiDimensionalArray>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Multi-Dimensional Array Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Array>;
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Multi-Dimensional Array</em> is an extension of a standard one-dimensional array,\n   where elements are organized in a grid-like structure across two or more dimensions. \n  It is a collection of elements arranged in a tabular or multi-dimensional structure for representing complex datasets,\n   such as matrices, tensors, or higher-dimensional data.\n  </p>\n  <p>The elements of a multi-dimensional array are N-tuples, where 'N' corresponds to the dimensionality of the array.\n  Each element is specified using the property 'qudt:element'.\n  </p>\n  <p>Ordinary or one-dimensional arrays are indexed by a single integer. \n  For a multi-dimensional array, the index into the array uses an ordered list of integers, such as in 'a[3,1,5]'. \n  The length of the list of integers used to index into the multi-dimensional array is always the same.\n  This is referred to as the array's dimensionality. \n  The bounds on each of these are called the array's dimensions.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/BooleanType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Boolean Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/OrdinalType>;
        <http://purl.org/dc/terms/description>
                "A boolean data type can take on only two values." .

<http://qudt.org/schema/qudt/defaultValue>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Default Value";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/VisualCue> , <http://qudt.org/schema/qudt/ModalCue> , <http://qudt.org/schema/qudt/IconicCue> , <http://qudt.org/schema/qudt/KinestheticCue> , <http://qudt.org/schema/qudt/EnumeratedValue> , <http://qudt.org/schema/qudt/AuralCue> .

<http://qudt.org/schema/qudt/maxLength>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "max length";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#integer> .

<http://qudt.org/schema/qudt/coordinateSystemFrame>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "coordinate system frame" .

<http://qudt.org/schema/qudt/ModalCue>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Modal Cue";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/duration>
                ] .

<http://qudt.org/schema/qudt/allowedPattern>
        a       <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "allowed pattern";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#string>;
        <http://purl.org/dc/terms/description>
                "This property relates a date string encoding (c.f. type:DateStringEncodingType) to one or more XML Schema compliant regular expressions that together determine the allowed lexical expressions that can be unambiguously parsed to determine a temporal quantity." .

<http://qudt.org/schema/qudt/CardinalityType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Cardinality Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/dtype#literal>
                ];
        <http://purl.org/dc/terms/description>
                "\n  In mathematics, the cardinality of a set is a measure of the number of elements of the set.\n  For example, the set $A = {2, 4, 6}$ contains 3 elements, and therefore $A$ has a cardinality of 3. \n  There are two approaches to cardinality: one which compares sets directly using bijections and injections,\n   and another which uses cardinal numbers.\n  "^^<http://qudt.org/schema/qudt/LatexString>;
        <http://qudt.org/schema/qudt/informativeReference>
                "http://en.wikipedia.org/wiki/Cardinality"^^<http://www.w3.org/2001/XMLSchema#anyURI> , "http://en.wikipedia.org/wiki/Cardinal_number"^^<http://www.w3.org/2001/XMLSchema#anyURI>;
        <http://qudt.org/schema/qudt/plainTextDescription>
                "In mathematics, the cardinality of a set is a measure of the number of elements of the set.  For example, the set 'A = {2, 4, 6}' contains 3 elements, and therefore 'A' has a cardinality of 3. There are two approaches to cardinality – one which compares sets directly using bijections and injections, and another which uses cardinal numbers.";
        <http://www.w3.org/ns/prov#wasInfluencedBy>
                <http://en.wikipedia.org/wiki/Cardinal_number> , <http://en.wikipedia.org/wiki/Cardinality> .

<http://qudt.org/schema/qudt/RotatingReferenceFrame>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Rotating reference frame";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/ReferenceFrame>;
        <http://purl.org/dc/terms/description>
                "A sub-type of 'Reference Frame'." .

<http://qudt.org/schema/qudt/Vector>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Vector";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Array>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/quantity>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Vector</em> is an array data type that can have a dimensionality of one, or more elements.\n  Vectors can represent physical quantities, such as velocity, force, displacement;\n  mathematical objects such as points or directions in space;\n  and abstract representations for things such as colors, features, or embeddings in computational contexts.\n  </p>\n  <p>As a one-dimensional mathematical object it can represent a quantity with both magnitude and direction in space.\n  One-dimensional vectors can be thought of as a special case of a 1D array.\n  For example a 3D vector can be expressed as a list of coordinates: [x,y,z].\n  </p>\n  <p>\n  A vector in n-dimensional space can represent a point, a direction, or a linear combination of basis vectors.\n  </p>\n  <p>\n  Vectors can represent quantifiable values.\n  For example a car moving at 60 m/hr to the north, assuming north is along the y-axis, can be represented in 2D as:\n  </p>\n  <dl>\n  <dd>[0, 60]</dd>\n  </dl>\n  <p>\n  In machine learning a <em>Feature Vector</em> can be expressed for a dataset entry as:\n  <p>\n  <dl>\n  <dd>[5.1, 3.5, 1.4, 0.2]</dd>\n  </dl>\n  <p>\n  In AI for text processing a <em>Word Embedding Vector</em> is expressed as a N-dimensional space, where N can be a large number.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/ScalarDatatype>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Scalar Datatype";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://www.w3.org/2000/01/rdf-schema#Datatype>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/maxInclusive>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/byteOrder>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/bits>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/minInclusive>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/bitOrder>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/rdfsDatatype>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/bytes>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/maxExclusive>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/length>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/encoding>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/minExclusive>
                ];
        <http://www.linkedmodel.org/schema/vaem#isElaboratedIn>
                <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

<http://qudt.org/schema/qudt/float_Z>
        a       <http://www.w3.org/2002/07/owl#FunctionalProperty> , <http://www.w3.org/2002/07/owl#DatatypeProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "float Z";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://www.w3.org/2001/XMLSchema#float> .

<http://qudt.org/schema/qudt/hasQuantityKindsList>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "quantity kinds";
        <http://purl.org/dc/terms/description>
                "This property is used to specify a list of quantity kinds." .

<http://qudt.org/schema/qudt/CoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Coordinate system";
        <http://www.w3.org/2000/01/rdf-schema#seeAlso>
                <http://en.wikipedia.org/wiki/Astronomical_coordinate_systems> , <http://en.wikipedia.org/wiki/Coordinate_system> , <http://mathworld.wolfram.com/Coordinates.html> , <http://mathworld.wolfram.com/CoordinateSystem.html>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Concept> , <http://www.w3.org/2004/02/skos/core#Concept>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/abbreviation>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/referenceFrame>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/coordinateCenter>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/originDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://www.linkedmodel.org/schema/vaem#acronym>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>A <em>Coordinate System</em> is a mathematical structure for assigning a unique n-tuple of numbers or scalars to each point in an n-dimensional space. \n  A Coordinate System Type is a data type that defines the properties of data structures that represent coordinate systems.\n  </p>\n  <p>In geometry, a coordinate system is a system which uses one or more numbers, or coordinates,\n   to uniquely determine the position of a point or other geometric element on a manifold such as Euclidean space. \n  The order of the coordinates is significant.\n  They are sometimes identified by their position in an ordered tuple and sometimes by a letter, as in 'the x-coordinate'. \n  </p>\n  <p>In elementary mathematics the coordinates are taken to be real numbers, but may be complex numbers or elements of a more abstract system such as a commutative ring. \n  The use of a coordinate system allows problems in geometry to be translated into problems about numbers and vice versa; this is the basis of analytic geometry. \n  </p>\n  <p>In astronomy, a celestial coordinate system is a system for specifying positions of celestial objects: satellites, planets, stars, galaxies, and so on. \n  Coordinate systems can specify a position in 3-dimensional space, or merely the direction of the object on the celestial sphere, if its distance is not known or not important.\n  </p>\n  <p>The coordinate systems are implemented in either spherical coordinates or rectangular coordinates. \n  Spherical coordinates, projected on the celestial sphere, are analogous to the geographic coordinate system used on the surface of the Earth.\n  These differ in their choice of fundamental plane, which divides the celestial sphere into two equal hemispheres along a great circle.\n  </p>\n  <p>Rectangular coordinates, in appropriate units, are simply the cartesian equivalent of the spherical coordinates, with the same fundamental (x,y) plane and primary (x-axis) direction. \n  Each coordinate system is named for its choice of fundamental plane.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML>;
        <http://qudt.org/schema/qudt/dbpediaMatch>
                <http://dbpedia.org/resource/Coordinate_system> .

<http://qudt.org/schema/qudt/ValidateQuantityHasUnitShape>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype> , <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/qudt>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Validate Quantity has Unit Shape";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/quantity>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/hasUnit>
                ];
        <http://purl.org/dc/terms/description>
                "\n  <p>Specifies and checks an optional property for a quantified value.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/VehicleCoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Vehicle coordinate system";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/AerospaceCoordinateSystem>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/pitchRotationDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/rollRotationDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/rollRotationDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/yawRotationDefinition>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/yawRotationDefinition>
                ];
        <http://purl.org/dc/terms/description>
                "A sub-type of 'Aerospace coordinate system'." .

<http://qudt.org/schema/qudt/TwoTuple>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Two-Tuple";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/N-Tuple>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          0;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/elementDatatype>
                ];
        <http://purl.org/dc/terms/description>
                "\n  A 2-tuple is called a pair. \n  For example, a complex number can be represented as a 2-tuple.\n  2D coordinates are sometimes represented as 2-tuples.\n  " .

<http://qudt.org/schema/qudt/HomogeneousArray>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Homogeneous Array";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Array>;
        <http://purl.org/dc/terms/description>
                "\n  <p>An <em>Array></em> is a data structure that stores a collection of elements, typically of the same type, in a contiguous block of memory. \n  Each element in an array is identified by an index or key, which is typically a numerical identifier, either starting at '0' or '1'.\n  </p>\n  <p>The key considerations for an Array are:\n  </p>\n  <ol>\n  <li>Fixed Size: The size of an array may be pre-determined when it is created and cannot be changed;</li>\n  <li>Index-Based Access: Elements can be accessed, updated, or modified using their index;</li>\n  <li>Homogeneous Elements: all elements in an array must be of the same datatype;</li>\n  <li>Contiguous Memory Allocation: The elements are stored in consecutive memory locations, which allows efficient access using the index.</li>\n  </ol>\n  <p>An Array is represented as ordered entries of values arranged according to its dimensionality.\n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>The property 'qudt:datatype' refers to the datatype of the elements.  \n  </p>\n  <p>An array can be multi-dimensional.\n  Multiple indices are used but they are treated as extensions of the same structure.\n  For Example: for a 2D array arr[2][3], indices refer to the row and column positions.\n  A 2D array is still represented as a list, where each member of the list is a list.\n  </p>\n  <p>Higher dimensional arrays can be represented as nested lists.\n  For each dimension a new nested list is defined.\n  </p>"^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/SignedVariableLengthIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Variable Length Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/VariableLengthIntegerType> , <http://qudt.org/schema/qudt/SignedIntegerType>;
        <http://purl.org/dc/terms/description>
                "A Signed Variable Length Integer data type defines a data structure for representing signed integers that uses a variable number of bits depending on the magnitude of the integer. Typically, variable length integer data types are between one and 64 bits in length." .

<http://qudt.org/schema/qudt/TimeInterval>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Time interval";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Concept>;
        <http://purl.org/dc/terms/description>
                "A relative interval that is an increment in time. \n  For example, this is used in time series arrays to express the time point of a vector of values.\n  " .

<http://qudt.org/schema/qudt/datatype>
        a       <http://www.w3.org/2002/07/owl#ObjectProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "datatype";
        <http://www.w3.org/2000/01/rdf-schema#range>
                <http://qudt.org/schema/qudt/Datatype> , <http://qudt.org/schema/qudt/DataType>;
        <http://purl.org/dc/terms/description>
                "This property is used to relate a structured data type with the data type of the structured type's elements. It is used for homogeneous structured data types, that is, those whose elements that are all of the same type." .

<http://qudt.org/schema/qudt/TimeSeriesArray>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Time Series Array";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Array>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/incrementDatatype>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/incrementDatatype>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/incrementDatatype>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#minCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/vector>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#cardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/vector>
                ];
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                [ a       <http://www.w3.org/2002/07/owl#Restriction>;
                  <http://www.w3.org/2002/07/owl#maxCardinality>
                          1;
                  <http://www.w3.org/2002/07/owl#onProperty>
                          <http://qudt.org/schema/qudt/vector>
                ];
        <http://purl.org/dc/terms/description>
                "\n  A Time Series Array is a data type that specifies the properties of arrays that hold time series data. \n  A time series is a sequence of data points, measured at successive time intervals. \n  The time intervals may be uniformly or non-uniformly spaced.\n  " .

<http://qudt.org/schema/qudt/TrajectoryCoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Trajectory Coordinate System";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/AerospaceCoordinateSystem>;
        <http://purl.org/dc/terms/description>
                "A \"Coordinate System\"." .

<http://qudt.org/schema/qudt/SignedShortIntegerType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Signed Short Integer Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/SignedIntegerType> , <http://qudt.org/schema/qudt/ShortIntegerType>;
        <http://purl.org/dc/terms/description>
                "A Signed Short Integer is a signed integer that can be represented in four octets (32 bits) of machine memory." .

<http://qudt.org/schema/qudt/elementTypeList>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "element type list";
        <http://purl.org/dc/terms/description>
                "\n  This property is used to define the data type of the elements of a structured data type. \n  It is used for structured data types with elements that are of different types.\n  " .

<http://qudt.org/schema/qudt/AxialOrientationType>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Axial Orientation Type";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/EnumeratedValue>;
        <http://purl.org/dc/terms/description>
                "The axial orientation of a coordinate system frame axis." .

<http://qudt.org/schema/qudt/LocalCoordinateSystem>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Local Coordinate System";
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/TrajectoryCoordinateSystem>;
        <http://purl.org/dc/terms/description>
                "\n  A \"Trajectory Coordinate System\" with the following instance(s):\n   \"Local vertical curvilinear coordinate system\",\n   \"Local vertical local horizontal coordinate system\",\n   \"Vehicle centered local vertical curvilinear coordinate system\".\n  " .

<http://qudt.org/schema/qudt/AssociativeArray>
        a       <http://www.w3.org/2002/07/owl#Class>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        <http://www.w3.org/2000/01/rdf-schema#label>
                "Associative Array";
        <http://www.w3.org/2000/01/rdf-schema#seeAlso>
                <http://qudt.org/schema/qudt/Map>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                <http://qudt.org/schema/qudt/Array>;
        <http://purl.org/dc/terms/description>
                "\n  <p>An <em>Associative Array</em> (or <em>Map</em>) is an abstract data type composed of a collection of keys and a collection of values,\n   where each key is associated with one value. \n  The operation of finding the value associated with a key is called a lookup or indexing,\n   and this is the most important operation supported by an associative array.\n  The relationship between a key and its value is sometimes called a mapping or binding.\n  </p>\n  "^^<http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML> .

<http://qudt.org/schema/qudt/significantDigits>
        a       <http://www.w3.org/2002/07/owl#AnnotationProperty>;
        <http://www.w3.org/2000/01/rdf-schema#isDefinedBy>
                <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
