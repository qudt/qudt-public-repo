        dcterms:description            "<p>This OWL schema is derived from the SHACL schema found at http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype. </p>"^^rdf:HTML;
        dcterms:modified               "1234-12-12T12:34:56Z"^^xsd:dateTime;
        dcterms:rights                 "\n  <p>The QUDT Ontologies are issued under a Creative Commons Attribution 4.0 International License (CC BY 4.0), available  <a href=\"https://creativecommons.org/licenses/by/4.0/\">here</a>. \n  Attribution should be made to <a href=\"https://www.qudt.org\">QUDT.org</a>.\n  </p>"^^rdf:HTML;
        dcterms:subject                "Datatypes";
        vaem:graphTitle                "QUDT Schema for Datatypes - Version $$QUDT_VERSION$$";
        vaem:hasGraphRole              vaem:SchemaGraph;
        vaem:isMetadataFor             <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        vaem:latestPublishedVersion    "https://qudt.org/doc/$$CURRENT_YEAR$$/$$CURRENT_MONTH$$/DOC_SCHEMA-DATATYPES.html"^^xsd:anyURI;
        vaem:logo                      "https://qudt.org/linkedmodels.org/assets/lib/lm/images/logos/qudt_logo-300x110.png"^^xsd:anyURI;
        vaem:name                      "QUDT";
        vaem:namespace                 "http://qudt.org/schema/qudt/"^^xsd:anyURI;
        vaem:namespacePrefix           "qudt";
        vaem:owner                     "QUDT.ORG";
        vaem:previousPublishedVersion  "https://qudt.org/doc/$$QUDT_PREV_RELEASE_YEAR$$/$$QUDT_PREV_RELEASE_MONTH$$/DOC_SCHEMA-DATATYPES.html"^^xsd:anyURI;
        vaem:publishedDate             "2017-05-10"^^xsd:date;
        vaem:releaseDate               "2016-05-09"^^xsd:date;
        vaem:title                     "QUDT Schema for Datatypes - Version $$QUDT_VERSION$$";
        vaem:turtleFileURL             "http://qudt.org/$$QUDT_VERSION$$/schema/datatype.ttl"^^xsd:anyURI;
        vaem:usesNonImportedResource   coords:PositiveX , datatype:CharEncoding , datatype:UTF8-CHAR , datatype:CT_COUNTABLY-INFINITE , coords:NegativeY , coords:FT_INERTIAL , datatype:BigEndian , dcterms:creator , datatype:SignedIntegerEncoding , coords:PositiveY , dcterms:rights , datatype:LittleEndian , coords:CCT_VehicleCentered , dcterms:created , coords:NegativeZ , datatype:CT_FINITE , datatype:WordAligned , datatype:TIME , datatype:CT_UNCOUNTABLE , coords:CCT_MoonCentered , dcterms:abstract , coords:PositiveZ , datatype:PadWithOnes , datatype:ShortUnsignedIntegerEncoding , datatype:TotallyOrdered , datatype:UTF16-CHAR , datatype:BooleanEncoding , datatype:LongSignedIntegerEncoding , datatype:Unordered , datatype:ByteAligned , coords:CCT_EarthCentered , coords:FT_ROTATING , datatype:BitEncoding , <http://voag.linkedmodel.org/voag#QUDT-Attribution> , datatype:Signed , datatype:PartiallyOrdered , datatype:Major , datatype:ByRow , datatype:PadWithAny , datatype:Minor , datatype:UnsignedIntegerEncoding , datatype:Unsigned , dcterms:title , datatype:BitAligned , dcterms:modified , coords:FT_NON-ROTATING , datatype:PadWithZeros , datatype:OctetEncoding , coords:NegativeX , datatype:ByLeftMostIndex , coords:CCT_MarsCentered , datatype:ShortSignedIntegerEncoding , coords:CCT_SunCentered , datatype:LongUnsignedIntegerEncoding , datatype:ByColumn;
        vaem:withAttributionTo         <http://voag.linkedmodel.org/voag#QUDT-Attribution>;
        prov:derivedFrom               <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

dcterms:contributor  rdf:type  owl:AnnotationProperty;
        rdfs:label  "contributor" .

dcterms:creator  rdf:type  owl:AnnotationProperty;
        rdfs:label  "creator" .

dcterms:description  rdf:type  owl:AnnotationProperty;
        rdfs:label  "description" .

dcterms:rights  rdf:type  owl:AnnotationProperty;
        rdfs:label  "rights" .

dcterms:subject  rdf:type  owl:AnnotationProperty;
        rdfs:label  "subject" .

dcterms:title  rdf:type  owl:AnnotationProperty;
        rdfs:label  "title" .

dtype:literal  rdf:type  owl:DatatypeProperty;
        rdfs:range  xsd:string .

dtype:value  rdf:type  owl:ObjectProperty;
        rdfs:range  qudt:EnumeratedValue .

qudt:AbstractDatatype
        rdf:type              owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Abstract Datatype";
        rdfs:subClassOf       qudt:StructuredDatatype;
        dcterms:description   "\n  <p>An \"Abstract Datatype\" (ADT) is a specification of a set of data and the set of operations that can be performed on the data. \n  Such a data type is abstract in the sense that it is independent of various concrete implementations. \n  The definition can be mathematical, or it can be programmed as an interface. \n  A first class ADT supports the creation of multiple instances of the ADT, and the interface normally provides a constructor,\n   which returns an abstract handle to new data, and several operations, \n   which are functions accepting the abstract handle as an argument.</p>\n  "^^rdf:HTML;
        prov:wasInfluencedBy  <http://en.wikipedia.org/wiki/Abstract_data_type> , <http://xlinux.nist.gov/dads/HTML/abstractDataType.html> .

qudt:accuracy  rdf:type      owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "accuracy";
        rdfs:range           xsd:integer;
        dcterms:description  "\n  <p><em>Accuracy</em> is the degree to which a given quantity is correct and free from error. \n  For example, a quantity specified as 100+/-1 has an (absolute) accuracy of +/-1 (meaning its true value can fall in the range 99-101),\n   while a quantity specified as 100+/-2% has a (relative) accuracy of +/-2% (meaning its true value can fall in the range 98-102).\n  </p>\n  <p>The concepts of accuracy and precision are both closely related and often confused. \n  While the accuracy of a number x is given by the number of significant decimal (or other) digits to the right of the decimal point in x,\n   the precision of x is the total number of significant decimal (or other) digits.\n  </p>\n  "^^rdf:HTML .

qudt:AlgebraicDatatype
        rdf:type              owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Algebraic Datatype";
        rdfs:seeAlso          qudt:AbstractDatatype;
        rdfs:subClassOf       qudt:StructuredDatatype;
        dcterms:description   "<p>An <em>Algebraic Datatype</em> is a datatype each of whose values are data from other data types wrapped in one of the constructors of the data type. \nAny wrapped datum is an argument to the constructor. \nIn contrast to other data types, the constructor is not executed and the only way to operate on the data is to unwrap the constructor using pattern matching.\n</p>\n<p>The most common algebraic data type is a list with two constructors: Nil or [] for an empty list, and Cons (an abbreviation of constructor), \n ::, or : for the combination of a new element with a shorter list (for example (Cons 1 '(2 3 4)) or 1:[2,3,4]).\n</p>\n<p>Special cases of algebraic types are product types i.e. records (only one constructor) and enumerated types (many constructors with no arguments). \nAlgebraic types are one kind of composite type (i.e. a type formed by combining other types).\n</p>\n<p>An algebraic data type may also be an abstract data type (ADT) if it is exported from a module without its constructors. \nValues of such a type can only be manipulated using functions defined in the same module as the type itself.\n</p>"^^rdf:HTML;
        prov:wasInfluencedBy  <http://en.wikipedia.org/wiki/Algebraic_data_type> .

qudt:AlignmentType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Alignment type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "\n  Specifies how a physical data field is aligned. \n  The alignment could be at a bit, byte or word boundary.\n  ";
        owl:oneOf            ( datatype:BitAligned datatype:ByteAligned datatype:WordAligned ) .

qudt:alignment  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "alignment";
        rdfs:range        qudt:AlignmentType .

qudt:allowedPattern  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "allowed pattern";
        rdfs:range           xsd:string;
        dcterms:description  "This property relates a date string encoding (c.f. type:DateStringEncodingType) to one or more XML Schema compliant regular expressions that together determine the allowed lexical expressions that can be unambiguously parsed to determine a temporal quantity." .

qudt:ansiSQLName  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "ANSI SQL name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:arg1Type  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "arg1Type";
        rdfs:subPropertyOf   qudt:argType;
        dcterms:description  "This property relates a funciton data type with the type of its arg1." .

qudt:arg2Type  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "arg2Type";
        rdfs:subPropertyOf   qudt:argType;
        dcterms:description  "This property relates a funciton data type with the type of its arg2." .

qudt:arg3Type  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "arg3Type";
        rdfs:subPropertyOf   qudt:argType;
        dcterms:description  "This property relates a funciton data type with the type of its arg3." .

qudt:argType  rdf:type       owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "argType";
        rdfs:range           qudt:Datatype;
        rdfs:subPropertyOf   qudt:elementDatatype;
        dcterms:description  "This property relates a function data type with the type of one of its arguments." .

qudt:Array2DvalueList
        rdf:type             owl:Class;
        rdf:first            qudt:List;
        rdf:rest             ( qudt:List );
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "2D Array Value List";
        rdfs:subClassOf      qudt:List;
        dcterms:description  "\n  An rdf:List for a 2D array.\n  For example \"[[1,2], [3,4], [5,6]]\"\n  " .

qudt:ArrayDataOrder  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Array data order";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "A sub-type of 'Enumerated Value'. Detailed description to be provided in a future version.";
        owl:oneOf            ( datatype:ByColumn datatype:ByRow datatype:ByLeftMostIndex ) .

qudt:ArrayType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Array Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  <p>An <em>Array Type</em> is a type specification for ordered entries of values arranged according to the dimensions given. \n  The dimensions are given as a list of integers where each integer is the cardinality of each dimension. \n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>Optionally a reference can be made to a variable, whose values are the array entries. \n  The data type of the array entries is an optional field, 'elementType', which points to a data type definition. \n  If the data type is given, then it applies to all elements.  \n  If it is not given then the elements can be of different types for each position in the array.\n  </p>\n  <p>The property <em>qudt:typeMatrix</em> must refer to a matrix of types.\n  If a default value is given this can be used to place the appropriate value in a cell when an entry value is not known. \n  If no dimensionality or dimension vector is specified the array is under-specified but still legitimate as a place-holder for a data type.\n  </p>"^^rdf:HTML .

qudt:Array  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Array";
        rdfs:subClassOf      qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:isHeterogeneous
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:dimensionality
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        dcterms:description  "\n  <p>An <em>Array></em> is a data structure that stores a collection of elements, typically of the same type, in a contiguous block of memory. \n  Each element in an array is identified by an index or key, which is typically a numerical identifier, either starting at '0' or '1'.\n  </p>\n  <p>The key considerations for an Array are:\n  </p>\n  <ol>\n  <li>Fixed Size: The size of an array may be pre-determined when it is created and cannot be changed;</li>\n  <li>Index-Based Access: Elements can be accessed, updated, or modified using their index;</li>\n  <li>Contiguous Memory Allocation: The elements are stored in consecutive memory locations, which allows efficient access using the index.</li>\n  </ol>\n  <p>An Array is represented as ordered entries of values arranged according to its dimensionality.\n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>An array can be multi-dimensional.\n  Multiple indices are used but they are treated as extensions of the same structure.\n  For Example: for a 2D array arr[2][3], indices refer to the row and column positions.\n  A 2D array is still represented as a list, where each member of the list is a list.\n  </p>\n  <p>Higher dimensional arrays can be represented as nested lists.\n  For each dimension a new nested list is defined.\n  </p>"^^rdf:HTML .

qudt:AssociativeArray
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Associative Array";
        rdfs:seeAlso         qudt:Map;
        rdfs:subClassOf      qudt:Array;
        dcterms:description  "\n  <p>An <em>Associative Array</em> (or <em>Map</em>) is an abstract data type composed of a collection of keys and a collection of values,\n   where each key is associated with one value. \n  The operation of finding the value associated with a key is called a lookup or indexing,\n   and this is the most important operation supported by an associative array.\n  The relationship between a key and its value is sometimes called a mapping or binding.\n  </p>\n  "^^rdf:HTML .

qudt:auralCueEnumeration
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "aural cue enumeration";
        rdfs:subPropertyOf  qudt:modalCueEnumeration .

qudt:AuralCue  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Aural Cue";
        rdfs:subClassOf      qudt:ModalCue;
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:sound
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:sound
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:sound
                             ];
        dcterms:description  "\n  <p>An aural cue is a sound produced by a device or a system that is used to alert personnel of of an advisory, cautionary, warning, or emergency state.\n  </p>"^^rdf:HTML .

qudt:auralCue  rdf:type     owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "aural cue";
        rdfs:subPropertyOf  qudt:modalCue .

qudt:BalancedTree  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Balanced Tree Type";
        rdfs:subClassOf      qudt:Tree;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxDepth
                             ];
        dcterms:description  "\n  <p>A <em>Balanced Tree</em> is a data type that defines the properties of data structures that represent balanced trees. \n  A balanced tree is a tree where no leaf is much farther away from the root than any other leaf. \n  Different balancing schemes allow different definitions of \"much farther\" and different amounts of work to keep them balanced.\n  </p>\n  "^^rdf:HTML .

qudt:base  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "base";
        rdfs:range        xsd:integer .

qudt:basis  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "basis";
        rdfs:range        qudt:Datatype , qudt:QuantityType .

qudt:BigIntegerType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Big Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  <p>A <em>Big Integer</em> is an integer that can be represented in eight octets (64 bits) of machine memory. \n  Big integers may be signed or unsigned.\n  </p>\n  "^^rdf:HTML .

qudt:BinaryTree  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Binary Tree Type";
        rdfs:subClassOf      qudt:Tree;
        dcterms:description  "\n  <p>A <em>Binary Tree</em> is a data type that defines the properties of data structures that represent binary trees. \n  A binary tree is a tree in which each node has at most 2 children.\n  </p>"^^rdf:HTML .

qudt:BitEncodingType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Bit Encoding";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "\n  <p>A <em>Bit Encoding Type</em> is an encoding type for the correspondence between the two possible values of a bit, 0 or 1, and some interpretation. \n  For example, in a boolean encoding, a bit denotes a truth value, where 0 corresponds to False and 1 corresponds to True.\n  </p>"^^rdf:HTML;
        owl:oneOf            ( datatype:BitEncoding ) .

qudt:BitField  rdf:type      rdfs:Datatype;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      xsd:string;
        dcterms:description  "\n  <p>A bit field is a common idiom used in computer programming to store a set of Boolean datatype flags compactly, as a series of bits. \n  The bit field is stored in an integral type of known, fixed bit-width. \n  Each Boolean flag is stored in a separate bit. \n  Usually the source code will define a set of constants, each a power of two, that semantically associate each individual bit with its respective Boolean flag. \n  The bitwise operators and, or, and not are used in combination to set, reset and test the flags.\n  </p>\n  "^^rdf:HTML .

qudt:bitOrder  rdf:type   owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "bit order";
        rdfs:range        qudt:EndianType .

qudt:bits  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "bits";
        rdfs:range        xsd:integer .

qudt:BooleanEncodingType
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Boolean Encoding Type";
        rdfs:subClassOf   qudt:Encoding;
        owl:oneOf         ( datatype:BooleanEncoding datatype:BitEncoding datatype:OctetEncoding ) .

qudt:BooleanTypeEnumeratedValue
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "boolean value";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "Specifies how a boolean value is expressed" .

qudt:BooleanType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Boolean Type";
        rdfs:subClassOf      qudt:OrdinalType;
        dcterms:description  "A boolean data type can take on only two values." .

qudt:bounded  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "bounded";
        rdfs:range           xsd:boolean;
        dcterms:description  "A datatype is bounded if its value space has either a finite upper and lower bound. Either bound may be inclusive or exclusive. " .

qudt:byRow  rdf:type      owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "by row";
        rdfs:range        xsd:boolean .

qudt:ByteEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Byte Encoding";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "This class contains the various ways that information may be encoded into bytes." .

qudt:byteOrder  rdf:type     owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "byte order";
        rdfs:range           qudt:EndianType;
        dcterms:description  "Byte order is an enumeration of two values: 'Big Endian' and 'Little Endian' and is used to denote whether the most signiticant byte is either first or last, respectively." .

qudt:bytes  rdf:type      owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "bytes";
        rdfs:range        xsd:integer .

qudt:CardinalityType  rdf:type     owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label                 "Cardinality Type";
        rdfs:subClassOf            qudt:EnumeratedValue;
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      dtype:literal
                                   ];
        dcterms:description        "\n  In mathematics, the cardinality of a set is a measure of the number of elements of the set.\n  For example, the set $A = {2, 4, 6}$ contains 3 elements, and therefore $A$ has a cardinality of 3. \n  There are two approaches to cardinality: one which compares sets directly using bijections and injections,\n   and another which uses cardinal numbers.\n  "^^qudt:LatexString;
        qudt:informativeReference  "https://en.wikipedia.org/wiki/Cardinal_number"^^xsd:anyURI , "https://en.wikipedia.org/wiki/Cardinality"^^xsd:anyURI;
        qudt:plainTextDescription  "In mathematics, the cardinality of a set is a measure of the number of elements of the set.  For example, the set 'A = {2, 4, 6}' contains 3 elements, and therefore 'A' has a cardinality of 3. There are two approaches to cardinality – one which compares sets directly using bijections and injections, and another which uses cardinal numbers.";
        owl:oneOf                  ( datatype:CT_COUNTABLY-INFINITE datatype:CT_UNCOUNTABLE datatype:CT_FINITE );
        prov:wasInfluencedBy       <http://en.wikipedia.org/wiki/Cardinal_number> , <http://en.wikipedia.org/wiki/Cardinality> .

qudt:cardinality  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "cardinality";
        rdfs:range        qudt:CardinalityType .

qudt:CharacterType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Character Type";
        rdfs:subClassOf      qudt:OrdinalType;
        dcterms:description  "\n  A <em>Character Type</em> is a data type that defines the type and encoding of single characters.\n  " .

qudt:CharEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Char Encoding Type";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "The class of all character encoding schemes, each of which defines a rule or algorithm for encoding character data as a sequence of bits or bytes." , "\n  <p>The class of all character encoding schemes.\n  Each defines a rule or algorithm for encoding character data as a sequence of bits or bytes.\n  </p>"^^rdf:HTML;
        owl:oneOf            ( datatype:CharEncoding ) .

qudt:cName  rdf:type         owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "C Language name" , "C name";
        rdfs:range           xsd:string;
        rdfs:subPropertyOf   qudt:id;
        dcterms:description  "Datatype name in the C programming language" .

qudt:Collection  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Collection Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        dcterms:description  "\n  <p>A collection is a grouping of some variable number of zero or more data items that need to be operated upon together in some controlled fashion. \n  Generally, the data items will all share the same data type or are derived from some common ancestor data type.\n  </p>"^^rdf:HTML .

qudt:ColorCue  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Color Cue";
        rdfs:subClassOf      qudt:VisualCue;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:rgbCode
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:rgbCode
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:rgbCode
                             ];
        dcterms:description  "\n  <p>A visual cue that uses color to distinguish it from other cues. \n  Each color cue has exactly one corresponding coordinate point in the RGB space.\n  </p>"^^rdf:HTML .

qudt:columns  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "columns";
        rdfs:range        xsd:integer .

qudt:CompositeDataStructure
        rdf:type              owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Composite Data Structure";
        rdfs:subClassOf       qudt:CompositeDatatype;
        dcterms:description   "\n  <p>A <em>Composite Data Structure</em>, also referred to as <em>Data Record</em> is a datatype that aggregates element of possibly different types. \n  The aggregated items are called fields or members and are usually identified or indexed by field labels.\n  </p>"^^rdf:HTML;
        prov:wasInfluencedBy  <https://en.wikipedia.org/wiki/List_of_data_structures> , <https://en.wikipedia.org/wiki/Record_(computer_science)> .

qudt:CompositeDatatype
        rdf:type              owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Composite Data Type";
        rdfs:subClassOf       qudt:StructuredDatatype;
        rdfs:subClassOf       [ rdf:type            owl:Restriction;
                                owl:maxCardinality  1;
                                owl:onProperty      qudt:padding
                              ];
        dcterms:description   "\n  <p>A <em>Composite Datatype</em> is a datatype that is constructed from basic primitive types and other composite types. \n  </p>"^^rdf:HTML;
        prov:wasInfluencedBy  <https://en.wikipedia.org/wiki/List_of_data_structures> .

qudt:CompositeTable  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Composite Table Type";
        rdfs:subClassOf      qudt:Table;
        dcterms:description  "A sub-type of 'Table Type'." .

qudt:CompositionFunction
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Composition function";
        rdfs:subClassOf   qudt:Function .

qudt:CompositionTree  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Composition Tree";
        rdfs:subClassOf   qudt:Tree;
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  1;
                            owl:onProperty      qudt:function
                          ];
        rdfs:subClassOf   [ rdf:type         owl:Restriction;
                            owl:cardinality  1;
                            owl:onProperty   qudt:function
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  1;
                            owl:onProperty      qudt:function
                          ] .

qudt:CRC32  rdf:type      rdfs:Datatype;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "CRC-32";
        rdfs:subClassOf   xsd:integer .

qudt:DataEncoding  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Data Encoding";
        rdfs:subClassOf      qudt:Aspect;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bitOrder
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:encoding
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:byteOrder
                             ];
        dcterms:description  "\n  <p><em>Data Encoding</em> expresses the properties that specify how data is represented at the bit and byte level. \n  These properties are applicable to describing raw data.\n  </p>"^^rdf:HTML .

qudt:dataEncoding  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "data encoding";
        rdfs:range        qudt:DataEncoding .

qudt:dataOrder  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "data order";
        rdfs:range        qudt:MatrixElementOrder .

qudt:DataSetElement  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "QUDT DataSet Element";
        rdfs:subClassOf      qudt:Tuple , qudt:DataItem;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:optional
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:elementLabel
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:elementLabel
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:elementLabel
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:hasQuantityKind
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:optional
                             ];
        dcterms:description  "\n  A field is a tuple that carries a name, a type and optionally other properties that characterize a member element of a composite data structure.\n  " .

qudt:Datatype  rdf:type            owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label                 "Datatype";
        rdfs:subClassOf            qudt:Concept;
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:pythonName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:cName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:ansiSQLName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:cName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:microsoftSQLServerName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:javaName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:matlabName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:cardinality
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:matlabName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:bounded
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:pythonName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:jsName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:vbName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:basis
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:oracleSQLName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:microsoftSQLServerName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:ansiSQLName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:orderedType
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:odbcName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:mySQLName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:protocolBuffersName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:id
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:vbName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:javaName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:oleDBName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:oleDBName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:oracleSQLName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:protocolBuffersName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:maxCardinality  1;
                                     owl:onProperty      qudt:jsName
                                   ];
        rdfs:subClassOf            [ rdf:type            owl:Restriction;
                                     owl:minCardinality  0;
                                     owl:onProperty      qudt:odbcName
                                   ];
        dcterms:description        "\n  <p>A <em>Datatype</em> is a definition of the type of the \"value\" of a data item (for example, \"all integers between 0 and 10\"),\n   and the allowable operations on those values; the meaning of the data; and the way values of that type can be stored.\n  Some types are primitive - built-in to the language, with no visible internal structure.\n  For example \"Boolean\"; others are composite - constructed from one or more other types (of either kind).\n  For example lists, arrays, structures, unions.\n  Some languages provide strong typing, others allow implicit type conversion and/or explicit type conversion.\n  </p>"^^rdf:HTML;
        qudt:informativeReference  "http://foldoc.org/data+type"^^xsd:anyURI , "http://www.princeton.edu/~achaney/tmve/wiki100k/docs/Data_type.html"^^xsd:anyURI , "https://en.wikipedia.org/wiki/Data_type"^^xsd:anyURI .

qudt:datatype  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "datatype";
        rdfs:range           qudt:Datatype;
        dcterms:description  "This property is used to relate a structured data type with the data type of the structured type's elements. It is used for homogeneous structured data types, that is, those whose elements that are all of the same type." .

qudt:DateStringType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Date String Type";
        rdfs:subClassOf      qudt:DateTimeStringType;
        dcterms:description  "Date String Types are scalar data types that define the properties of strings that represent calendar dates." .

qudt:DateTimeStringEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Date Time String Encoding Type";
        rdfs:subClassOf      qudt:StringEncodingType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:allowedPattern
                             ];
        dcterms:description  "Date Time encodings are logical encodings for expressing date/time quantities as strings by applying unambiguous formatting and parsing rules." .

qudt:DateTimeStringType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Temporal Type";
        rdfs:subClassOf      qudt:StringType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:encoding
                             ];
        dcterms:description  "\n  <p>A class of data types for structures that represent temporal quantities.\n  For example, calendar dates, times, duration of time since a given epoch, etc.\n  </p>"^^rdf:HTML .

qudt:DateTypeUnion  rdf:type  qudt:List;
        rdf:first            xsd:date;
        rdf:rest             ( xsd:dateTime xsd:gYear xsd:gMonth );
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Date Type Union";
        dcterms:description  "\n  An rdf:List that can be used in property constraints as the type in an sh:or to indicate\n   that all values of a property must be an xsd date type.\n  " .

qudt:defaultValue  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Default Value";
        rdfs:range        qudt:VisualCue , qudt:ModalCue , qudt:IconicCue , qudt:KinestheticCue , qudt:EnumeratedValue , qudt:AuralCue .

qudt:descriptor  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "descriptor" .

qudt:Dictionary  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Dictionary Type";
        rdfs:subClassOf      qudt:Map;
        dcterms:description  "A \"Map\"." .

qudt:DimensionalDatatype
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Dimensional Data Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        dcterms:description  "\n  <p>A <em>Dimensional Data Type</em> is a data type that specifies a physical quantity or unit of measure.\n  Information about the physical dimensions of the quantities and units is embedded in their types.\n  </p>\n  "^^rdf:HTML .

qudt:dimensionality  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "dimensionality";
        rdfs:range           xsd:integer;
        dcterms:description  "\n  The number of dimensions making up a matrix or an array. \n  For example a 4 by 4 array has a dimensionality of 2. \n  Whereas a vector or a string has a dimensionality of 1.\n  " .

qudt:dimensions  rdf:type    owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "dimensions";
        rdfs:range           qudt:List;
        dcterms:description  "\n  The extent of each dimension making up an array or matrix.\n  Dimensions are expressed as an integer list.\n  For example a 4 by 4 array has dimensions (4 4), whereas a vector or a string has dimensions (1).\n  " .

qudt:DiscreteState  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Discrete State";
        rdfs:subClassOf      qudt:EnumeratedValue;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:inverted
                             ];
        dcterms:description  "\n  <p>A <em>Discrete State</em> is the parent class for enumerated values that express a 'State' or 'Condition'.\n  Examples are 'on' and 'off for a switch, 'open' and 'closed' for a valve, and 'wet' and 'dry'.\n  </p>\n  "^^rdf:HTML .

qudt:double_X  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "double X" .

qudt:double_Y  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "double Y" .

qudt:double_Z  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "double Z" .

qudt:DoublePrecisionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Double Precision Type";
        rdfs:subClassOf      qudt:NumericType;
        dcterms:description  "\n  <p>A double precision data type specifies how a numeric value, such as an integer or real number, is stored in memory.\n  Typically this occupies two words in computer memory, where the byte length of a word depends on machine address size of the computer processor. \n  For example, on 32-bit machine architectures, a word is four bytes, and so double precision data value on a 32-bit machine architecture occupies eight bytes of memory.\n  </p>"^^rdf:HTML .

qudt:duration  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "duration" .

qudt:elementDatatype  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element datatype";
        rdfs:range           qudt:RealSinglePrecisionType , qudt:TupleMember , qudt:Datatype , qudt:ScalarDatatype , qudt:UnsignedIntegerType , qudt:CharacterType , qudt:NumericType;
        dcterms:description  "\n  This property is used to relate a structured data type with the data type the structured type's elements. \n  It is used for structured data types with elements that are all of the same type.\n  " .

qudt:elementKind  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element kind";
        rdfs:subPropertyOf   qudt:elementKind;
        dcterms:description  "This property is used to describe the quantity kind for a dimensional data type." .

qudt:elementLabel  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element label";
        rdfs:range           xsd:string;
        dcterms:description  "This property is used to label the field of a composite data structure." .

qudt:elementName  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "element name";
        rdfs:range        xsd:string .

qudt:elementTypeCount
        rdf:type             owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element type count";
        rdfs:range           xsd:integer;
        dcterms:description  "This property determines the allowed number of element types that a structured data type may have." .

qudt:elementTypeList  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "element type list";
        dcterms:description  "\n  This property is used to define the data type of the elements of a structured data type. \n  It is used for structured data types with elements that are of different types.\n  " .

qudt:elementUnit  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "element unit";
        rdfs:range        qudt:Unit .

qudt:Encoding  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Encoding";
        rdfs:subClassOf      skos:Concept;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bits
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bytes
                             ];
        dcterms:description  "\n  <p>An encoding is a rule or algorithm that is used to convert data from a native, or unspecified form into a specific form that satisfies the encoding rules. \n  Examples of encodings include character encodings, such as UTF-8.\n  </p>"^^rdf:HTML .

qudt:encoding  rdf:type   owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "encoding";
        rdfs:range        qudt:BooleanEncodingType , qudt:DateTimeStringEncodingType , qudt:Encoding .

qudt:EndianType  rdf:type          owl:Class;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label                 "Endian Type";
        rdfs:subClassOf            qudt:EnumeratedValue;
        qudt:informativeReference  "https://en.wikipedia.org/wiki/Endianness"^^xsd:anyURI;
        qudt:plainTextDescription  "In computing, endianness is the ordering used to represent some kind of data as a sequence of smaller units. Typical cases are the order in which integer values are stored as bytes in computer memory (relative to a given memory addressing scheme) and the transmission order over a network or other medium. When specifically talking about bytes, endianness is also referred to simply as byte order.  Most computer processors simply store integers as sequences of bytes, so that, conceptually, the encoded value can be obtained by simple concatenation. For an 'n-byte' integer value this allows 'n!' (n factorial) possible representations (one for each byte permutation). The two most common of them are: increasing numeric significance with increasing memory addresses, known as little-endian, and its opposite, called big-endian.";
        owl:oneOf                  ( datatype:LittleEndian datatype:BigEndian ) .

qudt:EngineeringValueTupleMember
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Engineering Value Tuple Member";
        rdfs:subClassOf      qudt:TupleMember;
        dcterms:description  "\n  <p>A sub-type of 'Tuple Member Type'. \n  </p>"^^rdf:HTML .

qudt:EnumerationScale
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Enumeration scale";
        rdfs:subClassOf      qudt:Scale , dtype:Enumeration;
        dcterms:description  "\n  A sub-type of 'DTYPE Enumeration'.\n  " .

qudt:Enumeration  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "QUDT Enumeration";
        rdfs:subClassOf      dtype:Enumeration , qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:encoding
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bits
                             ];
        vaem:isElaboratedIn  <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

qudt:enumeration  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "enumeration" .

qudt:exponent  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "exponent" .

qudt:fieldLabels  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "field labels";
        dcterms:description  "This property is used to list the field labels for a record type." .

qudt:fieldLabel  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "field label";
        rdfs:range        xsd:string .

qudt:fieldName  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "field name" .

qudt:FieldType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Field Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:fieldType
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:elementName
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:elementName
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:elementName
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:fieldLabel
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:fieldLabel
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:fieldLabel
                             ];
        dcterms:description  "\n  A sub-type of 'Composite Data Type'.\n  " .

qudt:fieldType  rdf:type    owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "field type";
        rdfs:range          qudt:Datatype;
        rdfs:subPropertyOf  qudt:elementDatatype .

qudt:field  rdf:type      owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "field";
        rdfs:range        qudt:DataSetElement .

qudt:FileFormat  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "File format";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "\n  A sub-type of 'Enumerated Value'.\n  " .

qudt:FixedIntervalTimeSeriesArrayType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Fixed Interval Time Series Array Type";
        rdfs:subClassOf      qudt:TimeSeriesArrayType;
        dcterms:description  "<p>A <em>Fixed Interval Time Series Array Type</em> is a data type that specifies the properties of arrays that hold time series data.\n For example, data that has been sampled over uniformly spaced time intervals. \n A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals.\n </p>"^^rdf:HTML .

qudt:FixedIntervalTimeSeriesArray
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Fixed Interval Time Series Array Type";
        rdfs:subClassOf      qudt:TimeSeriesArray;
        dcterms:description  "\n  <p>A <em>Fixed Interval Time Series Array Type</em> is a data type that specifies the properties of arrays that hold time series data.\n  For example, data that has been sampled over uniformly spaced time intervals.\n  A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals.\n  </p>"^^rdf:HTML .

qudt:FloatingPointEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Floating Point Encoding";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "\n  <p>A type for specifying an \"Encoding\" with the following instance(s): \n  \"Double Precision Encoding\", and \"Single Precision Real Encoding\".\n  </p>"^^rdf:HTML , "\n  A \"Encoding\" with the following instance(s): \"Double Precision Encoding\", \"Single Precision Real Encoding\".\n  " .

qudt:frameType  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "frame type" .

qudt:functionArity  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "function arity";
        rdfs:range           xsd:integer;
        dcterms:description  "This property is used to state the number of arguments for a function type." .

qudt:FunctionDatatype
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Function Data Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:returnType
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:functionArity
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:functionArity
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:returnType
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:functionArity
                             ];
        dcterms:description  "\n  <p>A function data type defines the input and output data type for a function or method. \n  The data type includes at least the function name and the number of its parameters. \n  In some programming languages, it may also specify the function's return type or the types of its arguments.\n  </p>"^^rdf:HTML .

qudt:Function  rdf:type   owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Function";
        rdfs:subClassOf   qudt:Concept .

qudt:function  rdf:type   owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "function";
        rdfs:range        qudt:CompositionFunction .

qudt:Graph  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Graph Type";
        rdfs:subClassOf      qudt:DataItem;
        dcterms:description  "\n  <p>A <em>Graph</em> is an instance of a kind of abstract data type, that consists of a set of nodes (also called vertices) and a set of edges that establish relationships (connections) between the nodes. \n  A Graph Type is a data type that defines the properties of data structures that represent graphs and their members (nodes and edges).\n  </p>"^^rdf:HTML .

qudt:hasQuantityKindsList
        rdf:type             owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "quantity kinds";
        rdfs:range           qudt:List;
        dcterms:description  "This property is used to specify a list of quantity kinds." .

qudt:Heap  rdf:type           owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Heap";
        rdfs:subClassOf       qudt:OrderedTree;
        dcterms:description   "\n  <p>A heap is a specialized tree-based data structure that satisfies the condition: if B is a child node of A, then $key(A) \\ge key(B)$. \n  This implies that an element with the greatest key is always in the root node, and so such a heap is sometimes called a max heap. \n  Alternatively, if the comparison is reversed, the smallest element is always in the root node, which results in a min heap. \n  The function or method that implements the key() operator is specified by the heap type.\n  </p>"^^rdf:HTML;
        prov:wasInfluencedBy  <http://en.wikipedia.org/wiki/Heap_(data_structure)> .

qudt:HeterogenousArray
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Heterogenous Array";
        rdfs:subClassOf      qudt:Array;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:datatype
                             ];
        dcterms:description  "\n  <p>An <em>Array></em> is a data structure that stores a collection of elements, typically of the same type, in a contiguous block of memory. \n  Each element in an array is identified by an index or key, which is typically a numerical identifier, either starting at '0' or '1'.\n  </p>\n  <p>The key considerations for an Array are:\n  </p>\n  <ol>\n  <li>Fixed Size: The size of an array may be pre-determined when it is created and cannot be changed;</li>\n  <li>Index-Based Access: Elements can be accessed, updated, or modified using their index;</li>\n  <li>Heterogenous Elements: all elements in the array may be of different data types;</li>\n  <li>Contiguous Memory Allocation: \n    the elements are stored in consecutive memory locations, which allows efficient access using the index.</li>\n  </ol>\n  <p>An Array is represented as ordered entries of values arranged according to its dimensionality.\n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>The property 'qudt:datatype' refers to a list if the datatypes of the elements.  \n  </p>\n  <p>An heterogenous array can be multi-dimensional.\n  Multiple indices are used but they are treated as extensions of the same structure.\n  For example: for a 2D array arr[2][3], indices refer to the row and column positions.\n  A 2D array is still represented as a list, where each member of the list is a list.\n  </p>\n  <p>Higher dimensional arrays can be represented as nested lists.\n  For each dimension a new nested list is defined.\n  </p>"^^rdf:HTML .

qudt:HexBinaryType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Hexidecimal Binary Type";
        rdfs:subClassOf      qudt:TextStringType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:minLength
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxLength
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:pattern
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:length
                             ];
        dcterms:description  "A string composed of hex characters." .

qudt:hexbinary  rdf:type  rdfs:Datatype , owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "hexbinary";
        rdfs:subClassOf   xsd:string .

qudt:HomogeneousArray
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Homogeneous Array";
        rdfs:subClassOf      qudt:Array;
        dcterms:description  "\n  <p>An <em>Array></em> is a data structure that stores a collection of elements, typically of the same type, in a contiguous block of memory. \n  Each element in an array is identified by an index or key, which is typically a numerical identifier, either starting at '0' or '1'.\n  </p>\n  <p>The key considerations for an Array are:\n  </p>\n  <ol>\n  <li>Fixed Size: The size of an array may be pre-determined when it is created and cannot be changed;</li>\n  <li>Index-Based Access: Elements can be accessed, updated, or modified using their index;</li>\n  <li>Homogeneous Elements: all elements in an array must be of the same datatype;</li>\n  <li>Contiguous Memory Allocation: The elements are stored in consecutive memory locations, which allows efficient access using the index.</li>\n  </ol>\n  <p>An Array is represented as ordered entries of values arranged according to its dimensionality.\n  The number of dimensions is specified in the attribute 'dimensionality'.\n  </p>\n  <p>The property 'qudt:datatype' refers to the datatype of the elements.  \n  </p>\n  <p>An array can be multi-dimensional.\n  Multiple indices are used but they are treated as extensions of the same structure.\n  For Example: for a 2D array arr[2][3], indices refer to the row and column positions.\n  A 2D array is still represented as a list, where each member of the list is a list.\n  </p>\n  <p>Higher dimensional arrays can be represented as nested lists.\n  For each dimension a new nested list is defined.\n  </p>"^^rdf:HTML .

qudt:iconicCueEnumeration
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "iconic cue enumeration";
        rdfs:subPropertyOf  qudt:modalCueEnumeration .

qudt:IconicCue  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Iconic enumeration literal";
        rdfs:subClassOf   qudt:ModalCue;
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:minCardinality  1;
                            owl:onProperty      qudt:image
                          ];
        rdfs:subClassOf   [ rdf:type            owl:Restriction;
                            owl:maxCardinality  1;
                            owl:onProperty      qudt:image
                          ];
        rdfs:subClassOf   [ rdf:type         owl:Restriction;
                            owl:cardinality  1;
                            owl:onProperty   qudt:image
                          ] .

qudt:iconicCue  rdf:type    owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "iconic cue";
        rdfs:subPropertyOf  qudt:modalCue .

qudt:incrementDatatype
        rdf:type          owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "increment datatype";
        rdfs:range        qudt:TimeStringType .

qudt:IntegerDatatype  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Integer Datatype";
        rdfs:subClassOf      qudt:OrdinalType , qudt:NumericType;
        dcterms:description  "An Integer Type is a data type that specifies how integer numbers are represented and stored in machine memory." .

qudt:IntegerEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Integer Encoding";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "The encoding scheme for integer types";
        owl:oneOf            ( datatype:LongUnsignedIntegerEncoding datatype:LongSignedIntegerEncoding datatype:ShortUnsignedIntegerEncoding datatype:ShortSignedIntegerEncoding datatype:SignedIntegerEncoding datatype:UnsignedIntegerEncoding ) .

qudt:IntegerListShape
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf   qudt:List .

qudt:IntegerUnionList
        rdf:type          qudt:List;
        rdf:first         xsd:int;
        rdf:rest          ( xsd:nonNegativeInteger xsd:positiveInteger xsd:integer );
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Integer Union List" .

qudt:InterpolatedTable
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Interpolated Table Type";
        rdfs:subClassOf      qudt:Table;
        dcterms:description  "A sub-type of 'Table Type'." .

qudt:inverted  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "inverted";
        rdfs:range        xsd:boolean .

qudt:isByteString  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "is byte string";
        rdfs:range        xsd:boolean .

qudt:isHeterogeneous  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "is heterogeneous";
        rdfs:range        xsd:boolean .

qudt:javaName  rdf:type     owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "java name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:jsName  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "Javascript name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:kinestheticCueEnumeration
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "kinesthetic cue enumeration";
        rdfs:subPropertyOf  qudt:modalCueEnumeration .

qudt:KinestheticCue  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Kinesthetic Cue";
        rdfs:subClassOf   qudt:ModalCue .

qudt:kinestheticCue  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "kinesthetic cue";
        rdfs:subPropertyOf  qudt:modalCue .

qudt:LargeObjectType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Large object";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "A 'LargeObject' datatype is used to store blocks of unstructured data (such as text, graphic images, video clips, and sound waveforms). They often are used to allow efficient, random, piece-wise access to the data." .

qudt:LargeObject  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Large object";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  A 'LargeObject' datatype is used to store blocks of unstructured data (such as text, graphic images, video clips, and sound waveforms). \n  They often are used to allow efficient, random, piece-wise access to the data.\n  " .

qudt:length  rdf:type        owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "length";
        rdfs:range           xsd:integer;
        dcterms:description  "The length of a structure, for example the size of a vector" .

qudt:LimitType  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Limit type";
        rdfs:subClassOf   qudt:EnumeratedValue .

qudt:List  rdf:type          owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "List";
        rdfs:subClassOf      qudt:DataItem;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:hasUnit
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:datatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:quantity
                             ];
        dcterms:description  "A sub-type of 'AbstractDataItem'." .

qudt:LongIntegerType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Long Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  A \"Long Integer\" is an integer that can be represented in four octets (32 bits) of machine memory. \n  Long integers may be signed or unsigned.\n  " .

qudt:lowerBound  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "lower bound" .

qudt:MajorMinorType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Major minor type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "A sub-type of 'Enumerated Value'.";
        owl:oneOf            ( datatype:Minor datatype:Major ) .

qudt:mantissa  rdf:type      owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "mantissa";
        dcterms:description  "In scientific notation, the mantissa of a real number is the integer coefficient preceding the base raised to the exponent." .

qudt:Map  rdf:type           owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Map Type";
        rdfs:seeAlso         qudt:AssociativeArray;
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "A Map Type is an abstract data type that defines the properties of map data structures. A Map (or Associative Array) is an abstract data structure composed of a collection of keys and a collection of values, where each key is associated with one value. The operation of finding the value associated with a key is called a lookup or indexing, and this is the most important operation supported by an associative array. The relationship between a key and its value is sometimes called a mapping or binding." .

qudt:MassPropertiesArray
        rdf:type             rdf:Class , owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Mass Properties Array";
        rdfs:subClassOf      qudt:HeterogenousArray;
        dcterms:description  "\n  <p>A <em>Mass Properties Array</em> holds, for an object, four values for the properties:\n   Center of Gravity, Mass, Moment of Inertia, and Product of Inertia. </p>\n  " .

qudt:MathsFunctionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Maths Function Type";
        rdfs:subClassOf      qudt:Concept;
        dcterms:description  "A sub-type of 'QUDT Concept'." .

qudt:matlabName  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "matlab name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:MatrixElementOrder
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Matrix Element Order";
        rdfs:subClassOf      qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:byRow
                             ];
        dcterms:description  "A datatype that specifies the order in which matrix elements are arranged." .

qudt:Matrix  rdf:type        owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Matrix";
        rdfs:subClassOf      qudt:Array;
        dcterms:description  "\n  <p>A <em>Matrix</em> is a data type that specifies the properties of an N-dimensional data structure.\n  </p>\n  "^^rdf:HTML .

qudt:maxBits  rdf:type    owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "maximum bits";
        rdfs:range        xsd:integer .

qudt:maxDepth  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "max depth";
        rdfs:range        xsd:integer .

qudt:maxExclusive  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "max exclusive";
        rdfs:range           xsd:string;
        rdfs:subPropertyOf   qudt:upperBound;
        dcterms:description  "maxExclusive is the exclusive upper bound of the value space for a datatype with the ordered property. The value of maxExclusive must be in the value space of the base type or be equal to {value} in {base type definition}." .

qudt:maxExponent  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "max exponent";
        rdfs:range        xsd:integer .

qudt:maxInclusive  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "max inclusive";
        rdfs:subPropertyOf   qudt:upperBound;
        dcterms:description  "maxInclusive is the inclusive upper bound of the value space for a datatype with the ordered property. The value of maxInclusive must be in the value space of the base type." .

qudt:maxLength  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "max length";
        rdfs:range        xsd:integer .

qudt:maxMantissa  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "max mantissa";
        dcterms:description  "\n  <p>The maximium mantissa is the largest integer that may appear as a coefficient in a finite precision representation of a real number.\n  For a given numeric data type, the value of <em>maxMantissa}</em> (<em>M</em>) and the values of <em>base</em> (<em>b</em>) and  <em>precision</em> (<em>p</em>) are related by the formula:\n  </p>\n  <p><em>M = b<sup></sup> - 1</em> .</p>\n  "^^rdf:HTML .

qudt:memberDatatype  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "member datatype";
        rdfs:range           qudt:CharacterType;
        dcterms:description  "\n  This property is used to define the data type of a collection's elements. \n  It is used for collections with elements that are all of the same type.\n  " .

qudt:member  rdf:type        owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "member";
        dcterms:description  "\n  This property is used to define a collection's elements. \n  " .

qudt:MemoryOrderType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Memory order type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "A sub-type of 'Enumerated Value'." .

qudt:microsoftSQLServerName
        rdf:type            owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "Microsoft SQL Server name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:minBits  rdf:type    owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "minimum bits";
        rdfs:range        xsd:integer .

qudt:minExclusive  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "min exclusive";
        rdfs:subPropertyOf   qudt:lowerBound;
        dcterms:description  "minExclusive is the exclusive lower bound of the value space for a datatype with the ordered property. The value of minExclusive must be in the value space of the base type or be equal to {value} in {base type definition}." .

qudt:minInclusive  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "min inclusive";
        rdfs:subPropertyOf   qudt:lowerBound;
        dcterms:description  "minInclusive is the inclusive lower bound of the value space for a datatype with the ordered property. The value of minInclusive must be in the value space of the base type." .

qudt:minLength  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "min length";
        rdfs:range        xsd:integer .

qudt:minMantissa  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "min mantissa";
        dcterms:description  "\n  <p>The minimium mantissa is the negative integer with the greatest magnitude that may appear as a coefficient in a finite precision representation of a real number.  \n  For a given numeric data type, the value of <em>minMantissa</em> (<em>M</em>) and the values of <em>base</em> (<em>b</em>) and <em>precision</em> (<em>p</em>) are related by the formula:\n  </p>\n  <p><em>M = -(b<sup>p</sup> - 1)</em>.\n  </p>"^^rdf:HTML .

qudt:minValue  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "minimum value" .

qudt:modalCueEnumeration
        rdf:type            owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "modal cue enumeration";
        rdfs:range          qudt:ModalEnumeration;
        rdfs:subPropertyOf  qudt:enumeration .

qudt:ModalCue  rdf:type   owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Modal Cue";
        rdfs:subClassOf   qudt:EnumeratedValue .

qudt:modalCue  rdf:type   owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "modal cue";
        rdfs:range        qudt:ModalCue .

qudt:ModalEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Modal Enumeration";
        rdfs:subClassOf      qudt:Enumeration;
        dcterms:description  "A sub-type of 'QUDT Enumeration'." .

qudt:modifiability  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "modifiability";
        dcterms:description  "Reference to one in a list of enumerated elements that indicates whether data (e.g. variable or parameter) can be changed." .

qudt:MultiDimensionalArray
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Multi-Dimensional Array Type";
        rdfs:subClassOf      qudt:Array;
        dcterms:description  "\n  <p>A <em>Multi-Dimensional Array</em> is an extension of a standard one-dimensional array,\n   where elements are organized in a grid-like structure across two or more dimensions. \n  It is a collection of elements arranged in a tabular or multi-dimensional structure for representing complex datasets,\n   such as matrices, tensors, or higher-dimensional data.\n  </p>\n  <p>The elements of a multi-dimensional array are N-tuples, where 'N' corresponds to the dimensionality of the array.\n  Each element is specified using the property 'qudt:element'.\n  </p>\n  <p>Ordinary or one-dimensional arrays are indexed by a single integer. \n  For a multi-dimensional array, the index into the array uses an ordered list of integers, such as in 'a[3,1,5]'. \n  The length of the list of integers used to index into the multi-dimensional array is always the same.\n  This is referred to as the array's dimensionality. \n  The bounds on each of these are called the array's dimensions.\n  </p>\n  "^^rdf:HTML .

qudt:MultiDimensionalDataFormat
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Multi dimensional data format";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  Data formats for storing and manipulating scalar and multidimensional data in a platform and discipline independent manner,\n   for example HDF, CDF and netCDF.\n  " .

qudt:MultiModalEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Multi modal enumeration";
        rdfs:subClassOf      qudt:Enumeration;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:visualCueEnumeration
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:auralCueEnumeration
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:iconicCueEnumeration
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:kinestheticCueEnumeration
                             ];
        dcterms:description  "A sub-type of 'QUDT Enumeration'." .

qudt:MultiModalType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Multi Modal Type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:visualCue
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:auralCue
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:iconicCue
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:kinestheticCue
                             ];
        dcterms:description  "A sub-type of 'Enumerated Value'." .

qudt:MultiSet  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Bag";
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "A bag is a set in which elements may be repeated." .

qudt:mySQLName  rdf:type    owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "MySQL name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:N-TupleType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "N-Tuple Type";
        rdfs:subClassOf      qudt:Tuple;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  A tuple containing n objects is known as an \"n-tuple\". \n  For example the 4-tuple (or \"quadruple\"), with components of respective types PERSON, DAY, MONTH and YEAR.\n  This could be used to record that a certain person was born on a certain day of a certain month of a certain year.\n  " .

qudt:N-Tuple  rdf:type       owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "N-Tuple Type";
        rdfs:subClassOf      qudt:Tuple;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  A tuple containing n objects is known as an \"n-tuple\". \n  For example the 4-tuple (or \"quadruple\"), with components of respective types PERSON, DAY, MONTH and YEAR.\n  This could be used to record that a certain person was born on a certain day of a certain month of a certain year.\n  " .

qudt:negativeDeltaLimit
        rdf:type             owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "negative delta limit";
        dcterms:description  "A negative change limit between consecutive sample values for a parameter. The Negative Delta may be the encoded value or engineering units value depending on whether or not a Calibrator is defined."^^rdf:HTML .

qudt:NonNegativeIntegerUnionList
        rdf:type          qudt:List;
        rdf:first         xsd:nonNegativeInteger;
        rdf:rest          ( xsd:positiveInteger );
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Non-negative union list" .

qudt:NumericType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Numeric Type";
        rdfs:subClassOf      qudt:ScalarDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:signedness
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:accuracy
                             ];
        dcterms:description  "Numeric data types are data types whose values denote quantities as defined by a mathematical number system." .

qudt:OctetType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Octet Type";
        rdfs:subClassOf      qudt:UnsignedIntegerType;
        dcterms:description  "An 8 bit unsigned integer" .

qudt:odbcName  rdf:type     owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "ODBC name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:OffOnStateTypeEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      qudt:Enumeration;
        dcterms:description  "\n  A discrete state enumeration whose values are 'off' and 'on'. \n  The 'off' value is encoded as a zero (0) and the 'on' value as a one (1).\n  " .

qudt:oleDBName  rdf:type           owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy           <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label                 "OLE DB name";
        rdfs:range                 xsd:string;
        rdfs:subPropertyOf         qudt:id;
        dcterms:description        "\n  <p>OLE DB (Object Linking and Embedding, Database, sometimes written as OLEDB or OLE-DB), an API designed by Microsoft, allows accessing data from a variety of sources in a uniform manner. \n  The API provides a set of interfaces implemented using the Component Object Model (COM); it is otherwise unrelated to OLE.\n  </p>"^^rdf:HTML , "OLE DB (Object Linking and Embedding, Database, sometimes written as OLEDB or OLE-DB), an API designed by Microsoft, allows accessing data from a variety of sources in a uniform manner. The API provides a set of interfaces implemented using the Component Object Model (COM); it is otherwise unrelated to OLE. ";
        qudt:informativeReference  "http://msdn.microsoft.com/en-us/library/windows/desktop/ms714931(v=vs.85).aspx"^^xsd:anyURI , "https://en.wikipedia.org/wiki/OLE_DB"^^xsd:anyURI;
        prov:wasInfluencedBy       <http://en.wikipedia.org/wiki/OLE_DB> , <http://msdn.microsoft.com/en-us/library/windows/desktop/ms714931(v=vs.85).aspx> .

qudt:OnOffStateTypeEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      qudt:Enumeration;
        dcterms:description  "\n  A discrete state enumeration whose values are 'off' and 'on'. \n  The 'on' value is encoded as a zero (0) and the 'off' value as a one (1).\n  ";
        qudt:inverted        true .

qudt:OnOffStateType  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "On off state type";
        rdfs:subClassOf   qudt:DiscreteState .

qudt:optional  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "optional";
        rdfs:range        xsd:boolean .

qudt:oracleSQLName  rdf:type  owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "ORACLE SQL name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:OrderedCollection
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordered Collection Kind";
        rdfs:subClassOf      qudt:Collection;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:orderingRelation
                             ];
        dcterms:description  "\n  <p>An <em>Ordered Collection Kind</em> is an abstract data type that defines the properties of collection data structures whose members can be linearly ordered. \n  An ordered collection is a collection together with an ordering relation (such as greater than) that linearly orders the collection elements.\n  </p>"^^rdf:HTML .

qudt:OrderedTree  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordered Tree Type";
        rdfs:subClassOf      qudt:Tree , qudt:OrderedCollection;
        dcterms:description  "\n  <p>An \"Ordered Tree Type\" is a data type that defines the properties of data structures that represent ordered trees. \n  An ordered tree is a tree where the children of every node are ordered, that is, there is a first child, second child, third child, etc. \n  Typically a type specification for an ordered tree will include the comparison operator (such as <b>lt</b> or <b>gt</b>) that is used to order the nodes.\n  </p>"^^rdf:HTML .

qudt:OrderedType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordered type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "Describes how a data or information structure is ordered.";
        owl:oneOf            ( datatype:Unordered datatype:PartiallyOrdered datatype:TotallyOrdered ) .

qudt:orderedType  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "ordered type";
        rdfs:range        qudt:OrderedType .

qudt:orderingRelation
        rdf:type             owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordering Relation";
        rdfs:range           dtype:ComparisonOperator;
        dcterms:description  "\n  This property identifies the mathematical comparison operator (such as \"<\" or \">\") that is used to order the elements of a collection.\n  " .

qudt:orderInStructure
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "order in structure" .

qudt:OrdinalType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Ordinal Data Type";
        rdfs:subClassOf      qudt:ScalarDatatype;
        dcterms:description  "\n  <p>An ordinal data type is a data type that specifies the properties of values that can easily be put in a one to one correspondence with a subset of the natural numbers. \n  Examples include boolean, character, and integer data types.\n  </p>"^^rdf:HTML .

qudt:originDefinition
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "origin definition" .

qudt:PaddingType  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Padding type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "\n  <p>This describes how unused bits of a field are filled. \n  Unused bits could be set to one or zero. \n  A third option is \"don't care\".\n  </p>"^^rdf:HTML;
        owl:oneOf            ( datatype:PadWithOnes datatype:PadWithZeros datatype:PadWithAny ) .

qudt:padding  rdf:type    owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "padding";
        rdfs:range        qudt:PaddingType .

qudt:ParameterModifiabilityType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Parameter modifiability type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "An enumeration of literals that signify whether a parameter is modifiable and if so, by whom." .

qudt:PartialArray  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Partial Array";
        rdfs:subClassOf      qudt:Array;
        dcterms:description  "\n  A partial array is an Array with two attributes that define the starting and ending indices of the elements that are provided.\n  "^^rdf:HTML .

qudt:pattern  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "pattern";
        rdfs:range           xsd:string;
        dcterms:description  "A pattern is a constraint on the value space of a datatype which is achieved by constraining the lexical space to literals which match a specific pattern. The value of pattern must be a regular expression." .

qudt:PhysicalAddress  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Physical Address Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "A physical address is a pointer to a memory location." .

qudt:Polarity  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Polarity";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "\n  A \"Tagged Enumeration\" with the following instance(s): \"negative\", \"positive\".\n  " .

qudt:PositiveBigIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Positive Big Integer Type";
        rdfs:subClassOf      qudt:UnsignedType , qudt:IntegerDatatype;
        dcterms:description  "Positive Integers are integers that are either non-zero and non-negative." .

qudt:positiveDeltaLimit
        rdf:type             owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Positive delta limit";
        dcterms:description  "A positive change limit between consecutive sample values for a parameter. The Positive Delta may be the encoded value or engineering units value depending on whether or not a Calibrator is defined."^^rdf:HTML .

qudt:PositiveIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Positive Integer Type";
        rdfs:subClassOf      qudt:UnsignedType , qudt:IntegerDatatype;
        dcterms:description  "Positive Integers are integers that are either non-zero and non-negative." .

qudt:precision  rdf:type     owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "precision";
        rdfs:range           xsd:integer;
        dcterms:description  "\n  <p>Precision is the number of digits used to perform a given computation. \n  The concepts of accuracy and precision are both closely related and often confused. \n  While the accuracy of a number x is given by the number of significant decimal (or other) digits to the right of the decimal point in x,\n   the precision of x is the total number of significant decimal (or other) digits.\n  </p>\n  <p>For a given numeric data type, the value of type:precision (?p) is related to the values of type:maxMantissa (?M) and type:base (?b) by the formula:\n  </p>\n  <p>?p := log(?b, ?M)\n  </p>\n  <p>where log(a,y) = x iff y=a^x.\n  </p>\n  "^^rdf:HTML .

qudt:protocolBuffersName
        rdf:type            owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "protocol buffers name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:pythonName  rdf:type   owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "python name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:Quantifiable  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:dataEncoding
                             ];
        vaem:isElaboratedIn  <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

qudt:quantify  rdf:type   owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "quantify";
        rdfs:range        qudt:Quantity .

qudt:QuantityKindList
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Quantity kind List";
        rdfs:subClassOf      qudt:List;
        dcterms:description  "\n  <p>A <em>Quantity Kind List</em> is a list of qudt:QuantityKind. \n  They are used, for instance, to specify the quantity kind in a Mass Properties Array. \n  </p>\n  "^^rdf:HTML .

qudt:QuantityValueType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Quantity value type";
        rdfs:subClassOf      qudt:DimensionalDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:elementUnit
                             ];
        dcterms:description  "A sub-type of 'Dimensional Data Type'." .

qudt:RawValueTupleMemberType
        rdf:type          owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Raw value tuple member type";
        rdfs:subClassOf   qudt:TupleMember .

qudt:RawValueTupleMember
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Raw value tuple member";
        rdfs:subClassOf      qudt:TupleMember;
        dcterms:description  "A sub-type of 'Tuple Member Type'." .

qudt:rdfsDatatype  rdf:type  owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "rdfs datatype";
        rdfs:range        rdfs:Datatype .

qudt:RealDatatype  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Real Datatype";
        rdfs:subClassOf      qudt:NumericType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:base
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:precision
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxExponent
                             ];
        dcterms:description  "\n  <p>A real number is represented as a factor, called the mantissa, multiplied by a power (the exponent) of a base. \n  Different bases yield different approximations to real numbers, and conversion between them is limited in accuracy.\n  Four floating-point types are defined in 'IEEE-754 Standard for Binary Floating-Point'. \n  These types are 'single', 'extended single', 'double', and 'extended double'.\n  </p>\n  "^^rdf:HTML .

qudt:RealDoublePrecisionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Real Double Precision Type";
        rdfs:subClassOf      qudt:RealDatatype , qudt:DoublePrecisionType;
        dcterms:description  "\n  <p>A real double precision data type specifies how a real number, or an approximation of a real number is stored in memory.\n  Typically this occupies two words in computer memory, where the byte length of a word depends on machine address size of the computer processor. \n  For example, on 32-bit machine architectures, a word is four bytes.\n  An example of a real double precision data type specification is the IEEE 754 standard for encoding binary or decimal floating point numbers in 8 bytes for storage on 32-bit machine architectures.\n  </p>"^^rdf:HTML .

qudt:realization  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "realization" .

qudt:RealNumberType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Real number type";
        rdfs:subClassOf      qudt:RealDatatype;
        dcterms:description  "\n  <p>A <em>Real Number Type</em> is the class of data values that approximate real numbers in finite precision. \n  Often, such values are expressed in \"mantissa, base, exponent\" form. \n  Any rational number can be expressed in the form m*b^<sup>e</sup>, where m (the mantissa), b (the base), and e (the exponent) are integers. \n  Typically, b is chosen to be either 2 or 10, and then the values of m and e are determined given the choice of base.\n  </p>\n  "^^rdf:HTML .

qudt:RealSinglePrecisionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Real Single Precision Type";
        rdfs:subClassOf      qudt:SinglePrecisionType , qudt:RealDatatype;
        dcterms:description  "\n  <p>A real single precision data type specifies how a real number,\n   or an approximation of a real number is stored in memory that occupies one word in computer memory, \n   where the byte length of a word depends on machine address size of the computer processor.\n  </p>\n  <p> \n  For example, on 32-bit machine architectures, a word is four bytes. \n  An example of a real single precision data type specification is the IEEE 754 standard for encoding binary\n   or decimal floating point numbers in 4 bytes for storage on 32-bit machine architectures.\n  </p>\n  "^^rdf:HTML .

qudt:Record  rdf:type        owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Record Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  A Record Type is a type whose values are records, i.e. aggregates of several items of possibly different types. \n  The aggregated items are called fields or members and are usually identified or indexed by field labels.\n  " .

qudt:returnType  rdf:type    owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "return type";
        rdfs:range           qudt:Datatype;
        rdfs:subPropertyOf   qudt:elementDatatype;
        dcterms:description  "This property is used to state the return type of a function type." .

qudt:rgbCode  rdf:type    owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "rgb code";
        rdfs:range        xsd:string .

qudt:rows  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "rows";
        rdfs:range        xsd:integer .

qudt:ScalarDatatype  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Scalar Datatype";
        rdfs:subClassOf      rdfs:Datatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:rdfsDatatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bitOrder
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:encoding
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxExclusive
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxInclusive
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bytes
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:byteOrder
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:bits
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:length
                             ];
        vaem:isElaboratedIn  <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

qudt:ScalarListShape  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:subClassOf   qudt:List .

qudt:scalarValue  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "scalar value" .

qudt:Sequence  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Sequence";
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "\n  <p>A <em>Sequence</em> is an enumerated collection of objects in which repetitions are allowed. \n  Like a set, it contains members (also called elements, or terms). \n  The number of elements (possibly infinite) is called the length of the sequence.\n  </p>\n  <p>Unlike a set, order matters, and exactly the same elements can appear multiple times at different positions in the sequence. \n  Formally, a sequence can be defined as a function whose domain is either the set of the natural numbers (for infinite sequences) or the set of the first n natural numbers (for a sequence of finite length n). \n  </p>\n  <p>The position of an element in a sequence is its rank or index; it is the integer from which the element is the image. \n  It depends on the context or of a specific convention, if the first element has index 0 or 1. [Wikipedia]\n  </p>\n  "^^rdf:HTML .

qudt:Set  rdf:type           owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Set Type";
        rdfs:subClassOf      qudt:Collection;
        dcterms:description  "\n  <p>A <em>Set</em> is an abstract data type that defines the properties of sets. \n  A set is a collection (container) of certain values, without any particular order, and no repeated values. \n  It corresponds with a finite set in mathematics.\n  </p>\n  "^^rdf:HTML .

qudt:ShortIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Short Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  A Short Integer is an integer that can be represented in two octets (16 bits) of machine memory. \n  Short integers may be signed or unsigned.\n  " .

qudt:SignedBigIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Big Integer Type";
        rdfs:subClassOf      qudt:BigIntegerType , qudt:SignedIntegerType;
        dcterms:description  "A Signed Big Integer is a signed integer that can be represented in eight octets (64 bits) of machine memory." .

qudt:SignedIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Integer Type";
        rdfs:subClassOf      qudt:SignedType , qudt:IntegerDatatype;
        dcterms:description  "Signed Integers are integers can take on both positive and negative values." .

qudt:SignedLongIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Long Integer Type";
        rdfs:subClassOf      qudt:LongIntegerType , qudt:SignedIntegerType;
        dcterms:description  "A Signed Long Integer is a signed integer that can be represented in four octets (32 bits) of machine memory." .

qudt:SignedMediumIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Integer Type";
        rdfs:subClassOf      qudt:SignedIntegerType;
        dcterms:description  "\n  A \"Signed Medium Integers\" is an integer of 24 bits that can take on both positive and negative values.\n  " .

qudt:SignednessType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signedness type";
        rdfs:subClassOf      qudt:EnumeratedValue;
        dcterms:description  "Specifics whether a value should be signed or unsigned.";
        owl:oneOf            ( datatype:Signed datatype:Unsigned ) .

qudt:signedness  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "signedness";
        rdfs:range        qudt:SignednessType .

qudt:SignedShortIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Short Integer Type";
        rdfs:subClassOf      qudt:SignedIntegerType , qudt:ShortIntegerType;
        dcterms:description  "A Signed Short Integer is a signed integer that can be represented in four octets (32 bits) of machine memory." .

qudt:SignedType  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Type";
        rdfs:subClassOf      qudt:NumericType;
        dcterms:description  "A signed type is a numeric type that distinguishes between positive and negative numbers using an encoding scheme, such as sign and magnitude, one's compliment, and two's compliment to represent negative numbers." .

qudt:SignedVariableLengthIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Signed Variable Length Integer Type";
        rdfs:subClassOf      qudt:VariableLengthIntegerType , qudt:SignedIntegerType;
        dcterms:description  "A Signed Variable Length Integer data type defines a data structure for representing signed integers that uses a variable number of bits depending on the magnitude of the integer. Typically, variable length integer data types are between one and 64 bits in length." .

qudt:significantDigits
        rdf:type          owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "significant digits" .

qudt:SinglePrecisionType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Single Precision Type";
        rdfs:subClassOf      qudt:NumericType;
        dcterms:description  "\n  A single precision data type specifies how a numeric value, such as an integer or real number,\n   is stored in memory that occupies one word in computer memory,\n   where the byte length of a word depends on machine address size of the computer processor. \n  For example, on 32-bit machine architectures, a word is four bytes.\n  A single precision data value on a 32-bit machine architecture occupies four bytes of memory.\n  " .

qudt:sound  rdf:type         owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "sound";
        rdfs:range           xsd:anyURI;
        dcterms:description  "The intended use of the sound property is to be associated with modal enumerations" .

qudt:SplineCalibrator
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Spline calibrator";
        rdfs:subClassOf      qudt:Map;
        dcterms:description  "A sub-type of 'Map Type'." .

qudt:SplinePoint  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Spline point";
        rdfs:subClassOf      qudt:Tuple;
        dcterms:description  "A sub-type of 'Tuple Type'." .

qudt:StateSpaceMatrix
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "State Space Matrix Type";
        rdfs:subClassOf      qudt:Matrix;
        dcterms:description  "\n  <p>In control engineering, a state space representation is a mathematical model of a physical system\n   as a set of input, output and state variables related by first-order differential equations. \n  To abstract from the number of inputs, outputs and states, the variables are expressed as vectors.\n  The differential and algebraic equations are written in matrix form (the last one can be done when the dynamical system is linear and time invariant).\n  </p>"^^rdf:HTML .

qudt:StringEncodingType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "String Encoding Type";
        rdfs:subClassOf      qudt:Encoding;
        dcterms:description  "\n  An \"Encoding\" with the following instance(s): \"datatype:UTF8-StringEncoding\", \"datatype:UTF16-StringEncoding\".\n  " , "\n  <p><em>String Encoding Type</em> is an \"Encoding\" with the following instance(s):\n   \"UTF-16 String\", \"UTF-8 Encoding\".\n   </p>\n  "^^rdf:HTML .

qudt:StringType  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "String Type";
        rdfs:subClassOf      qudt:ScalarDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:isByteString
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:maxLength
                             ];
        dcterms:description  "\n  <p>A <em>String Type</em> is a data type that specifies the properties of a list structure that holds characters.\n  </p>\n  "^^rdf:HTML .

qudt:StringUTF16  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "String UTF16";
        rdfs:subClassOf      qudt:TextStringType , qudt:StringType;
        dcterms:description  "\n  <p><em>String UTF-16</em> is a string data type that specifies the properties of string data structures which encode strings using the UTF-16 encoding. \n  UTF-16 is the native internal representation of text in many software systems, for example:\n  </p>\n  <ol>\n  <li>Microsoft Windows NT/Windows 2000/Windows XP/Windows CE;</li>\n  <li>Qualcomm BREW, and Symbian operating systems;</li>\n  <li>the Java and .NET byte code environments;</li>\n  <li>Mac OS X's Cocoa and Core Foundation frameworks;</li>\n  <li>Qt cross-platform graphical widget toolkit.</li>\n  </ol>\n  "^^rdf:HTML .

qudt:StringUTF8  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "String UTF8 Type";
        rdfs:subClassOf      qudt:TextStringType , qudt:StringType;
        dcterms:description  "\n  String UTF-8 Type is a string data type that specifies the properties of string data structures which encode strings using the UTF-8 encoding. \n  UTF-8 includes ASCII, otherwise referred to as IA-5 (International Alphabet 5, as standardized by International Organization for Standardization [ISO]) as the first 128 values. \n  The Internet Engineering Task Force (IETF) requires all Internet protocols to identify the encoding used for character data with UTF-8 as at least one supported encoding. \n  The Internet Mail Consortium (IMC) recommends that all e-mail programs must be able to display and create mail using UTF-8.\n  ";
        vaem:isElaboratedIn  <http://qudt.org/$$QUDT_VERSION$$/schema/shacl/datatype> .

qudt:stringValue  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "string value";
        rdfs:subPropertyOf  qudt:scalarValue .

qudt:StructuredDatatype
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Structured Data Type";
        rdfs:subClassOf      qudt:Datatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  <p>A <em>Structured Datatype</em>, in contrast to a scalar data type, is used to characterize classes of complex data structures.\n  Examples are collections, linked and indexed lists, trees, ordered trees, and multi-dimensional file formats.\n  </p>"^^rdf:HTML .

qudt:Table  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Table Type";
        rdfs:subClassOf      qudt:StructuredDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:columns
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:dimensionality
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:rows
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:byRow
                             ];
        dcterms:description  "\n  A Table Type is a data type that specifies the properties of table data structures. \n  A table is both a mode of visual communication and a means of arranging data. \n  The precise conventions and terminology for describing tables varies depending on the context. \n  Moreover, tables differ significantly in variety, structure, flexibility, notation, representation and use.\n  " .

qudt:TaggedEnumeration
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Tagged Enumeration";
        rdfs:subClassOf      qudt:Enumeration;
        dcterms:description  "An enumeration where each literal  has a tag that is a non-negative integer. These enumerations are likely to have their literals encoded - hence the need for the tag." .

qudt:TextStringType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Text String Type";
        rdfs:subClassOf      qudt:StringType;
        dcterms:description  "\n  A <em>Text String Type</em> has encodings that are specified in subclasses or in connection to character arrays in <em>Structured Datatypes</em>.\n  " .

qudt:TextTypeUnion  rdf:type  qudt:List;
        rdf:first            xsd:string;
        rdf:rest             ( rdf:HTML qudt:LatexString );
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Text Type Union";
        dcterms:description  "\n  An rdf:List that can be used in property constraints as value for sh:or to indicate that all values of a property\n   must be a plain string, a string with HTML markup, or a string with LaTeX markup.\n  " .

qudt:ThreeTuple  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Three-Tuple";
        rdfs:subClassOf      qudt:N-Tuple;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  A three-tuple is a tuple with exactly three members. \n  A Three-Tuple Type is a data type that defines the type properties of a class of three-tuples and their members.\n  " .

qudt:TimeDataType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time data type";
        rdfs:subClassOf      qudt:ScalarDatatype , qudt:Enumeration;
        dcterms:description  "A sub-type of 'QUDT Enumeration'.";
        dtype:value          datatype:TIME .

qudt:timeDatatype  rdf:type  owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "time datatype";
        rdfs:subPropertyOf  qudt:type .

qudt:TimeInterval  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time interval";
        rdfs:subClassOf      qudt:Concept;
        dcterms:description  "A relative interval that is an increment in time. \n  For example, this is used in time series arrays to express the time point of a vector of values.\n  " .

qudt:TimeSeriesArrayType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time Series Array Type";
        rdfs:subClassOf      qudt:ArrayType;
        dcterms:description  "\n  <p>A <em>Time Series Array Type</em> is a data type that specifies the properties of arrays that hold time series data. \n  A time series is a sequence of data points, measured at successive time intervals. \n  The time intervals may be uniformly or non-uniformly spaced.\n  </p>\n  "^^rdf:HTML .

qudt:TimeSeriesArray  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time Series Array";
        rdfs:subClassOf      qudt:Array;
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:incrementDatatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:vector
                             ];
        rdfs:subClassOf      [ rdf:type         owl:Restriction;
                               owl:cardinality  1;
                               owl:onProperty   qudt:vector
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:vector
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  1;
                               owl:onProperty      qudt:incrementDatatype
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:incrementDatatype
                             ];
        dcterms:description  "\n  A Time Series Array is a data type that specifies the properties of arrays that hold time series data. \n  A time series is a sequence of data points, measured at successive time intervals. \n  The time intervals may be uniformly or non-uniformly spaced.\n  " .

qudt:TimeStringType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time Type";
        rdfs:subClassOf      qudt:TextStringType , qudt:DateTimeStringType;
        dcterms:description  "Time takes a number of forms, depending on the units used (e.g., year, day, minute, millisecond, or combinations thereof) and the origin (i.e., time zero) to which the time value is related." .

qudt:Time  rdf:type          owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Time";
        rdfs:subClassOf      qudt:ScalarDatatype;
        dcterms:description  "The class of data values that denote a point in time. Time values may be encoded in a 12-hour clock or a 24-hour clock, such as 1:35 AM, or 13:35." .

qudt:totalDigits  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "total digits" .

qudt:Tree  rdf:type           owl:Class;
        rdfs:isDefinedBy      <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label            "Tree Type";
        rdfs:subClassOf       qudt:Graph;
        dcterms:description   "\n  A \"Tree\" is a data type that defines the properties of data structures that represent trees. \n  Each node is either a leaf or an internal node. \n  An internal node has one or more child nodes and is called the parent of its child nodes. \n  Leaf nodes have no chidren. Nodes that share the same parent are siblings. \n  In graph theoretic terminology, a tree is a connected, undirected, acyclic graph.\n  ";
        prov:wasInfluencedBy  <http://en.wikipedia.org/wiki/Tree_(data_structure)> .

qudt:Triplet  rdf:type       owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Triplet";
        rdfs:seeAlso         qudt:ThreeTuple;
        rdfs:subClassOf      qudt:ThreeTuple;
        dcterms:description  "A \"Tuple\"." .

qudt:TupleMember  rdf:type   owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Tuple Member Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        dcterms:description  "\n  <p><em>Tuple Member</em> defines the properties of a member of a tuple. \n  It is used to provide fine grained type specification to the elements of tuples.\n  </p>\n  "^^rdf:HTML .

qudt:TupleType  rdf:type     owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Tuple Type";
        rdfs:subClassOf      qudt:CompositeDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:length
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:length
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementTypeCount
                             ];
        dcterms:description  "\n  <p><em>Tuple</em> originated as an abstraction of the sequence: single, double, triple, quadruple, quintuple, n-tuple.  \n  In mathematics, a tuple is a finite sequence (also known as an <em>Ordered List</em> of objects, each of a specified type. \n  The <em>n</em> can be any non-negative integer.\n  </p>\n  "^^rdf:HTML .

qudt:Tuple  rdf:type         owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Tuple";
        rdfs:subClassOf      qudt:CompositeDatatype;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:length
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:length
                             ];
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementTypeCount
                             ];
        dcterms:description  "\n  <p>The term <em>Tuple</em> originated as an abstraction of the sequence: single, double, triple, quadruple, quintuple, n-tuple. \n  In mathematics, a tuple is a finite sequence (also known as an <em>Ordered List</em> of objects, each of a specified type. \n  The <em>n</em> can be any non-negative integer.\n  </p>"^^rdf:HTML .

qudt:TwoTupleType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Two-Tuple Type";
        rdfs:subClassOf      qudt:N-TupleType;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "A 2-tuple is called a pair. For example, a complex number can be represented as a 2-tuple, and 2D coordinates are sometimes represented as 2-tuples." .

qudt:TwoTuple  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Two-Tuple";
        rdfs:subClassOf      qudt:N-Tuple;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:minCardinality  0;
                               owl:onProperty      qudt:elementDatatype
                             ];
        dcterms:description  "\n  A 2-tuple is called a pair. \n  For example, a complex number can be represented as a 2-tuple.\n  2D coordinates are sometimes represented as 2-tuples.\n  " .

qudt:TypeList  rdf:type      owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Type list";
        rdfs:subClassOf      qudt:Datatype;
        dcterms:description  "A sub-type of 'QUDT Datatype'." .

qudt:TypeMatrix  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Type matrix";
        rdfs:subClassOf      qudt:Matrix;
        dcterms:description  "\n  Members of this class are matrix data structures that describe the datatypes of a class of matrices. \n  That is, the members of this class are matrices with cells that contain datatypes (c.f. type:Datatype) and are used to describe the datatype structure of other matrices.\n  " .

qudt:typeMatrix  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "type matrix" .

qudt:TypeVector  rdf:type    owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Type vector";
        rdfs:subClassOf      qudt:Vector;
        dcterms:description  "\n  <p>A <em>Type Vector</em> is a vector whose elements are data types. \n  They are used to specify the type of each component of a vector or class of vectors. \n  </p>"^^rdf:HTML .

qudt:typeVector  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "type vector" .

qudt:type  rdf:type          owl:ObjectProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "type";
        rdfs:range           qudt:TimeStringType;
        dcterms:description  "A reference to the specification of the data type of a variable or constant." .

qudt:UnsignedBigIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Big Integer Type";
        rdfs:subClassOf      qudt:UnsignedIntegerType , qudt:BigIntegerType;
        dcterms:description  "An Unsgned Big Integer is an unsigned integer that can be represented in eight octets (64 bits) of machine memory." .

qudt:UnsignedIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Integer Type";
        rdfs:subClassOf      qudt:UnsignedType , qudt:IntegerDatatype;
        dcterms:description  "Unsgned Integers are integers that are either strictly non-negative or non-positive." .

qudt:UnsignedLongIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Long Integer Type";
        rdfs:subClassOf      qudt:UnsignedIntegerType , qudt:LongIntegerType;
        dcterms:description  "An Unsigned Long Integer is an unsigned integer that can be represented in four octets (32 bits) of machine memory." .

qudt:UnsignedMediumIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Medium Integer Type";
        rdfs:subClassOf      qudt:UnsignedIntegerType;
        dcterms:description  "\n  An \"Unsigned Medium Integer\" is an integer of 24 bits that only takes on both positive values.\n  " .

qudt:UnsignedShortIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Short Integer Type";
        rdfs:subClassOf      qudt:ShortIntegerType , qudt:UnsignedIntegerType;
        dcterms:description  "An Unsigned Short Integer is an unsigned integer that can be represented in four octets (32 bits) of machine memory." .

qudt:UnsignedType  rdf:type  owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Type";
        rdfs:subClassOf      qudt:NumericType;
        dcterms:description  "An unsigned data type is a numeric type that does not distinguish between positive and negative values." .

qudt:UnsignedVariableLengthIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Unsigned Variable Length Integer Type";
        rdfs:subClassOf      qudt:VariableLengthIntegerType , qudt:UnsignedIntegerType;
        dcterms:description  "\n  An \"Unsigned Variable Length Integer\" data type defines a data structure for representing unsigned integers that uses a variable number of bits depending on the magnitude of the integer. \n  Typically, variable length integer data types are between one and 64 bits in length.\n  " .

qudt:upperBound  rdf:type  owl:DatatypeProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "upper bound" .

qudt:UserModifiableParameter
        rdf:type             qudt:ParameterModifiabilityType;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "User modifiable parameter";
        dcterms:description  "Parameter is modifiable by a user.";
        dtype:code           "2";
        dtype:literal        "user" .

qudt:valueRange  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "value range" .

qudt:valueType  rdf:type  owl:AnnotationProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "value type" .

qudt:valueVector  rdf:type   owl:AnnotationProperty;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "value vector";
        dcterms:description  "A list of the values of elements in a Partial Array." .

qudt:VariableIntervalTimeSeriesArrayType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Variable Interval Time Series Array Type";
        rdfs:subClassOf      qudt:TimeSeriesArrayType;
        dcterms:description  "A Variable Interval Time Series Array Type is a data type that specifies the properties of arrays that hold time series data that has been sampled over non-uniformly spaced time intervals. A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals. For variable interval time series, the successive time intervals may follow a repeating pattern, or may be completely random." .

qudt:VariableIntervalTimeSeriesArray
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Variable Interval Time Series Array Type";
        rdfs:subClassOf      qudt:TimeSeriesArray;
        dcterms:description  "A Variable Interval Time Series Array Type is a data type that specifies the properties of arrays that hold time series data that has been sampled over non-uniformly spaced time intervals. A time series is a sequence of data points, measured typically at successive times, spaced at uniform or non-uniform time intervals. For variable interval time series, the successive time intervals may follow a repeating pattern, or may be completely random." .

qudt:VariableLengthIntegerType
        rdf:type             owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Variable Length Integer Type";
        rdfs:subClassOf      qudt:IntegerDatatype;
        dcterms:description  "\n  A \"Variable Length Integer\" data type defines a data structure for representing integers that uses a variable number of bits depending on the magnitude of the integer. \n  Typically, variable length integer data types are between one and 64 bits in length.\n  " .

qudt:vbName  rdf:type       owl:FunctionalProperty , owl:DatatypeProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "Visual Basic name";
        rdfs:range          xsd:string;
        rdfs:subPropertyOf  qudt:id .

qudt:Vector  rdf:type        owl:Class;
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "Vector";
        rdfs:subClassOf      qudt:Array;
        rdfs:subClassOf      [ rdf:type            owl:Restriction;
                               owl:maxCardinality  1;
                               owl:onProperty      qudt:quantity
                             ];
        dcterms:description  "\n  <p>A <em>Vector</em> is an array data type that can have a dimensionality of one, or more elements.\n  Vectors can represent physical quantities, such as velocity, force, displacement;\n  mathematical objects such as points or directions in space;\n  and abstract representations for things such as colors, features, or embeddings in computational contexts.\n  </p>\n  <p>As a one-dimensional mathematical object it can represent a quantity with both magnitude and direction in space.\n  One-dimensional vectors can be thought of as a special case of a 1D array.\n  For example a 3D vector can be expressed as a list of coordinates: [x,y,z].\n  </p>\n  <p>\n  A vector in n-dimensional space can represent a point, a direction, or a linear combination of basis vectors.\n  </p>\n  <p>\n  Vectors can represent quantifiable values.\n  For example a car moving at 60 m/hr to the north, assuming north is along the y-axis, can be represented in 2D as:\n  </p>\n  <dl>\n  <dd>[0, 60]</dd>\n  </dl>\n  <p>\n  In machine learning a <em>Feature Vector</em> can be expressed for a dataset entry as:\n  <p>\n  <dl>\n  <dd>[5.1, 3.5, 1.4, 0.2]</dd>\n  </dl>\n  <p>\n  In AI for text processing a <em>Word Embedding Vector</em> is expressed as a N-dimensional space, where N can be a large number.\n  </p>\n  "^^rdf:HTML .

qudt:vector  rdf:type     owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "vector";
        rdfs:range        qudt:Vector .

qudt:visualCueEnumeration
        rdf:type            owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "visual cue enumeration";
        rdfs:subPropertyOf  qudt:modalCueEnumeration .

qudt:VisualCue  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Visual Cue";
        rdfs:subClassOf   qudt:ModalCue .

qudt:visualCue  rdf:type    owl:FunctionalProperty , owl:ObjectProperty;
        rdfs:isDefinedBy    <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label          "visual cue";
        rdfs:subPropertyOf  qudt:modalCue .

qudt:WetDryStateType  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Wet dry state type";
        rdfs:subClassOf   qudt:EnumeratedValue , qudt:DiscreteState .

qudt:XSDatomicTypeUnion
        rdf:type             qudt:List;
        rdf:first            xsd:anySimpleType;
        rdf:rest             ( xsd:anySimpleType );
        rdfs:isDefinedBy     <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label           "XSD Atomic Type Union";
        dcterms:description  "\n  <p>In XML Schema Definition (XSD) xsd:anySimpleType is the base type for all simple types.\n  Simple types in XSD represent atomic values without any child elements or complex structures.\n  All simple types are compliant with xsd:anySimpleType.\n  </p>\n  <p>In XSD, the atomic types are: xsd:string, xsd:boolean, xsd:decimal, xsd:float,\n   xsd:double, xsd:duration, xsd:dateTime, xsd:time, xsd:date, xsd:gYearMonth, xsd:gYear, xsd:gMonthDay,\n   xsd:gDay, xsd:gMonth, xsd:hexBinary, xsd:base64Binary, xsd:anyURI, xsd:QName, and xsd:NOTATION.\n  </p>"^^rdf:HTML .

qudt:YesNoType  rdf:type  owl:Class;
        rdfs:isDefinedBy  <http://qudt.org/$$QUDT_VERSION$$/schema/datatype>;
        rdfs:label        "Yes no type";
        rdfs:subClassOf   qudt:EnumeratedValue .

