@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix pfx: <http://qudt.org/vocab/prefix/> .
@prefix profile: <http://qudt.org/schema/vocab/profile/> .
@prefix quantitykind: <http://qudt.org/vocab/quantitykind/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix unit: <http://qudt.org/vocab/unit/> .

profile:blocksIncludesShape
  a sh:NodeShape ;
  sh:property [
    sh:path qudt:blocksInclude ;
    sh:values [
      sh:path ( qudt:includes qudt:hasQuantityKind ) ;
      sh:path ( qudt:includes qudt:applicableUnit ) ;
    ] ;
  ] ;
  sh:targetNode profile:construction .

profile:construction
  a qudt:Profile ;
  qudt:includes pfx:Kilo ;
  qudt:includes quantitykind:Dimensionless ;
  qudt:includes quantitykind:DimensionlessRatio ;
  qudt:includes quantitykind:ElectricCurrent ;
  qudt:includes quantitykind:Frequency ;
  qudt:includes quantitykind:Illuminance ;
  qudt:includes quantitykind:LuminousFluxRatio ;
  qudt:includes quantitykind:Population ;
  qudt:includes quantitykind:Pressure ;
  qudt:includes quantitykind:Temperature ;
  qudt:includes quantitykind:ThermodynamicTemperature ;
  qudt:includes quantitykind:Unknown ;
  qudt:includes quantitykind:Voltage ;
  qudt:includes quantitykind:VolumeFlowRate ;
  qudt:includes quantitykind:VolumeFraction ;
  qudt:includes unit:A ;
  qudt:includes unit:DEG_F ;
  qudt:includes unit:FT3-PER-MIN ;
  qudt:includes unit:HZ ;
  qudt:includes unit:K ;
  qudt:includes unit:LUX ;
  qudt:includes unit:NUM ;
  qudt:includes unit:PERCENT ;
  qudt:includes unit:PSI ;
  qudt:includes unit:UNKNOWN ;
  qudt:includes unit:V .


